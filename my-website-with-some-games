<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Saket Arcade Offline</title>
  <style>
    :root {
      color-scheme: dark;
      --bg: #07111f;
      --panel: rgba(9, 16, 30, 0.82);
      --line: rgba(148, 163, 184, 0.2);
      --text: #e2e8f0;
      --muted: #94a3b8;
      --cyan: #22d3ee;
      --pink: #f472b6;
      --green: #4ade80;
      --amber: #f59e0b;
      --violet: #8b5cf6;
    }
    * { box-sizing: border-box; }
    html, body {
      margin: 0;
      min-height: 100%;
      background:
        radial-gradient(circle at top, rgba(34, 211, 238, 0.18), transparent 30%),
        radial-gradient(circle at bottom right, rgba(244, 114, 182, 0.12), transparent 30%),
        linear-gradient(180deg, #020617, #07111f 55%, #020617);
      color: var(--text);
      font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }
    body { overflow: hidden; }
    .app {
      height: 100vh;
      display: grid;
      grid-template-rows: auto auto 1fr;
    }
    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 18px 22px 14px;
      border-bottom: 1px solid var(--line);
      background: rgba(2, 6, 23, 0.76);
      backdrop-filter: blur(18px);
    }
    .brand {
      display: flex;
      align-items: center;
      gap: 14px;
    }
    .brand-mark {
      width: 42px;
      height: 42px;
      border-radius: 14px;
      background: linear-gradient(135deg, rgba(34, 211, 238, 0.95), rgba(139, 92, 246, 0.9));
      display: grid;
      place-items: center;
      color: #04101d;
      font-weight: 900;
      letter-spacing: 0.16em;
      box-shadow: 0 12px 40px rgba(34, 211, 238, 0.22);
    }
    .brand h1 {
      margin: 0;
      font-size: clamp(22px, 3vw, 34px);
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }
    .brand p {
      margin: 4px 0 0;
      color: var(--muted);
      font-size: 12px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }
    .status {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 14px;
      border: 1px solid rgba(74, 222, 128, 0.24);
      border-radius: 999px;
      background: rgba(10, 18, 32, 0.86);
      color: #bbf7d0;
      font-size: 12px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }
    .status-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: var(--green);
      box-shadow: 0 0 0 0 rgba(74, 222, 128, 0.7);
      animation: pulse 1.8s infinite;
    }
    .summary {
      display: flex;
      gap: 14px;
      padding: 18px 22px;
      border-bottom: 1px solid var(--line);
      overflow-x: auto;
    }
    .pill {
      min-width: 180px;
      padding: 14px 16px;
      border: 1px solid var(--line);
      border-radius: 18px;
      background: var(--panel);
      backdrop-filter: blur(18px);
      box-shadow: 0 18px 40px rgba(2, 6, 23, 0.28);
    }
    .pill .label {
      font-size: 11px;
      color: var(--muted);
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }
    .pill .value {
      margin-top: 8px;
      font-size: 26px;
      font-weight: 800;
      letter-spacing: 0.06em;
    }
    .content {
      display: grid;
      grid-template-columns: 260px 1fr;
      min-height: 0;
    }
    .sidebar {
      border-right: 1px solid var(--line);
      background: rgba(2, 6, 23, 0.54);
      padding: 20px 16px 22px;
      overflow-y: auto;
    }
    .tab-group {
      display: grid;
      gap: 10px;
    }
    .tab-btn {
      width: 100%;
      text-align: left;
      padding: 14px 16px;
      border-radius: 16px;
      border: 1px solid var(--line);
      background: rgba(15, 23, 42, 0.56);
      color: var(--text);
      cursor: pointer;
      transition: transform 0.18s ease, border-color 0.18s ease, background 0.18s ease;
    }
    .tab-btn strong {
      display: block;
      font-size: 13px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }
    .tab-btn span {
      display: block;
      margin-top: 6px;
      color: var(--muted);
      font-size: 12px;
      line-height: 1.5;
    }
    .tab-btn:hover,
    .tab-btn.active {
      transform: translateX(4px);
      border-color: rgba(34, 211, 238, 0.45);
      background: rgba(14, 116, 144, 0.14);
    }
    .note {
      margin-top: 18px;
      padding: 14px;
      border-radius: 16px;
      border: 1px solid rgba(139, 92, 246, 0.24);
      background: rgba(76, 29, 149, 0.1);
      color: #ddd6fe;
      font-size: 12px;
      line-height: 1.7;
    }
    .main {
      min-width: 0;
      display: grid;
      grid-template-rows: auto 1fr;
      padding: 22px;
      gap: 18px;
      overflow: hidden;
    }
    .hero {
      display: flex;
      justify-content: space-between;
      gap: 20px;
      padding: 22px;
      border-radius: 24px;
      border: 1px solid var(--line);
      background:
        radial-gradient(circle at right top, rgba(34, 211, 238, 0.16), transparent 35%),
        linear-gradient(145deg, rgba(9, 16, 30, 0.92), rgba(13, 21, 38, 0.84));
      box-shadow: 0 24px 80px rgba(2, 6, 23, 0.34);
    }
    .hero h2 {
      margin: 0;
      font-size: clamp(22px, 3vw, 36px);
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }
    .hero p {
      margin: 10px 0 0;
      max-width: 720px;
      color: var(--muted);
      line-height: 1.7;
      font-size: 14px;
    }
    .hero-badge {
      align-self: flex-start;
      padding: 10px 14px;
      border-radius: 999px;
      border: 1px solid rgba(34, 211, 238, 0.28);
      color: #a5f3fc;
      font-size: 12px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      white-space: nowrap;
      background: rgba(8, 47, 73, 0.34);
    }
    .grid {
      overflow-y: auto;
      padding-right: 4px;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 16px;
      align-content: start;
    }
    .card {
      position: relative;
      display: flex;
      flex-direction: column;
      min-height: 220px;
      border-radius: 22px;
      border: 1px solid var(--line);
      background: linear-gradient(180deg, rgba(15, 23, 42, 0.92), rgba(8, 15, 28, 0.92));
      overflow: hidden;
      box-shadow: 0 18px 50px rgba(2, 6, 23, 0.3);
    }
    .card-art {
      position: relative;
      height: 112px;
      display: grid;
      place-items: center;
      font-size: 42px;
      background: var(--art-bg, linear-gradient(135deg, #0f172a, #1d4ed8));
      isolation: isolate;
    }
    .card-art::after {
      content: "";
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at center, rgba(255,255,255,0.18), transparent 55%);
      mix-blend-mode: screen;
      pointer-events: none;
    }
    .card-body {
      padding: 16px;
      display: grid;
      gap: 10px;
      flex: 1;
    }
    .meta {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }
    .tag {
      padding: 5px 9px;
      border-radius: 999px;
      border: 1px solid rgba(255,255,255,0.18);
      font-size: 11px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #cbd5e1;
      background: rgba(15, 23, 42, 0.55);
    }
    .accent {
      color: var(--accent-color, #a5f3fc);
      font-size: 11px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      font-weight: 700;
    }
    .card h3 {
      margin: 0;
      font-size: 18px;
      letter-spacing: 0.04em;
    }
    .card p {
      margin: 0;
      color: var(--muted);
      font-size: 13px;
      line-height: 1.7;
      flex: 1;
    }
    .actions {
      display: flex;
      gap: 10px;
    }
    .launch {
      flex: 1;
      padding: 12px 14px;
      border: none;
      border-radius: 14px;
      background: var(--accent-color, var(--cyan));
      color: #04111c;
      font-weight: 900;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      cursor: pointer;
      transition: transform 0.18s ease, filter 0.18s ease;
    }
    .launch:hover {
      transform: translateY(-2px);
      filter: brightness(1.08);
    }
    .overlay {
      position: fixed;
      inset: 0;
      display: none;
      align-items: stretch;
      justify-content: center;
      background: rgba(2, 6, 23, 0.88);
      backdrop-filter: blur(12px);
      z-index: 20;
    }
    .overlay.show { display: flex; }
    .player {
      width: min(1400px, 100vw);
      height: 100vh;
      display: grid;
      grid-template-rows: auto 1fr;
      background: #020617;
    }
    .player-bar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 14px 18px;
      border-bottom: 1px solid rgba(148, 163, 184, 0.18);
      background: rgba(3, 7, 18, 0.92);
    }
    .player-info strong {
      display: block;
      font-size: 14px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }
    .player-info span {
      display: block;
      margin-top: 4px;
      color: var(--muted);
      font-size: 12px;
    }
    .controls-row {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }
    .player-btn {
      padding: 10px 14px;
      border-radius: 12px;
      border: 1px solid rgba(148, 163, 184, 0.22);
      background: rgba(15, 23, 42, 0.88);
      color: var(--text);
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      cursor: pointer;
    }
    .player iframe {
      width: 100%;
      height: 100%;
      border: 0;
      background: #000;
    }
    .empty {
      display: grid;
      place-items: center;
      min-height: 260px;
      color: var(--muted);
      border: 1px dashed rgba(148, 163, 184, 0.22);
      border-radius: 22px;
      text-transform: uppercase;
      letter-spacing: 0.18em;
      font-size: 12px;
    }
    @keyframes pulse {
      0% { box-shadow: 0 0 0 0 rgba(74, 222, 128, 0.7); }
      70% { box-shadow: 0 0 0 14px rgba(74, 222, 128, 0); }
      100% { box-shadow: 0 0 0 0 rgba(74, 222, 128, 0); }
    }
    @media (max-width: 920px) {
      .content { grid-template-columns: 1fr; }
      .sidebar { border-right: 0; border-bottom: 1px solid var(--line); }
      .hero { flex-direction: column; }
      .summary { padding-top: 14px; }
    }
  </style>
</head>
<body>
  <div class="app">
    <header class="topbar">
      <div class="brand">
        <div class="brand-mark">AR</div>
        <div>
          <h1>Saket Arcade</h1>
          <p>Offline single-file build for HTML runners</p>
        </div>
      </div>
      <div class="status"><span class="status-dot"></span> Internal Runtime Ready</div>
    </header>

    <section class="summary">
      <div class="pill"><div class="label">Games</div><div class="value">4</div></div>
      <div class="pill"><div class="label">Experiments</div><div class="value">1</div></div>
      <div class="pill"><div class="label">Runtime</div><div class="value">No Fetch</div></div>
      <div class="pill"><div class="label">Mode</div><div class="value">Paste + Play</div></div>
    </section>

    <section class="content">
      <aside class="sidebar">
        <div class="tab-group">
          <button class="tab-btn active" data-view="games">
            <strong>Games</strong>
            <span>Minecraft Builder, Glass Tag, Neon Overdrive, and Nitro Drift X.</span>
          </button>
          <button class="tab-btn" data-view="experiments">
            <strong>Experiments</strong>
            <span>Fluid Sensory Playground lives here as a standalone visual lab.</span>
          </button>
          <button class="tab-btn" data-view="all">
            <strong>All</strong>
            <span>Show every internal build in one grid.</span>
          </button>
        </div>
        <div class="note">
          This page is now fully internal. You can paste this one file into an HTML runner and the requested new games will still open because their code is embedded inside the page.
        </div>
      </aside>

      <main class="main">
        <section class="hero">
          <div>
            <h2 id="hero-title">Games</h2>
            <p id="hero-copy">Your requested game updates are embedded directly in this file. No GitHub fetches, no runtime dependency on repo URLs, and no missing cards when you paste it into a runner.</p>
          </div>
          <div class="hero-badge" id="hero-badge">4 Internal Builds</div>
        </section>
        <section class="grid" id="card-grid"></section>
      </main>
    </section>
  </div>

  <div class="overlay" id="overlay">
    <div class="player">
      <div class="player-bar">
        <div class="player-info">
          <strong id="player-title">Game</strong>
          <span id="player-subtitle">Internal sandbox build</span>
        </div>
        <div class="controls-row">
          <button class="player-btn" id="reload-btn">Reload</button>
          <button class="player-btn" id="close-btn">Close</button>
        </div>
      </div>
      <iframe id="game-frame" title="Embedded game sandbox" sandbox="allow-scripts allow-same-origin"></iframe>
    </div>
  </div>

  <script>
    const GAME_HTML = {
      minecraft: `<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Minecraft Builder</title>
<style>
:root{color-scheme:dark}
*{box-sizing:border-box}
body{margin:0;background:linear-gradient(180deg,#09111d,#0f172a);color:#e2e8f0;font-family:Inter,system-ui,sans-serif;display:grid;grid-template-rows:auto 1fr;min-height:100vh}
.top{display:flex;justify-content:space-between;gap:12px;padding:14px 16px;border-bottom:1px solid rgba(148,163,184,.2);background:rgba(2,6,23,.72);backdrop-filter:blur(12px)}
.top h1{margin:0;font-size:20px;letter-spacing:.14em;text-transform:uppercase}.top p{margin:4px 0 0;color:#94a3b8;font-size:12px}
.wrap{display:grid;grid-template-columns:300px 1fr;min-height:0}.panel{padding:16px;border-right:1px solid rgba(148,163,184,.18);background:rgba(2,6,23,.45)}
.palette{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px;margin-top:14px}.block{padding:12px;border-radius:14px;border:1px solid rgba(148,163,184,.2);cursor:pointer;background:#111827;color:#e2e8f0;text-align:left;font-weight:700}.block.active{outline:2px solid #22c55e;transform:translateY(-2px)}
.controls{margin-top:16px;padding:14px;border-radius:16px;background:rgba(15,23,42,.72);border:1px solid rgba(148,163,184,.18);font-size:12px;line-height:1.7;color:#cbd5e1}
.controls strong{display:block;margin-bottom:8px;letter-spacing:.12em;text-transform:uppercase;color:#86efac}
.btn-row{display:flex;gap:10px;margin-top:14px;flex-wrap:wrap}.btn{padding:10px 12px;border-radius:12px;border:1px solid rgba(148,163,184,.22);background:#0f172a;color:#e2e8f0;font-weight:700;letter-spacing:.1em;text-transform:uppercase;cursor:pointer}
.stage{position:relative;overflow:auto;background:radial-gradient(circle at top,rgba(34,197,94,.12),transparent 30%),#020617}.stage-inner{min-width:900px;min-height:700px;display:grid;place-items:center;padding:24px}
canvas{max-width:100%;background:linear-gradient(180deg,#87ceeb 0%,#bfdbfe 42%,#0f172a 42%,#111827 100%);border-radius:24px;box-shadow:0 24px 80px rgba(2,6,23,.45)}
.stat{margin-top:14px;display:flex;gap:10px;flex-wrap:wrap}.chip{padding:8px 10px;border-radius:999px;background:rgba(30,41,59,.78);border:1px solid rgba(148,163,184,.18);font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:#cbd5e1}
@media(max-width:900px){.wrap{grid-template-columns:1fr}.panel{border-right:0;border-bottom:1px solid rgba(148,163,184,.18)}}
</style>
</head>
<body>
<header class="top"><div><h1>Minecraft Builder</h1><p>Build a colorful block world with height, palettes, terrain presets, and a paste-friendly offline canvas sandbox.</p></div><div class="chip" id="mode-chip">Mode: Build</div></header>
<div class="wrap">
  <aside class="panel">
    <div><strong style="letter-spacing:.14em;text-transform:uppercase;font-size:12px;color:#86efac">Palette</strong></div>
    <div class="palette" id="palette"></div>
    <div class="btn-row">
      <button class="btn" id="terrain-btn">Random Terrain</button>
      <button class="btn" id="clear-btn">Clear</button>
    </div>
    <div class="stat"><div class="chip" id="selected-chip">Block: Grass</div><div class="chip" id="cursor-chip">Cell: 0,0</div></div>
    <div class="controls">
      <strong>Controls</strong>
      Move your cursor with the mouse. Left click raises a block with the selected material. Right click lowers it. Hold Shift while clicking to repaint the top block without changing height.
    </div>
  </aside>
  <section class="stage"><div class="stage-inner"><canvas id="world" width="900" height="700"></canvas></div></section>
</div>
<script>
const canvas=document.getElementById('world');
const ctx=canvas.getContext('2d');
const size=10;
const tileW=46;
const tileH=23;
const originX=canvas.width/2;
const originY=170;
const maxHeight=8;
const palette=[
  {name:'Grass',top:'#4ade80',left:'#22c55e',right:'#16a34a'},
  {name:'Stone',top:'#cbd5e1',left:'#94a3b8',right:'#64748b'},
  {name:'Clay',top:'#fdba74',left:'#fb923c',right:'#f97316'},
  {name:'Water',top:'#38bdf8',left:'#0ea5e9',right:'#0284c7'},
  {name:'Amethyst',top:'#c4b5fd',left:'#8b5cf6',right:'#6d28d9'},
  {name:'Sand',top:'#fde68a',left:'#fcd34d',right:'#f59e0b'}
];
let selected=0;
const grid=Array.from({length:size},()=>Array.from({length:size},()=>({h:0,t:0})));
let hover={x:-1,y:-1};
const paletteEl=document.getElementById('palette');
const selectedChip=document.getElementById('selected-chip');
const cursorChip=document.getElementById('cursor-chip');
const modeChip=document.getElementById('mode-chip');
function buildPalette(){paletteEl.innerHTML='';palette.forEach((mat,index)=>{const btn=document.createElement('button');btn.className='block'+(index===selected?' active':'');btn.innerHTML='<div style="display:flex;align-items:center;gap:10px"><span style="width:16px;height:16px;border-radius:999px;background:'+mat.top+';display:inline-block"></span>'+mat.name+'</div>';btn.onclick=()=>{selected=index;buildPalette();selectedChip.textContent='Block: '+palette[selected].name;};paletteEl.appendChild(btn);});}
function isoToScreen(x,y,h){return{x:originX+(x-y)*tileW/2,y:originY+(x+y)*tileH/2-h*18};}
function drawColumn(x,y,h,t){if(h<=0)return;const mat=palette[t];const p=isoToScreen(x,y,h);ctx.beginPath();ctx.moveTo(p.x,p.y);ctx.lineTo(p.x+tileW/2,p.y+tileH/2);ctx.lineTo(p.x,p.y+tileH);ctx.lineTo(p.x-tileW/2,p.y+tileH/2);ctx.closePath();ctx.fillStyle=mat.top;ctx.fill();ctx.strokeStyle='rgba(15,23,42,.5)';ctx.stroke();ctx.beginPath();ctx.moveTo(p.x-tileW/2,p.y+tileH/2);ctx.lineTo(p.x,p.y+tileH);ctx.lineTo(p.x,p.y+tileH+h*18);ctx.lineTo(p.x-tileW/2,p.y+tileH/2+h*18);ctx.closePath();ctx.fillStyle=mat.left;ctx.fill();ctx.beginPath();ctx.moveTo(p.x+tileW/2,p.y+tileH/2);ctx.lineTo(p.x,p.y+tileH);ctx.lineTo(p.x,p.y+tileH+h*18);ctx.lineTo(p.x+tileW/2,p.y+tileH/2+h*18);ctx.closePath();ctx.fillStyle=mat.right;ctx.fill();}
function drawGrid(){ctx.clearRect(0,0,canvas.width,canvas.height);for(let gy=0;gy<size;gy++){for(let gx=0;gx<size;gx++){const base=isoToScreen(gx,gy,0);ctx.beginPath();ctx.moveTo(base.x,base.y);ctx.lineTo(base.x+tileW/2,base.y+tileH/2);ctx.lineTo(base.x,base.y+tileH);ctx.lineTo(base.x-tileW/2,base.y+tileH/2);ctx.closePath();ctx.fillStyle='rgba(30,41,59,.58)';ctx.fill();ctx.strokeStyle='rgba(148,163,184,.22)';ctx.stroke();}}
for(let gy=0;gy<size;gy++){for(let gx=size-1;gx>=0;gx--){const cell=grid[gx][gy];drawColumn(gx,gy,cell.h,cell.t);}}
if(hover.x>=0){const cell=grid[hover.x][hover.y];const p=isoToScreen(hover.x,hover.y,cell.h+1);ctx.beginPath();ctx.moveTo(p.x,p.y);ctx.lineTo(p.x+tileW/2,p.y+tileH/2);ctx.lineTo(p.x,p.y+tileH);ctx.lineTo(p.x-tileW/2,p.y+tileH/2);ctx.closePath();ctx.strokeStyle='rgba(255,255,255,.92)';ctx.lineWidth=2;ctx.stroke();ctx.lineWidth=1;}}
