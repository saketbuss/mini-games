      const el = document.createElement('article');
      el.className = 'port-card';
      el.innerHTML = '<div class="port-card-thumb" style="background:'+card.bg+'"><span>'+card.icon+'</span></div><div class="port-card-body"><div class="port-top"><span class="port-tag">'+card.tag+'</span><span class="port-accent">OPEN</span></div><h3 class="port-card-name">'+card.title+'</h3><p class="port-card-desc">'+card.desc+'</p><div class="port-actions"><button class="port-open-btn" style="--btn-accent:'+card.accent+'" data-open="'+card.id+'">OPEN</button></div></div>';
      return el;
    }

    function createArenaCard(item) {
      const el = document.createElement('div');
      el.className = 'mini-card';
      el.innerHTML = '<strong>'+item.title+'</strong><span>'+item.copy+'</span>';
      return el;
    }

    function renderAll() {
      gameGrid.innerHTML = '';
      GAME_CARDS.forEach(card => gameGrid.appendChild(createGameCard(card)));
      portsGrid.innerHTML = '';
      EXPERIMENT_CARDS.forEach(card => portsGrid.appendChild(createPortCard(card)));
      arenaList.innerHTML = '';
      RECENT_ADDS.forEach(item => arenaList.appendChild(createArenaCard(item)));
    }

    function gamePayload(id) {
      return GAME_HTML[id] || PLACEHOLDER_HTML;
    }

    function gameMeta(id) {
      return GAME_CARDS.concat(EXPERIMENT_CARDS).find(card => card.id === id) || {title:'GAME', tag:'LOCAL'};
    }

    function openGame(id) {
      const meta = gameMeta(id);
      titleEl.textContent = meta.title.toUpperCase();
      subEl.textContent = meta.kind === 'internal' ? 'LOCAL OFFLINE BUILD' : 'ARCADE SHELL SLOT';
      frame.srcdoc = gamePayload(id);
      overlay.classList.add('show');
      document.body.style.overflow = 'hidden';
    }

    function closeGame() {
      overlay.classList.remove('show');
      frame.srcdoc = '';
      document.body.style.overflow = 'hidden';
    }

    function switchView(id) {
      document.querySelectorAll('.view').forEach(view => view.classList.toggle('active', view.id === id));
      document.querySelectorAll('.nav-btn[data-view]').forEach(btn => btn.classList.toggle('active', btn.dataset.view === id));
    }

    document.addEventListener('click', event => {
      const openId = event.target.getAttribute('data-open');
      if (openId) openGame(openId);
      const viewId = event.target.getAttribute('data-view');
      if (viewId) switchView(viewId);
    });

    document.getElementById('play-featured').addEventListener('click', () => openGame('aros'));
    document.getElementById('open-experiments').addEventListener('click', () => switchView('ports-view'));
    document.getElementById('settings-open').addEventListener('click', () => settingsPanel.classList.toggle('show'));
    document.getElementById('terms-yes').addEventListener('click', () => {
      terms.classList.add('hide');
      appShell.classList.remove('hidden');
    });
    document.getElementById('terms-no').addEventListener('click', () => {
      terms.classList.add('hide');
      appShell.classList.remove('hidden');
    });
    document.getElementById('eg-close').addEventListener('click', closeGame);
    document.getElementById('eg-full').addEventListener('click', () => {
      const player = document.querySelector('.player');
      if (player.requestFullscreen) player.requestFullscreen();
    });
    addEventListener('keydown', event => {
      if (event.key === 'Escape') {
        settingsPanel.classList.remove('show');
        if (overlay.classList.contains('show')) closeGame();
      }
    });

    renderAll();
    bootSequence();
  </script>
</body>
</html>
