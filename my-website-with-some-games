<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SAKET'S SITE // GAME ARCADE</title>
  <style>
    :root {
      color-scheme: dark;
      --bg-0: #020617;
      --bg-1: #071120;
      --bg-2: #0f172a;
      --line: rgba(148, 163, 184, 0.16);
      --line-strong: rgba(148, 163, 184, 0.26);
      --text: #e2e8f0;
      --muted: #94a3b8;
      --cyan: #22d3ee;
      --blue: #38bdf8;
      --pink: #f472b6;
      --green: #4ade80;
      --amber: #f59e0b;
      --violet: #8b5cf6;
      --card: rgba(15, 23, 42, 0.78);
      --card-2: rgba(8, 15, 28, 0.88);
      --shadow: 0 28px 90px rgba(2, 6, 23, 0.42);
    }
    * { box-sizing: border-box; }
    html, body {
      margin: 0;
      min-height: 100%;
      background:
        radial-gradient(circle at top, rgba(34, 211, 238, 0.16), transparent 28%),
        radial-gradient(circle at bottom right, rgba(244, 114, 182, 0.12), transparent 24%),
        linear-gradient(180deg, #020617, #071120 48%, #020617);
      color: var(--text);
      font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }
    body {
      overflow: hidden;
    }
    button, input {
      font: inherit;
    }
    .hidden {
      display: none !important;
    }
    .boot {
      position: fixed;
      inset: 0;
      z-index: 40;
      display: grid;
      place-items: center;
      background:
        radial-gradient(circle at top, rgba(56, 189, 248, 0.16), transparent 35%),
        linear-gradient(180deg, #020617, #071120 58%, #020617);
      transition: opacity 0.35s ease, visibility 0.35s ease;
    }
    .boot.hide {
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
    }
    .boot-shell {
      width: min(560px, calc(100vw - 32px));
      padding: 28px 24px;
      border-radius: 28px;
      border: 1px solid var(--line-strong);
      background: rgba(9, 16, 30, 0.82);
      backdrop-filter: blur(18px);
      box-shadow: var(--shadow);
    }
    .boot-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      color: #a5f3fc;
      font-size: 12px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }
    .boot h1 {
      margin: 18px 0 6px;
      font-size: clamp(32px, 6vw, 48px);
      letter-spacing: 0.16em;
      line-height: 0.95;
      text-transform: uppercase;
    }
    .boot p {
      margin: 0;
      color: var(--muted);
      line-height: 1.7;
      font-size: 14px;
    }
    .progress {
      margin-top: 20px;
      height: 10px;
      border-radius: 999px;
      background: rgba(148, 163, 184, 0.14);
      overflow: hidden;
    }
    .progress > span {
      display: block;
      width: 0;
      height: 100%;
      border-radius: 999px;
      background: linear-gradient(90deg, var(--cyan), var(--violet));
      transition: width 0.18s ease;
    }
    .shell {
      height: 100vh;
      display: grid;
      grid-template-columns: 1fr 340px;
      background: transparent;
    }
    .main-shell {
      min-width: 0;
      display: grid;
      grid-template-rows: auto auto 1fr;
    }
    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 20px;
      padding: 20px 22px 16px;
      border-bottom: 1px solid var(--line);
      background: rgba(2, 6, 23, 0.72);
      backdrop-filter: blur(18px);
    }
    .brand {
      display: flex;
      align-items: center;
      gap: 14px;
    }
    .brand-mark {
      width: 44px;
      height: 44px;
      border-radius: 15px;
      display: grid;
      place-items: center;
      color: #04111c;
      font-weight: 900;
      letter-spacing: 0.18em;
      background: linear-gradient(135deg, var(--cyan), var(--blue));
      box-shadow: 0 14px 38px rgba(34, 211, 238, 0.24);
    }
    .brand-title {
      margin: 0;
      font-size: clamp(24px, 3vw, 36px);
      letter-spacing: 0.18em;
      text-transform: uppercase;
      line-height: 0.95;
    }
    .brand-sub {
      margin: 6px 0 0;
      color: var(--muted);
      font-size: 12px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }
    .top-actions {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      justify-content: flex-end;
    }
    .nav-btn, .ghost-btn {
      padding: 11px 14px;
      border-radius: 14px;
      border: 1px solid var(--line-strong);
      background: rgba(15, 23, 42, 0.74);
      color: var(--text);
      letter-spacing: 0.12em;
      text-transform: uppercase;
      cursor: pointer;
      transition: transform 0.18s ease, border-color 0.18s ease, background 0.18s ease;
    }
    .nav-btn.active, .nav-btn:hover, .ghost-btn:hover {
      transform: translateY(-1px);
      border-color: rgba(34, 211, 238, 0.42);
      background: rgba(8, 47, 73, 0.34);
    }
    .hero {
      display: grid;
      grid-template-columns: minmax(0, 1.2fr) 320px;
      gap: 18px;
      padding: 20px 22px 0;
    }
    .hero-panel, .board-panel {
      border: 1px solid var(--line);
      border-radius: 26px;
      background:
        radial-gradient(circle at top right, rgba(34, 211, 238, 0.14), transparent 35%),
        linear-gradient(145deg, rgba(9, 16, 30, 0.9), rgba(12, 20, 36, 0.86));
      box-shadow: var(--shadow);
    }
    .hero-panel {
      padding: 24px;
      overflow: hidden;
      position: relative;
    }
    .hero-panel::after {
      content: "";
      position: absolute;
      inset: -1px;
      background:
        linear-gradient(transparent 31px, rgba(255,255,255,0.04) 32px),
        linear-gradient(90deg, transparent 31px, rgba(255,255,255,0.04) 32px);
      background-size: 32px 32px;
      mask-image: linear-gradient(180deg, rgba(0,0,0,0.48), rgba(0,0,0,0));
      pointer-events: none;
    }
    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 12px;
      border-radius: 999px;
      color: #a5f3fc;
      background: rgba(14, 165, 233, 0.12);
      font-size: 12px;
      font-weight: 800;
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }
    .hero-title {
      margin: 18px 0 8px;
      font-size: clamp(28px, 5vw, 48px);
      line-height: 0.95;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      position: relative;
      z-index: 1;
    }
    .hero-copy {
      margin: 0;
      max-width: 760px;
      color: var(--muted);
      line-height: 1.75;
      font-size: 14px;
      position: relative;
      z-index: 1;
    }
    .hero-buttons {
      margin-top: 22px;
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      position: relative;
      z-index: 1;
    }
    .primary-btn {
      padding: 13px 16px;
      border-radius: 16px;
      border: none;
      background: linear-gradient(135deg, var(--cyan), var(--blue));
      color: #021018;
      font-weight: 900;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      cursor: pointer;
      transition: transform 0.18s ease, filter 0.18s ease;
    }
    .primary-btn:hover {
      transform: translateY(-1px);
      filter: brightness(1.05);
    }
    .board-panel {
      padding: 20px;
      display: grid;
      gap: 10px;
      align-content: start;
    }
    .panel-title {
      margin: 0;
      font-size: 12px;
      color: #a5f3fc;
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }
    .board-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      padding: 12px 0;
      border-bottom: 1px solid rgba(148, 163, 184, 0.12);
      font-size: 13px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }
    .board-row:last-child {
      border-bottom: 0;
    }
    .board-row span:last-child {
      color: var(--muted);
    }
    .stats {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 14px;
      padding: 18px 22px 0;
    }
    .stat {
      padding: 16px;
      border-radius: 22px;
      border: 1px solid var(--line);
      background: rgba(9, 16, 30, 0.72);
      box-shadow: 0 16px 44px rgba(2, 6, 23, 0.26);
    }
    .stat-label {
      color: var(--muted);
      font-size: 11px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }
    .stat-value {
      margin-top: 8px;
      font-size: 28px;
      font-weight: 900;
      letter-spacing: 0.1em;
    }
    .views {
      min-height: 0;
      padding: 18px 22px 22px;
      overflow: hidden;
    }
    .view {
      height: 100%;
      display: none;
      overflow: hidden;
    }
    .view.active {
      display: grid;
      grid-template-rows: auto 1fr;
      gap: 16px;
    }
    .section-head {
      display: flex;
      align-items: end;
      justify-content: space-between;
      gap: 16px;
    }
    .section-left h2 {
      margin: 0;
      font-size: 13px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }
    .section-left p {
      margin: 10px 0 0;
      color: var(--muted);
      line-height: 1.7;
      font-size: 13px;
      max-width: 760px;
    }
    .section-count {
      padding: 10px 14px;
      border-radius: 999px;
      border: 1px solid var(--line-strong);
      color: #cbd5e1;
      font-size: 12px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      white-space: nowrap;
      background: rgba(15, 23, 42, 0.72);
    }
    .grid-scroll {
      overflow-y: auto;
      padding-right: 4px;
    }
    .game-grid, .ports-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 16px;
      align-content: start;
    }
    .gc, .port-card {
      display: flex;
      flex-direction: column;
      border-radius: 22px;
      border: 1px solid var(--line);
      background: linear-gradient(180deg, rgba(15, 23, 42, 0.92), rgba(7, 13, 26, 0.92));
      overflow: hidden;
      box-shadow: 0 20px 48px rgba(2, 6, 23, 0.3);
    }
    .gc-thumb, .port-card-thumb {
      position: relative;
      height: 118px;
      display: grid;
      place-items: center;
      font-size: 42px;
      isolation: isolate;
    }
    .gc-thumb::after, .port-card-thumb::after {
      content: "";
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at center, rgba(255,255,255,0.16), transparent 58%);
      mix-blend-mode: screen;
      pointer-events: none;
    }
    .gc-body, .port-card-body {
      padding: 16px;
      display: grid;
      gap: 10px;
      flex: 1;
    }
    .gc-top, .port-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }
    .gc-tag, .port-tag {
      padding: 5px 9px;
      border-radius: 999px;
      border: 1px solid rgba(255,255,255,0.16);
      background: rgba(15, 23, 42, 0.58);
      color: #cbd5e1;
      font-size: 10px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }
    .gc-author, .port-accent {
      color: var(--muted);
      font-size: 11px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }
    .gc-name, .port-card-name {
      margin: 0;
      font-size: 18px;
      letter-spacing: 0.04em;
    }
    .port-card-desc {
      margin: 0;
      color: var(--muted);
      font-size: 13px;
      line-height: 1.7;
    }
    .gc-actions, .port-actions {
      display: flex;
      gap: 10px;
      margin-top: auto;
    }
    .play-btn, .port-open-btn {
      flex: 1;
      padding: 12px 14px;
      border: none;
      border-radius: 14px;
      background: var(--btn-accent, var(--cyan));
      color: #04111c;
      font-weight: 900;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      cursor: pointer;
      transition: transform 0.18s ease, filter 0.18s ease;
    }
    .play-btn:hover, .port-open-btn:hover {
      transform: translateY(-1px);
      filter: brightness(1.06);
    }
    .arena-wrap {
      display: grid;
      grid-template-columns: 1.2fr 0.8fr;
      gap: 16px;
      min-height: 0;
    }
    .arena-panel, .arena-list {
      border: 1px solid var(--line);
      border-radius: 24px;
      background: rgba(9, 16, 30, 0.78);
      box-shadow: 0 20px 52px rgba(2, 6, 23, 0.3);
    }
    .arena-panel {
      padding: 22px;
      display: grid;
      gap: 14px;
      align-content: start;
    }
    .arena-panel h3, .arena-list h3 {
      margin: 0;
      font-size: 14px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }
    .arena-panel p {
      margin: 0;
      color: var(--muted);
      line-height: 1.75;
      font-size: 14px;
    }
    .arena-card-list {
      padding: 16px;
      display: grid;
      gap: 12px;
      overflow-y: auto;
      min-height: 0;
    }
    .mini-card {
      display: grid;
      gap: 6px;
      padding: 14px;
      border-radius: 18px;
      border: 1px solid var(--line);
      background: rgba(15, 23, 42, 0.72);
    }
    .mini-card strong {
      font-size: 14px;
      letter-spacing: 0.04em;
    }
    .mini-card span {
      color: var(--muted);
      font-size: 12px;
      line-height: 1.6;
    }
    .sidebar {
      border-left: 1px solid var(--line);
      background: rgba(2, 6, 23, 0.72);
      backdrop-filter: blur(18px);
      display: grid;
      grid-template-rows: auto 1fr auto;
      min-height: 0;
    }
    .ai-head, .settings-head {
      padding: 18px 18px 12px;
      border-bottom: 1px solid var(--line);
    }
    .ai-title, .settings-title {
      margin: 0;
      font-size: 13px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }
    .ai-copy {
      margin: 10px 0 0;
      color: var(--muted);
      font-size: 13px;
      line-height: 1.7;
    }
    .ai-quick {
      padding: 14px 18px 0;
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }
    .chip-btn {
      padding: 9px 12px;
      border-radius: 999px;
      border: 1px solid var(--line-strong);
      background: rgba(15, 23, 42, 0.84);
      color: var(--text);
      cursor: pointer;
    }
    .chat {
      padding: 16px 18px;
      overflow-y: auto;
      display: grid;
      align-content: start;
      gap: 12px;
    }
    .bubble {
      padding: 14px;
      border-radius: 18px;
      background: rgba(15, 23, 42, 0.82);
      border: 1px solid var(--line);
      color: #dbe5f2;
      font-size: 13px;
      line-height: 1.7;
    }
    .bubble strong {
      display: block;
      margin-bottom: 6px;
      color: #a5f3fc;
      font-size: 11px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }
    .chatbox {
      padding: 14px 18px 18px;
      border-top: 1px solid var(--line);
      display: grid;
      gap: 10px;
    }
    .chatbox input {
      width: 100%;
      padding: 12px 14px;
      border-radius: 14px;
      border: 1px solid var(--line-strong);
      background: rgba(15, 23, 42, 0.82);
      color: var(--text);
    }
    .settings-panel {
      position: fixed;
      right: 24px;
      top: 24px;
      width: min(380px, calc(100vw - 32px));
      max-height: calc(100vh - 48px);
      overflow-y: auto;
      z-index: 26;
      display: none;
      border-radius: 24px;
      border: 1px solid var(--line-strong);
      background: rgba(8, 14, 28, 0.96);
      box-shadow: var(--shadow);
    }
    .settings-panel.show {
      display: block;
    }
    .settings-body {
      padding: 16px 18px 18px;
      display: grid;
      gap: 14px;
    }
    .setting {
      padding: 14px;
      border-radius: 18px;
      border: 1px solid var(--line);
      background: rgba(15, 23, 42, 0.74);
    }
    .setting strong {
      display: block;
      font-size: 12px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }
    .setting span {
      display: block;
      margin-top: 8px;
      color: var(--muted);
      line-height: 1.7;
      font-size: 13px;
    }
    .setting-line {
      margin-top: 12px;
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }
    .pill {
      padding: 8px 10px;
      border-radius: 999px;
      border: 1px solid var(--line-strong);
      background: rgba(2, 6, 23, 0.6);
      color: #dbe5f2;
      font-size: 12px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }
    .terms {
      position: fixed;
      inset: 0;
      z-index: 30;
      display: grid;
      place-items: center;
      background: rgba(2, 6, 23, 0.72);
      backdrop-filter: blur(12px);
    }
    .terms.hide {
      display: none;
    }
    .terms-card {
      width: min(620px, calc(100vw - 32px));
      padding: 26px 24px;
      border-radius: 24px;
      border: 1px solid var(--line-strong);
      background: rgba(8, 14, 28, 0.96);
      box-shadow: var(--shadow);
    }
    .terms-card h2 {
      margin: 0;
      font-size: 14px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
    }
    .terms-card p, .terms-card li {
      color: var(--muted);
      font-size: 14px;
      line-height: 1.8;
    }
    .terms-actions {
      margin-top: 18px;
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
    }
    .overlay {
      position: fixed;
      inset: 0;
      z-index: 35;
      display: none;
      align-items: stretch;
      justify-content: center;
      background: rgba(2, 6, 23, 0.88);
      backdrop-filter: blur(12px);
    }
    .overlay.show {
      display: flex;
    }
    .player {
      width: min(1440px, 100vw);
      height: 100vh;
      display: grid;
      grid-template-rows: auto 1fr;
      background: #020617;
    }
    .player-bar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 14px 18px;
      border-bottom: 1px solid var(--line);
      background: rgba(3, 7, 18, 0.92);
    }
    .player-info strong {
      display: block;
      font-size: 14px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }
    .player-info span {
      display: block;
      margin-top: 4px;
      color: var(--muted);
      font-size: 12px;
    }
    .player-actions {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }
    .player-btn {
      padding: 10px 14px;
      border-radius: 12px;
      border: 1px solid var(--line-strong);
      background: rgba(15, 23, 42, 0.88);
      color: var(--text);
      letter-spacing: 0.12em;
      text-transform: uppercase;
      cursor: pointer;
    }
    iframe {
      width: 100%;
      height: 100%;
      border: 0;
      background: #000;
    }
    @media (max-width: 1200px) {
      .shell {
        grid-template-columns: 1fr;
      }
      .sidebar {
        display: none;
      }
    }
    @media (max-width: 960px) {
      .hero {
        grid-template-columns: 1fr;
      }
      .stats {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
      .arena-wrap {
        grid-template-columns: 1fr;
      }
    }
    @media (max-width: 640px) {
      .stats {
        grid-template-columns: 1fr;
      }
      .topbar {
        align-items: start;
        flex-direction: column;
      }
      .section-head {
        align-items: start;
        flex-direction: column;
      }
    }
  </style>
</head>
<body>
  <div class="boot" id="boot-screen">
    <div class="boot-shell">
      <div class="boot-top">
        <span>GAME ARCADE // AR.OS v7</span>
        <span id="boot-percent">0%</span>
      </div>
      <h1>SAKET'S SITE<br>GAME ARCADE</h1>
      <p>// INITIALISING SYSTEMS...</p>
      <div class="progress"><span id="boot-bar"></span></div>
    </div>
  </div>

  <div class="terms" id="terms-modal">
    <div class="terms-card">
      <h2>TERMS OF CONDITIONS</h2>
      <p>// SAKET'S SITE · GAME ARCADE</p>
      <p>By clicking YES you are confirming that:</p>
      <ul>
        <li>You are not currently in school hours.</li>
        <li>You take full responsibility for your own time management.</li>
        <li>This site is for personal entertainment only.</li>
      </ul>
      <div class="terms-actions">
        <button class="ghost-btn" id="terms-no">NO, I'M IN SCHOOL</button>
        <button class="primary-btn" id="terms-yes">YES, I AGREE</button>
      </div>
    </div>
  </div>

  <div class="settings-panel" id="settings-panel">
    <div class="settings-head">
      <h2 class="settings-title">SETTINGS // AR.OS</h2>
    </div>
    <div class="settings-body">
      <div class="setting">
        <strong>DISPLAY</strong>
        <span>Theme</span>
        <span>Light or dark mode</span>
        <div class="setting-line">
          <span class="pill">Dark (Default)</span>
          <span class="pill">Light</span>
        </div>
