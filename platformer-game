    },
 
    draw() {
        if (this.isDead) return;
        const skin=SKINS[skinIdx];
        const od=this.odTimer>0;
        const glowCol=od?(Math.floor(gtime/45)%2===0?'#ff00ff':'#00ffee'):skin.main;
        const blinking=this.invincible>0&&Math.floor(gtime/80)%2===0;
        if (blinking) return;
 
        // Trail
        ctx.globalCompositeOperation='lighter';
        for (const t of this.trail) {
            ctx.save();
            ctx.translate(t.x+this.w/2,t.y+this.h);
            ctx.scale(t.sx,t.sy); ctx.rotate(t.rot||0);
            ctx.fillStyle=glowCol; ctx.globalAlpha=t.life*0.35;
            ctx.beginPath(); ctx.ellipse(0,-this.h/2,this.w/2,this.h/2,0,0,Math.PI*2); ctx.fill();
            ctx.restore();
        }
        ctx.globalCompositeOperation='source-over';
 
        ctx.save();
        ctx.translate(this.x+this.w/2,this.y+this.h);
        ctx.scale(this.sx,this.sy); ctx.rotate(this.rot);
 
        // Outer glow body
        ctx.shadowBlur=od?50:28; ctx.shadowColor=glowCol;
        ctx.fillStyle=glowCol;
        ctx.beginPath(); ctx.ellipse(0,-this.h/2+2,this.w/2,this.h/2-2,0,0,Math.PI*2); ctx.fill();
 
        // Core
        ctx.shadowBlur=0;
        ctx.fillStyle=skin.core;
        ctx.beginPath(); ctx.ellipse(0,-this.h/2+5,this.w/2-6,this.h/2-6,0,0,Math.PI*2); ctx.fill();
 
        // Eyes
        if (this.blinkT>130) {
            ctx.fillStyle=od?'#000':'#fff';
            const ex=this.vx*0.5, ey=this.vy>0?-this.h+14:-this.h+10;
            ctx.beginPath(); ctx.roundRect(-9+ex,ey,4,9,2); ctx.fill();
            ctx.beginPath(); ctx.roundRect(5+ex,ey,4,9,2); ctx.fill();
        } else {
            ctx.fillStyle=glowCol;
            ctx.beginPath(); ctx.roundRect(-9,-this.h+12,4,3,1); ctx.fill();
            ctx.beginPath(); ctx.roundRect(5,-this.h+12,4,3,1); ctx.fill();
        }
 
        // Thrusters
        ctx.fillStyle=od?'#ff00ff':'#00ffee'; ctx.shadowBlur=18; ctx.shadowColor=ctx.fillStyle;
        ctx.beginPath(); ctx.roundRect(18,-this.h/2-8,22,11,4); ctx.fill();
        ctx.beginPath(); ctx.roundRect(-40,-this.h/2-8,22,11,4); ctx.fill();
        ctx.shadowBlur=0; ctx.fillStyle='#fff';
        ctx.fillRect(34,-this.h/2-6,7,7); ctx.fillRect(-40,-this.h/2-6,7,7);
 
        // Overdrive crown spikes
        if (od) {
            ctx.fillStyle=glowCol; ctx.shadowBlur=15; ctx.shadowColor=glowCol;
            for (let i=0;i<5;i++) {
                const a=-Math.PI/2+(i-2)*0.35+Math.sin(gtime*0.01)*0.2;
                ctx.beginPath(); ctx.moveTo(Math.cos(a)*14,Math.sin(a)*14-this.h/2);
                ctx.lineTo(Math.cos(a)*(this.w/2+6),Math.sin(a)*(this.h/2+6)-this.h/2);
                ctx.lineTo(Math.cos(a+0.15)*12,Math.sin(a+0.15)*12-this.h/2);
                ctx.fill();
            }
            ctx.shadowBlur=0;
        }
 
        ctx.restore();
    }
};
 
// ─── Helpers ────────────────────────────────────────────────────
function aabb(a,b) { return a.x<b.x+b.w&&a.x+a.w>b.x&&a.y<b.y+b.h&&a.y+a.h>b.y; }
function wrap(v,max) { return ((v%max)+max)%max; }
function addScore(pts) {
    P.score+=pts*P.combo;
    document.getElementById('score-val').textContent=P.score;
    P.combo++;
    document.getElementById('combo-val').textContent='x'+P.combo;
    // Combo flash at milestones
    if (P.combo%5===0&&P.combo>1) {
        const el=document.getElementById('combo-flash');
        el.textContent='x'+P.combo+' COMBO!';
        el.style.opacity=1;
        setTimeout(()=>el.style.opacity=0,800);
    }
}
 
function killEnemy(e, bounced=false) {
    e.isDead=true; e.deathTimer=400;
    SFX.hit();
    spawnParts(e.x+e.w/2,e.y+e.h/2,bounced?40:25,e.type==='flyer'?COLORS.purple:COLORS.orange,8);
    shake(bounced?4:2); hitstop(bounced?40:15);
}
 
function bossKill() {
    boss.isDead=true;
    SFX.level(); shake(30); hitstop(120);
    spawnParts(boss.x+boss.w/2,boss.y+boss.h/2,120,boss.col,16);
    for(let i=0;i<40;i++) spawnParts(boss.x+boss.w/2+Math.random()*200-100,boss.y+Math.random()*100,20,COLORS.yellow,10);
    document.getElementById('boss-bar-wrap').style.display='none';
    toast('BOSS DESTROYED!',COLORS.yellow);
    goal={x:boss.type===1?500:520,y:-30,w:90,h:130};
}
 
// ─── GAME ────────────────────────────────────────────────────────
function startGame(lvl, keepScore=false) {
    if (document.activeElement) document.activeElement.blur();
    initAudio();
    currentLevel=lvl;
    document.getElementById('start-screen').classList.add('hidden');
    P.reset(keepScore);
    resetWorld();
    document.getElementById('lv-val').textContent=currentLevel;
    document.getElementById('score-val').textContent=P.score;
    document.getElementById('combo-val').textContent='x'+P.combo;
    cam.x=P.x; cam.y=P.y; cam.zoom=1;
    particles.length=0;
    bgLasers=[]; bgExplosions=[];
    gameActive=true; lastTime=performance.now(); gtime=0;
    if (rafId) cancelAnimationFrame(rafId);
    rafId=requestAnimationFrame(gameLoop);
}
 
function pauseGame() { gameActive=false; }
 
// ─── GAME LOOP ───────────────────────────────────────────────────
function gameLoop(ts) {
    if (!gameActive) return;
    const dt=Math.min(ts-lastTime,30); lastTime=ts; gtime+=dt;
 
    if (hitPause>0) { hitPause-=dt; rafId=requestAnimationFrame(gameLoop); return; }
 
    // -- Update --
    P.update(dt);
 
    // Platform crumble
    for (const p of platforms) {
        if (p.type==='crumble'&&!p.crumbled&&p.crumbleTimer>=0) {
            p.crumbleTimer-=dt;
            if (p.crumbleTimer<=0) {
                p.crumbled=true; p.active=false;
                spawnParts(p.x+p.w/2,p.y,20,COLORS.orange,5,0.5);
                shake(3);
            }
        }
        if (!p.active&&p.opacity!==undefined) { p.opacity-=dt*0.003; if(p.opacity<0)p.opacity=0; }
        // Moving platforms
        if (p.active&&(p.vx||p.vy)) {
            const ox=p.x,oy=p.y;
            if (p.vx) p.x=p.baseX+Math.sin(gtime*0.002+p.timeOff)*130;
            if (p.vy) p.y=p.baseY+Math.sin(gtime*0.002+p.timeOff)*120;
            if (P.standingOn===p) { P.x+=p.x-ox; P.y+=p.y-oy; }
        }
    }
 
    // Box physics
    for (const b of boxes) {
        b.vy+=GRAVITY; b.vx*=0.84;
        b.x+=b.vx;
        for (const p of platforms) {
            if (!p.active) continue;
            if (aabb(b,p)&&b.y+b.h>p.y+8) {
                if (b.vx>0) { b.x=p.x-b.w; b.vx=0; } else if (b.vx<0) { b.x=p.x+p.w; b.vx=0; }
            }
        }
        b.y+=b.vy; b.grounded=false;
        for (const p of platforms) {
            if (!p.active) continue;
            if (aabb(b,p)&&b.vy>0) { b.y=p.y-b.h; b.vy=0; b.grounded=true; }
        }
        if (P.standingOn===b) { P.x+=b.vx; P.y+=b.vy; }
    }
 
    // Enemy AI
    for (const e of enemies) {
        if (e.isDead) { e.deathTimer-=dt; continue; }
        e.anim=(e.anim||0)+dt;
 
        if (e.type==='walker') {
            e.x+=e.vx; if (e.x<e.minX||e.x>e.maxX) e.vx*=-1;
        } else if (e.type==='flyer') {
            e.x+=(P.x-e.x)*0.015;
            e.y+=Math.sin(gtime*0.004+e.anim*0.001)*1.8;
            e.shootT-=dt;
            if (e.shootT<=0&&Math.abs(P.x-e.x)<400) {
                if (e.pattern===0) {
                    enemyProj.push({x:e.x+e.w/2,y:e.y+e.h,w:12,h:22,vx:0,vy:5,col:COLORS.purple});
                } else {
                    const dx=P.x-e.x,dy=P.y-e.y;
                    const ang=Math.atan2(dy,dx);
                    enemyProj.push({x:e.x+e.w/2,y:e.y+e.h/2,w:12,h:12,vx:Math.cos(ang)*6,vy:Math.sin(ang)*6,col:COLORS.purple});
                }
                e.shootT=1400; SFX.shoot();
            }
        } else if (e.type==='turret') {
            e.shootT-=dt; e.charged=(e.charged||0)+dt*0.001;
            if (e.shootT<=0) {
                const dx=P.x-e.x,dy=P.y-e.y;
                const ang=Math.atan2(dy,dx);
                enemyProj.push({x:e.x+e.w/2,y:e.y,w:14,h:14,vx:Math.cos(ang)*7,vy:Math.sin(ang)*7,col:COLORS.orange});
                e.shootT=1800; e.charged=0; SFX.shoot();
            }
        } else if (e.type==='shieldWalker') {
            e.x+=e.vx; if (e.x<e.minX||e.x>e.maxX) e.vx*=-1;
            e.shieldAngle=(e.shieldAngle||0)+dt*0.003;
        }
    }
 
    // Player projectiles
    for (let i=playerProj.length-1;i>=0;i--) {
        const pp=playerProj[i]; pp.x+=pp.vx;
        let hit=false;
        // Hit boss
        if (boss&&!boss.isDead&&aabb(pp,boss)) {
            boss.hp--; SFX.hit();
            spawnParts(pp.x,pp.y+pp.h/2,28,boss.col,7);
            shake(4); hitstop(8);
            document.getElementById('boss-fill').style.width=(boss.hp/boss.maxHp*100)+'%';
            if (boss.hp<=0) bossKill();
            hit=true;
        } else {
            for (const e of enemies) {
                if (!e.isDead&&aabb(pp,e)) {
                    // Shield walker takes extra shots
                    if (e.type==='shieldWalker') {
                        const shieldX=e.x+e.w/2+Math.cos(e.shieldAngle)*24;
                        const shieldY=e.y+e.h/2+Math.sin(e.shieldAngle)*24;
                        const dx=pp.x-shieldX,dy=pp.y-shieldY;
                        if (dx*dx+dy*dy<400) { hit=true; spawnParts(shieldX,shieldY,15,COLORS.cyan,6); break; }
                    }
                    e.hp--;
                    if (e.hp<=0) killEnemy(e);
                    else { SFX.hit(); spawnParts(e.x+e.w/2,e.y,10,COLORS.white,5); }
                    hit=true; break;
                }
            }
        }
        if (hit) { playerProj.splice(i,1); continue; }
        if (pp.x<cam.x-W||pp.x>cam.x+W*2) playerProj.splice(i,1);
    }
 
    // Enemy projectiles
    for (let i=enemyProj.length-1;i>=0;i--) {
        const ep=enemyProj[i]; ep.x+=ep.vx; ep.y+=ep.vy;
        if (ep.y>2000||ep.x<cam.x-W||ep.x>cam.x+W*2) enemyProj.splice(i,1);
    }
 
    // Boss AI
    if (boss&&!boss.isDead) {
        boss.x+=boss.vx;
        if (boss.x<80||boss.x>820) boss.vx*=-1;
        boss.y=(-240)+Math.sin(gtime*0.004)*(boss.phase===2?60:40);
        boss.orbAngle+=dt*0.003*(boss.phase===2?2:1);
        boss.timer+=dt; boss.shootT-=dt;
 
        // Phase 2 when at 50% hp
        if (boss.hp<=boss.maxHp/2&&boss.phase===1) {
            boss.phase=2; boss.vx*=1.5; shake(20); toast('PHASE 2!',boss.col);
            spawnParts(boss.x+boss.w/2,boss.y+boss.h/2,80,boss.col,15);
        }
 
        document.getElementById('boss-fill').style.width=(boss.hp/boss.maxHp*100)+'%';
 
        if (boss.timer>2200-boss.phase*300) {
            boss.state=Math.floor(Math.random()*(boss.type===1?3:4));
            boss.timer=0;
        }
        if (boss.shootT<=0) {
            const bx=boss.x+boss.w/2,by=boss.y+boss.h;
            const dx=P.x-bx,dy=P.y-by;
            const ang=Math.atan2(dy,dx);
            const spd=boss.phase===2?10:7;
            if (boss.type===1) {
                if (boss.state===0) {
                    bossProj.push({x:bx,y:by,w:18,h:18,vx:0,vy:6,col:'#ff00ff'});
                    boss.shootT=600;
                } else if (boss.state===1) {
                    for(let i=0;i<3;i++) bossProj.push({x:bx,y:by,w:16,h:16,vx:(i-1)*4,vy:6,col:'#aa00ff'});
                    boss.shootT=900;
                } else {
                    // Aimed
                    bossProj.push({x:bx,y:by,w:20,h:20,vx:Math.cos(ang)*spd,vy:Math.sin(ang)*spd,col:'#ff4400'});
                    boss.shootT=500;
                }
            } else {
                if (boss.state===0) {
                    bossProj.push({x:bx,y:by,w:14,h:14,vx:Math.cos(ang)*spd,vy:Math.sin(ang)*spd,col:'#ffaa00'});
                    boss.shootT=220;
                } else if (boss.state===1) {
                    for(let i=0;i<8;i++){const a=(i/8)*Math.PI*2;bossProj.push({x:bx,y:boss.y+boss.h/2,w:18,h:18,vx:Math.cos(a)*7,vy:Math.sin(a)*7,col:'#ff0000'});}
                    boss.shootT=1200;
                } else if (boss.state===2) {
                    bossProj.push({x:bx-80,y:by,w:28,h:28,vx:0,vy:10,col:'#ff4400'});
                    bossProj.push({x:bx+80,y:by,w:28,h:28,vx:0,vy:10,col:'#ff4400'});
                    boss.shootT=700;
                } else {
                    // Phase 2 extra: triple aimed
                    for(let i=-1;i<=1;i++) bossProj.push({x:bx,y:by,w:14,h:14,vx:Math.cos(ang+i*0.3)*spd,vy:Math.sin(ang+i*0.3)*spd,col:'#ffffff'});
                    boss.shootT=400;
                }
            }
            SFX.shoot();
        }
        boss.snipeT-=dt;
        if (boss.snipeT<=0) {
            const bx=boss.x+boss.w/2,by=boss.y+boss.h;
            const dx=P.x-bx,dy=P.y-by;
            const ang=Math.atan2(dy,dx);
            const spd=boss.type===1?8:12;
            bossProj.push({x:bx,y:by,w:26,h:26,vx:Math.cos(ang)*spd,vy:Math.sin(ang)*spd,col:boss.type===1?'#ff4400':'#fff'});
            boss.snipeT=boss.type===1?6000:3500;
            shake(4); SFX.land&&SFX.hit();
        }
 
        for (let i=bossProj.length-1;i>=0;i--) {
            const bp=bossProj[i]; bp.x+=bp.vx; bp.y+=bp.vy;
            if (bp.y>800||bp.x<-200||bp.x>1400) bossProj.splice(i,1);
        }
    }
 
    // Coins bob
    for (const c of coins) { c.t+=dt*0.005; c.y=c.baseY+Math.sin(c.t)*9; }
    for (const h of hearts) { h.t+=dt*0.005; h.y=h.baseY+Math.sin(h.t+1)*8; }
 
    // Particles
    for (let i=particles.length-1;i>=0;i--) {
        const p=particles[i];
        p.x+=p.vx; p.y+=p.vy; p.vy+=p.grav;
        p.vx*=0.95; p.life-=dt;
        if (p.life<=0) particles.splice(i,1);
    }
 
    // Probe ahead to generate more chunks
    if (currentLevel!==5&&currentLevel!==10&&P.x>nextGenX-W*1.8) generateMore(nextGenX+W*2.5);
 
    // Camera
    cam.tx=P.x+P.vx*12-W/2.4;
    cam.ty=P.y+P.vy*6-H/1.6;
    cam.x+=(cam.tx-cam.x)*0.1;
    cam.y+=(cam.ty-cam.y)*0.1;
    const spdRatio=Math.abs(P.vx)/9;
    cam.tz=P.dashT>0?0.78:1-spdRatio*0.16;
    cam.zoom+=(cam.tz-cam.zoom)*0.06;
    if (shakePwr>0) { shakePwr*=0.88; if(shakePwr<0.5)shakePwr=0; }
 
    // BG ships/battles
    for (let i=bgShips.length-1;i>=0;i--) {
        const s=bgShips[i]; s.t+=dt; s.fireT-=dt; s.dodgeT-=dt;
        if (s.dodgeT<=0) { s.ty=(Math.random()*H*0.8+H*0.1)+cam.y*s.dp; s.dodgeT=Math.random()*2000+1200; }
        s.x+=s.vx*dt; s.y+=(s.ty-s.y)*0.0012*dt;
        if (s.fireT<=0) {
            bgLasers.push({x:s.x+(s.fac===1?25:-25),y:s.y,vx:s.fac*0.8,dp:s.dp,fac:s.fac});
            s.fireT=Math.random()*2500+1200;
        }
        const sx=s.x-cam.x*s.dp;
        if (s.fac===1&&sx>W+400) bgShips[i]=mkShip(1);
        if (s.fac===-1&&sx<-400) bgShips[i]=mkShip(-1);
    }
    for (let i=bgLasers.length-1;i>=0;i--) {
        const l=bgLasers[i]; l.x+=l.vx*dt;
        const sx=l.x-cam.x*l.dp;
        if (sx<-500||sx>W+500) { bgLasers.splice(i,1); continue; }
        let hit=false;
        for (let j=bgShips.length-1;j>=0;j--) {
            const s=bgShips[j];
            if (s.fac!==l.fac) {
                const dx=s.x-l.x,dy=s.y-l.y;
                if (dx*dx+dy*dy<1600) {
                    for(let k=0;k<14;k++) bgExplosions.push({x:s.x,y:s.y,vx:(Math.random()-0.5)*0.35,vy:(Math.random()-0.5)*0.35,life:Math.random()*500+200,maxLife:700,dp:s.dp,col:s.fac===1?COLORS.cyan:COLORS.pink});
                    bgShips[j]=mkShip(s.fac); hit=true; break;
                }
            }
        }
        if (hit) bgLasers.splice(i,1);
    }
    for (let i=bgExplosions.length-1;i>=0;i--) {
        const e=bgExplosions[i]; e.x+=e.vx*dt; e.y+=e.vy*dt; e.life-=dt;
        if (e.life<=0) bgExplosions.splice(i,1);
    }
 
    // -- DRAW --
    draw();
    rafId=requestAnimationFrame(gameLoop);
}
 
function draw() {
    ctx.fillStyle='#04020e'; ctx.fillRect(0,0,W,H);
 
    // Stars (parallax)
    for (const s of stars) {
        const sx=wrap(s.x-cam.x*s.dp,W), sy=wrap(s.y-cam.y*s.dp,H);
        const twink=0.4+Math.sin(gtime*0.003+s.blink)*0.6;
        ctx.globalAlpha=s.dp*twink; ctx.fillStyle='#fff';
        ctx.fillRect(sx,sy,s.sz,s.sz);
    }
    ctx.globalAlpha=1;
 
    // Asteroids
    for (const a of bgAsteroids) {
        a.x+=a.vx*1; a.y+=a.vy*1; a.rot+=a.rs;
        const dx=wrap(a.x-cam.x*a.dp,W+a.sz*2)-a.sz;
        const dy=wrap(a.y-cam.y*a.dp,H+a.sz*2)-a.sz;
        ctx.save(); ctx.translate(dx,dy); ctx.rotate(a.rot);
        ctx.beginPath(); ctx.moveTo(a.pts[0].x,a.pts[0].y);
        for(let i=1;i<a.pts.length;i++) ctx.lineTo(a.pts[i].x,a.pts[i].y);
        ctx.closePath();
        ctx.fillStyle='#3a2510'; ctx.fill();
        ctx.strokeStyle='#7a4a18'; ctx.lineWidth=2; ctx.stroke();
        ctx.restore();
    }
 
    // BG ships
    for (const s of bgShips) {
        const dx=s.x-cam.x*s.dp, dy=s.y-cam.y*s.dp;
        ctx.save(); ctx.translate(dx,dy); ctx.scale(s.fac*s.scale,s.scale);
        const mc=s.fac===1?COLORS.cyan:COLORS.pink;
        ctx.globalCompositeOperation='lighter';
        ctx.fillStyle=mc+'66'; ctx.globalAlpha=0.4+Math.sin(s.t*0.02)*0.4;
        ctx.beginPath(); ctx.moveTo(-15,0); ctx.lineTo(-38-Math.random()*15,-5); ctx.lineTo(-38-Math.random()*15,5); ctx.fill();
        ctx.globalCompositeOperation='source-over'; ctx.globalAlpha=1;
        ctx.fillStyle='#111'; ctx.strokeStyle=mc; ctx.lineWidth=2;
        ctx.beginPath(); ctx.moveTo(25,0); ctx.lineTo(-15,12); ctx.lineTo(-10,0); ctx.lineTo(-15,-12); ctx.closePath();
        ctx.fill(); ctx.stroke();
        ctx.restore();
    }
 
    // BG lasers
    for (const l of bgLasers) {
        const dx=l.x-cam.x*l.dp, dy=l.y-cam.y*l.dp;
        ctx.strokeStyle=l.fac===1?COLORS.cyan:COLORS.pink; ctx.lineWidth=2;
        ctx.beginPath(); ctx.moveTo(dx,dy); ctx.lineTo(dx-l.vx*20,dy); ctx.stroke();
    }
 
    // BG explosions
    for (const e of bgExplosions) {
        const dx=e.x-cam.x*e.dp, dy=e.y-cam.y*e.dp;
        ctx.globalAlpha=Math.max(0,e.life/e.maxLife);
        ctx.fillStyle=e.col;
        ctx.beginPath(); ctx.arc(dx,dy,3+Math.random()*2,0,Math.PI*2); ctx.fill();
    }
    ctx.globalAlpha=1;
 
    // ─── World space ────
    ctx.save();
    ctx.translate(W/2,H/2);
    ctx.scale(cam.zoom,cam.zoom);
    const sx=(Math.random()-0.5)*shakePwr*2, sy=(Math.random()-0.5)*shakePwr*2;
    ctx.translate(-cam.x+sx-W/2,-cam.y+sy-H/2);
 
    // Draw platforms
    for (const p of platforms) {
        if (p.opacity!==undefined&&p.opacity<=0) continue;
        if (p.x+p.w<cam.x-W||p.x>cam.x+W*2) continue;
        ctx.globalAlpha=p.opacity!==undefined?Math.max(0,p.opacity):1;
        ctx.lineWidth=3;
 
        if (p.type==='door') {
            ctx.fillStyle='rgba(0,255,238,0.12)'; ctx.strokeStyle=COLORS.cyan;
            ctx.shadowBlur=12; ctx.shadowColor=COLORS.cyan;
            ctx.fillRect(p.x,p.y,p.w,p.h); ctx.strokeRect(p.x,p.y,p.w,p.h);
            ctx.beginPath(); for(let i=0;i<p.h;i+=24){ctx.moveTo(p.x,p.y+i);ctx.lineTo(p.x+p.w,p.y+i+24);} ctx.stroke();
        } else if (p.type==='bounce') {
            ctx.fillStyle='#0d2200'; ctx.strokeStyle=COLORS.yellow;
            ctx.shadowBlur=18; ctx.shadowColor=COLORS.yellow;
            ctx.fillRect(p.x,p.y,p.w,p.h); ctx.strokeRect(p.x,p.y,p.w,p.h);
            ctx.fillStyle=COLORS.yellow; ctx.shadowBlur=8;
            for(let i=0;i<p.w;i+=22){ctx.beginPath();ctx.arc(p.x+i+11,p.y+12,6,0,Math.PI*2);ctx.fill();}
        } else if (p.type==='crumble') {
            const pct=p.crumbleTimer>0?p.crumbleTimer/600:1;
            ctx.fillStyle=`rgba(80,40,10,${pct})`; ctx.strokeStyle=`rgba(255,140,30,${pct})`;
            ctx.shadowBlur=8; ctx.shadowColor=COLORS.orange;
            ctx.fillRect(p.x,p.y,p.w,p.h); ctx.strokeRect(p.x,p.y,p.w,p.h);
            if (p.crumbleTimer>0) {
                ctx.fillStyle=COLORS.orange; ctx.globalAlpha*=0.5;
                for(let i=0;i<5;i++){ctx.fillRect(p.x+Math.random()*p.w,p.y+Math.random()*p.h,4,4);}
            }
        } else if (p.vx||p.vy) {
            ctx.fillStyle='#180630'; ctx.strokeStyle=COLORS.purple;
            ctx.shadowBlur=16; ctx.shadowColor=COLORS.purple;
            ctx.fillRect(p.x,p.y,p.w,p.h); ctx.strokeRect(p.x,p.y,p.w,p.h);
            ctx.fillStyle=COLORS.purple;
            for(let i=0;i<p.w;i+=32){ctx.beginPath();ctx.moveTo(p.x+i,p.y);ctx.lineTo(p.x+i+16,p.y);ctx.lineTo(p.x+i+6,p.y+12);ctx.lineTo(p.x+i-10,p.y+12);ctx.fill();}
        } else {
            // Normal ground
            const isGround=p.h>200;
            ctx.fillStyle=isGround?'#0a0820':'#0d1030';
            ctx.strokeStyle=COLORS.cyan;
            ctx.shadowBlur=10; ctx.shadowColor=COLORS.cyan;
            ctx.fillRect(p.x,p.y,p.w,p.h); ctx.strokeRect(p.x,p.y,p.w,p.h);
            ctx.fillStyle=COLORS.cyan; ctx.shadowBlur=0;
            ctx.fillRect(p.x,p.y,p.w,6);
            // Grid lines on large ground
            if (isGround) {
                ctx.strokeStyle='rgba(0,255,238,0.06)'; ctx.lineWidth=1;
                for(let gx=p.x;gx<p.x+p.w;gx+=60){ctx.beginPath();ctx.moveTo(gx,p.y);ctx.lineTo(gx,p.y+p.h);ctx.stroke();}
            }
        }
        ctx.globalAlpha=1; ctx.shadowBlur=0;
    }
 
    // Enemies
    for (const e of enemies) {
        if (e.x+e.w<cam.x-W||e.x>cam.x+W*2) continue;
        if (e.isDead&&e.deathTimer<=0) continue;
 
        if (e.isDead) {
            ctx.globalAlpha=e.deathTimer/400;
            ctx.fillStyle='#fff';
            ctx.save(); ctx.translate(e.x+e.w/2,e.y+e.h/2); ctx.rotate(e.deathTimer*0.01);
            ctx.beginPath(); ctx.arc(0,0,e.w/2,0,Math.PI*2); ctx.fill();
            ctx.restore(); ctx.globalAlpha=1; continue;
        }
 
        if (e.type==='walker') {
            const sq=1+Math.sin(e.anim*0.015)*0.14;
            ctx.save(); ctx.translate(e.x+e.w/2,e.y+e.h);
            ctx.scale(1/sq,sq);
            ctx.fillStyle='#ff9900'; ctx.shadowBlur=15; ctx.shadowColor='#ff9900';
            ctx.beginPath(); ctx.roundRect(-e.w/2,-e.h,e.w,e.h,8); ctx.fill();
            ctx.fillStyle='#fff'; ctx.shadowBlur=0;
            ctx.fillRect(-6,-e.h+5,12,11);
            ctx.fillStyle='#000'; ctx.fillRect(-4+(e.vx>0?5:0),-e.h+7,5,7);
            ctx.restore();
        } else if (e.type==='flyer') {
            ctx.fillStyle=COLORS.purple; ctx.shadowBlur=18; ctx.shadowColor=COLORS.purple;
            ctx.save(); ctx.translate(e.x+e.w/2,e.y+e.h/2);
            ctx.rotate(Math.sin(e.anim*0.01)*0.2);
            ctx.beginPath(); ctx.moveTo(0,-e.h/2); ctx.lineTo(e.w/2,0); ctx.lineTo(0,e.h/2); ctx.lineTo(-e.w/2,0); ctx.closePath(); ctx.fill();
            ctx.fillStyle='#fff'; ctx.shadowBlur=0; ctx.fillRect(-4,-4,8,8);
            ctx.restore(); ctx.shadowBlur=0;
        } else if (e.type==='turret') {
            const charge=e.charged||0;
            ctx.fillStyle='#222'; ctx.strokeStyle=COLORS.orange; ctx.lineWidth=3;
            ctx.shadowBlur=10+charge*20; ctx.shadowColor=COLORS.orange;
            ctx.fillRect(e.x,e.y+20,e.w,e.h-20); ctx.strokeRect(e.x,e.y+20,e.w,e.h-20);
            // Barrel
            const dx=P.x-(e.x+e.w/2),dy=P.y-(e.y+e.h/2);
            const ang=Math.atan2(dy,dx);
            ctx.save(); ctx.translate(e.x+e.w/2,e.y+10);
            ctx.rotate(ang);
            ctx.fillStyle=COLORS.orange; ctx.fillRect(0,-5,28,10); ctx.restore();
            ctx.fillStyle=COLORS.red+Math.min(255,Math.floor(charge*255)).toString(16);
            ctx.beginPath(); ctx.arc(e.x+e.w/2,e.y+10,8+charge*8,0,Math.PI*2); ctx.fill();
            ctx.shadowBlur=0;
        } else if (e.type==='shieldWalker') {
            const sq=1+Math.sin(e.anim*0.012)*0.12;
            ctx.save(); ctx.translate(e.x+e.w/2,e.y+e.h);
            ctx.scale(1/sq,sq);
            ctx.fillStyle='#4488ff'; ctx.shadowBlur=15; ctx.shadowColor='#4488ff';
            ctx.beginPath(); ctx.roundRect(-e.w/2,-e.h,e.w,e.h,8); ctx.fill();
            ctx.fillStyle='#fff'; ctx.shadowBlur=0; ctx.fillRect(-5,-e.h+6,10,10);
            // Shield orb
            const sa=e.shieldAngle||0;
            ctx.strokeStyle=COLORS.cyan; ctx.lineWidth=3; ctx.shadowBlur=15; ctx.shadowColor=COLORS.cyan;
            ctx.beginPath(); ctx.arc(Math.cos(sa)*26,-e.h/2+Math.sin(sa)*26,12,0,Math.PI*2); ctx.stroke();
            ctx.fillStyle=COLORS.cyan+'44'; ctx.fill();
            ctx.restore(); ctx.shadowBlur=0;
        }
    }
 
    // Boxes
    for (const b of boxes) {
        if (b.x+b.w<cam.x-W||b.x>cam.x+W*2) continue;
        ctx.fillStyle='#1a1005'; ctx.fillRect(b.x,b.y,b.w,b.h);
        ctx.strokeStyle='#ffaa00'; ctx.lineWidth=3; ctx.shadowBlur=6; ctx.shadowColor='#ffaa00';
        ctx.strokeRect(b.x,b.y,b.w,b.h);
        ctx.beginPath(); ctx.moveTo(b.x,b.y); ctx.lineTo(b.x+b.w,b.y+b.h); ctx.stroke();
        ctx.beginPath(); ctx.moveTo(b.x+b.w,b.y); ctx.lineTo(b.x,b.y+b.h); ctx.stroke();
        ctx.shadowBlur=0;
    }
 
    // Levers
    for (const lv of levers) {
        if (lv.x+lv.w<cam.x-W||lv.x>cam.x+W*2) continue;
        ctx.fillStyle='#444'; ctx.fillRect(lv.x,lv.y+lv.h-10,lv.w,10);
        const ec=lv.active?COLORS.green:COLORS.red;
        ctx.strokeStyle=ec; ctx.lineWidth=5; ctx.shadowBlur=10; ctx.shadowColor=ec;
        ctx.beginPath(); ctx.moveTo(lv.x+lv.w/2,lv.y+lv.h-10);
        ctx.lineTo(lv.x+(lv.active?lv.w:0),lv.y); ctx.stroke();
        ctx.fillStyle=ec; ctx.beginPath(); ctx.arc(lv.x+(lv.active?lv.w:0),lv.y,8,0,Math.PI*2); ctx.fill();
        ctx.shadowBlur=0;
    }
 
    // Hazards (spikes + mines)
    for (const h of hazards) {
        if (h.x+h.w<cam.x-W||h.x>cam.x+W*2) continue;
        if (h.type==='mine') {
            if (h.collected) continue;
            ctx.fillStyle='#440000'; ctx.strokeStyle=COLORS.red; ctx.lineWidth=2;
            ctx.shadowBlur=10; ctx.shadowColor=COLORS.red;
            ctx.beginPath(); ctx.arc(h.x+15,h.y+15,15,0,Math.PI*2); ctx.fill(); ctx.stroke();
            ctx.fillStyle=COLORS.red; ctx.beginPath(); ctx.arc(h.x+15,h.y+15,5+Math.sin(gtime*0.01)*3,0,Math.PI*2); ctx.fill();
            ctx.shadowBlur=0;
        } else {
            ctx.fillStyle='#ff2222'; ctx.shadowBlur=12; ctx.shadowColor='#ff0000';
            ctx.beginPath();
            const spikes=Math.floor(h.w/15);
            ctx.moveTo(h.x,h.y+h.h);
            for(let i=0;i<spikes;i++){ctx.lineTo(h.x+i*15+7.5,h.y);ctx.lineTo(h.x+i*15+15,h.y+h.h);}
            ctx.fill(); ctx.shadowBlur=0;
        }
    }
 
    // Coins
    for (const c of coins) {
        if (c.collected||c.x+c.w<cam.x-W||c.x>cam.x+W*2) continue;
        ctx.save(); ctx.translate(c.x+c.w/2,c.y+c.h/2);
        const spinScale=Math.sin(c.t*3);
        ctx.scale(spinScale,1); ctx.rotate(c.t*0.5);
        ctx.fillStyle=COLORS.cyan; ctx.shadowBlur=22; ctx.shadowColor=COLORS.cyan;
        ctx.beginPath(); ctx.moveTo(0,-c.h/2); ctx.lineTo(c.w/2,0); ctx.lineTo(0,c.h/2); ctx.lineTo(-c.w/2,0); ctx.closePath(); ctx.fill();
        ctx.scale(0.45,0.45); ctx.fillStyle='#fff'; ctx.fill();
        ctx.restore(); ctx.shadowBlur=0;
    }
 
    // Hearts
    for (const h of hearts) {
        if (h.collected||h.x+20<cam.x-W||h.x>cam.x+W*2) continue;
        ctx.save(); ctx.translate(h.x,h.y);
        ctx.fillStyle=COLORS.pink; ctx.shadowBlur=18; ctx.shadowColor=COLORS.pink;
        // Heart shape
        const s=10+Math.sin(gtime*0.008)*2;
        ctx.beginPath();
        ctx.moveTo(0,s*0.4);
        ctx.bezierCurveTo(0,0,-s,0,-s,-s*0.5);
        ctx.bezierCurveTo(-s,-s*1.2,0,-s*1.2,0,-s*0.6);
        ctx.bezierCurveTo(0,-s*1.2,s,-s*1.2,s,-s*0.5);
        ctx.bezierCurveTo(s,0,0,0,0,s*0.4);
        ctx.fill(); ctx.restore(); ctx.shadowBlur=0;
    }
 
    // Goal portal
    if (goal&&goal.x+goal.w>cam.x-W&&goal.x<cam.x+W*2) {
        const pulse=Math.sin(gtime*0.006)*18;
        const gx=goal.x-pulse/2,gy=goal.y-pulse,gw=goal.w+pulse,gh=goal.h+pulse;
        ctx.fillStyle='rgba(0,255,136,0.15)'; ctx.strokeStyle=COLORS.green; ctx.lineWidth=4;
        ctx.shadowBlur=50; ctx.shadowColor=COLORS.green;
        ctx.fillRect(gx,gy,gw,gh); ctx.strokeRect(gx,gy,gw,gh);
        // Spinning inner ring
        ctx.save(); ctx.translate(gx+gw/2,gy+gh/2); ctx.rotate(gtime*0.002);
        ctx.strokeStyle='#fff'; ctx.lineWidth=2; ctx.shadowBlur=20; ctx.shadowColor='#fff';
        ctx.strokeRect(-20,-30,40,60);
        ctx.restore();
        ctx.shadowBlur=0;
        ctx.fillStyle='#fff'; ctx.font='bold 12px Share Tech Mono'; ctx.textAlign='center';
        ctx.fillText('EXIT',gx+gw/2,gy-8);
    }
 
    // Boss
    if (boss&&!boss.isDead) {
        const bsx=1+Math.sin(gtime*0.009)*0.14, bsy=1+Math.cos(gtime*0.009)*0.14;
        ctx.save(); ctx.translate(boss.x+boss.w/2,boss.y+boss.h/2);
        ctx.scale(bsx,bsy);
        ctx.fillStyle=boss.col; ctx.shadowBlur=50; ctx.shadowColor=boss.col;
        ctx.beginPath(); ctx.ellipse(0,0,boss.w/2,boss.h/2,0,0,Math.PI*2); ctx.fill();
        ctx.fillStyle='#fff'; ctx.shadowBlur=0;
 
        if (boss.type===1) {
            ctx.beginPath(); ctx.moveTo(-32,-22); ctx.lineTo(-10,-10); ctx.lineTo(-32,-4); ctx.fill();
            ctx.beginPath(); ctx.moveTo(32,-22); ctx.lineTo(10,-10); ctx.lineTo(32,-4); ctx.fill();
            // Phase 2: teeth
            if (boss.phase===2) {
                ctx.fillStyle='#ff4400';
                for(let i=-2;i<=2;i++){ctx.beginPath();ctx.moveTo(i*12,-5);ctx.lineTo(i*12-6,12);ctx.lineTo(i*12+6,12);ctx.fill();}
            }
        } else {
            // Eye
            ctx.beginPath(); ctx.ellipse(0,-10,16,6,0,0,Math.PI*2); ctx.fill();
            ctx.fillStyle='#000'; ctx.beginPath(); ctx.ellipse(0,-10,6,6,0,0,Math.PI*2); ctx.fill();
            ctx.fillStyle='#ff0000'; ctx.beginPath(); ctx.arc(0,-10,3,0,Math.PI*2); ctx.fill();
            // Orbs
            ctx.rotate(boss.orbAngle);
            const orbCol=boss.phase===2?'#ffffff':'#ffaa00';
            ctx.fillStyle=orbCol; ctx.shadowBlur=20; ctx.shadowColor=orbCol;
            const orbDist=boss.phase===2?75:65, orbN=boss.phase===2?6:4;
            for(let i=0;i<orbN;i++){
                const a=(i/orbN)*Math.PI*2;
                ctx.beginPath(); ctx.arc(Math.cos(a)*orbDist,Math.sin(a)*orbDist,boss.phase===2?9:12,0,Math.PI*2); ctx.fill();
            }
        }
        ctx.restore(); ctx.shadowBlur=0;
 
        // Boss projectiles
        for (const bp of bossProj) {
            ctx.fillStyle=bp.col; ctx.shadowBlur=18; ctx.shadowColor=bp.col;
            ctx.beginPath(); ctx.arc(bp.x,bp.y,bp.w/2,0,Math.PI*2); ctx.fill();
            ctx.fillStyle='#fff88'; ctx.shadowBlur=0;
            ctx.beginPath(); ctx.arc(bp.x-2,bp.y-2,bp.w/6,0,Math.PI*2); ctx.fill();
        }
        ctx.shadowBlur=0;
    }
 
    // Enemy projectiles
    for (const ep of enemyProj) {
        ctx.fillStyle=ep.col; ctx.shadowBlur=14; ctx.shadowColor=ep.col;
        ctx.beginPath(); ctx.ellipse(ep.x,ep.y,ep.w/2,ep.h/2,0,0,Math.PI*2); ctx.fill();
        ctx.shadowBlur=0;
    }
 
    // Player projectiles
    ctx.shadowBlur=18; ctx.shadowColor=SKINS[skinIdx].main;
    for (const pp of playerProj) {
        ctx.fillStyle=pp.col;
        ctx.beginPath(); ctx.ellipse(pp.x+pp.w/2,pp.y+pp.h/2,pp.w/2,pp.h/2,0,0,Math.PI*2); ctx.fill();
        ctx.fillStyle='#fff';
        ctx.beginPath(); ctx.ellipse(pp.x+pp.w/2,pp.y+pp.h/2,pp.w/2-3,pp.h/2-3,0,0,Math.PI*2); ctx.fill();
    }
    ctx.shadowBlur=0;
 
    // Player
    P.draw();
 
    // Particles (additive)
    ctx.globalCompositeOperation='lighter';
    for (const p of particles) {
        const alpha=Math.max(0,p.life/p.maxLife);
        ctx.globalAlpha=alpha;
        ctx.fillStyle=p.col; ctx.shadowBlur=10; ctx.shadowColor=p.col;
        ctx.beginPath(); ctx.arc(p.x,p.y,p.size*alpha*0.5,0,Math.PI*2); ctx.fill();
    }
    ctx.globalCompositeOperation='source-over'; ctx.globalAlpha=1; ctx.shadowBlur=0;
 
    // AI guide
    if (aiEnabled&&gameActive) drawAI();
 
    ctx.restore(); // end world space
 
    // HUD: distance indicator
    if (currentLevel!==5&&currentLevel!==10&&!P.hasWon) {
        const dist=Math.max(0,Math.floor((WIN_X-P.x)/10));
        ctx.fillStyle='rgba(0,255,238,0.3)';
        ctx.fillRect(W-180,H-24,Math.max(0,178*(1-dist/((WIN_X-100)/10))),8);
        ctx.strokeStyle='rgba(0,255,238,0.2)'; ctx.lineWidth=1; ctx.strokeRect(W-180,H-24,178,8);
        ctx.fillStyle='rgba(0,255,238,0.5)'; ctx.font='10px Share Tech Mono'; ctx.textAlign='right';
        ctx.fillText(dist+'m to exit',W-16,H-28);
    }
}
 
// AI guide
let aiX=0, aiY=0, aiTxt='', aiInit=false;
function drawAI() {
    if (!aiInit) { aiX=P.x; aiY=P.y-80; aiInit=true; }
    let tx=P.x, ty=P.y-90;
    if (boss&&!boss.isDead) { tx=boss.x+boss.w/2; ty=boss.y-130; aiTxt='SHOOT & STOMP BOSS!'; }
    else if (goal) { tx=goal.x+goal.w/2; ty=goal.y-60; aiTxt='→ EXIT PORTAL!'; }
    else if (P.odTimer>0) aiTxt='⚡ OVERDRIVE — DESTROY ALL!';
    else if (P.combo>5) aiTxt='KEEP THE COMBO GOING!';
    else if (!P.grounded&&P.canDbl) aiTxt='DOUBLE JUMP!';
    else aiTxt='MOVE RIGHT TO PROGRESS';
 
    aiX+=(tx-aiX)*0.07; aiY+=(ty-aiY)*0.07;
    aiY+=Math.sin(gtime*0.005)*3;
    if (Math.random()>0.6) spawnParts(aiX,aiY+12,1,COLORS.purple,2,0);
 
    ctx.save(); ctx.translate(aiX,aiY);
    ctx.fillStyle='#fff'; ctx.shadowBlur=14; ctx.shadowColor=COLORS.purple;
    ctx.beginPath(); ctx.arc(0,0,13,0,Math.PI*2); ctx.fill();
    ctx.fillStyle=COLORS.purple; ctx.shadowBlur=0;
    ctx.beginPath(); ctx.arc(0,0,7,0,Math.PI*2); ctx.fill();
    ctx.fillStyle=COLORS.cyan; ctx.fillRect(P.x>aiX?3:-6,-3,5,5);
    if (aiTxt) {
        ctx.fillStyle='rgba(8,4,28,0.9)'; ctx.strokeStyle=COLORS.purple; ctx.lineWidth=2;
        ctx.shadowBlur=8; ctx.shadowColor=COLORS.purple;
        const tw=Math.min(200,aiTxt.length*7+20);
        ctx.beginPath(); ctx.roundRect(-tw/2,-56,tw,22,5); ctx.fill(); ctx.stroke();
        ctx.shadowBlur=0;
        ctx.beginPath(); ctx.moveTo(-8,-34); ctx.lineTo(8,-34); ctx.lineTo(0,-25); ctx.fill(); ctx.stroke();
        ctx.fillStyle='#fff'; ctx.font='10px Share Tech Mono'; ctx.textAlign='center'; ctx.textBaseline='middle';
        ctx.fillText(aiTxt,0,-45);
    }
    ctx.restore();
}
 
// Init render — black canvas while menu
ctx.fillStyle='#04020e'; ctx.fillRect(0,0,W,H);
</script>
