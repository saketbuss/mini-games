// ─── Player ─────────────────────────────────────────────────────
let currentLevel=1;
 
const P = {
    x:100, y:-600, w:34, h:34,
    vx:0, vy:5,
    grounded:false, standingOn:null,
    coyote:0, jumpBuf:0,
    canDbl:true,
    facingR:true,
    sx:1, sy:1, sxV:0, syV:0, rot:0,
    trail:[],
    blinkT:0,
    hp:3, maxHp:3,
    invincible:0,
    score:0, combo:1,
    odCoins:0, odTimer:0,
    shootT:0,
    dashT:0, dashCool:0,
    isDead:false, hasWon:false,
 
    reset(keepScore=false) {
        this.x=100; this.y=-600; this.vx=0; this.vy=5;
        this.grounded=false; this.standingOn=null;
        this.coyote=0; this.jumpBuf=0; this.canDbl=true;
        this.facingR=true;
        this.sx=1; this.sy=1; this.sxV=0; this.syV=0; this.rot=0;
        this.trail=[];
        this.blinkT=2000; this.invincible=0;
        this.hp=3;
        if (!keepScore) { this.score=0; this.combo=1; }
        this.odCoins=0; this.odTimer=0;
        this.shootT=0; this.dashT=0; this.dashCool=0;
        this.isDead=false; this.hasWon=false;
        this.updateHPUI();
    },
 
    updateHPUI() {
        for (let i=0;i<3;i++) {
            const pip=document.getElementById('hp'+i);
            if (!pip) continue;
            pip.className='hp-pip'+(i>=this.hp?' empty':'');
        }
    },
 
    hurt() {
        if (this.invincible>0||this.dashT>0||this.isDead) return;
        this.hp--;
        this.invincible=1200; // ms of i-frames after hit
        SFX.hit();
        shake(14); hitstop(60);
        spawnParts(this.x+this.w/2,this.y+this.h/2,20,COLORS.red,7);
        this.updateHPUI();
        toast('⚠ HIT!', COLORS.red);
        if (this.hp<=0) this.die();
    },
 
    healHP() {
        this.hp=Math.min(this.hp+1,this.maxHp);
        this.updateHPUI();
        SFX.heart();
        toast('❤ HEALED!', COLORS.pink);
        spawnParts(this.x+this.w/2,this.y+this.h/2,25,COLORS.pink,6);
    },
 
    update(dt) {
        if (this.isDead||this.hasWon) return;
        const skin=SKINS[skinIdx];
        const od=this.odTimer>0;
 
        this.coyote-=dt; this.jumpBuf-=dt; this.blinkT-=dt;
        this.shootT-=dt; this.dashCool-=dt; this.dashT-=dt;
        this.invincible-=dt;
        if (od) { this.odTimer-=dt; if(this.odTimer<=0) toast('OVERDRIVE ENDED',COLORS.cyan); }
 
        if (this.blinkT<=0) this.blinkT=Math.random()*3000+1200;
        if (keys.jumpTap) { this.jumpBuf=150; keys.jumpTap=false; }
 
        const maxSpd=od?14:9;
        const JF=od?-13:-11;
        const accel=od?0.75:0.55;
 
        // DASH
        if (keys.dash&&this.dashCool<=0) {
            this.dashT=160; this.dashCool=1400; SFX.dash();
            this.vx=this.facingR?28:-28; this.vy=0;
            spawnParts(this.x+this.w/2,this.y+this.h/2,30,skin.main,12);
            shake(6);
        }
 
        if (this.dashT>0) {
            this.vy=0;
        } else {
            if (keys.left)  { this.vx-=accel; this.facingR=false; }
            if (keys.right) { this.vx+=accel; this.facingR=true; }
            this.vx*=0.84;
            this.vx=Math.max(-maxSpd,Math.min(maxSpd,this.vx));
            this.vy+=GRAVITY;
            if (this.vy<0&&!keys.jump) this.vy+=GRAVITY*1.6;
 
            if (this.jumpBuf>0) {
                if (this.coyote>0) {
                    this.vy=JF; this.jumpBuf=0; this.coyote=0; this.grounded=false; this.standingOn=null;
                    this.sx=0.28; this.sy=2; SFX.jump();
                    spawnParts(this.x+this.w/2,this.y+this.h,18,skin.main,6,1.5);
                } else if (this.canDbl) {
                    this.vy=JF*0.9; this.jumpBuf=0; this.canDbl=false; this.standingOn=null;
                    this.sx=0.28; this.sy=2; SFX.jump();
                    spawnParts(this.x+this.w/2,this.y+this.h,24,COLORS.cyan,7,2);
                }
            }
        }
 
        // Move X
        this.standingOn=null;
        this.x+=this.vx;
        for (const p of platforms) {
            if (!p.active) continue;
            if (aabb(this,p)&&this.y+this.h>p.y+8) {
                if (this.vx>0) { this.x=p.x-this.w; this.vx=0; }
                else if (this.vx<0) { this.x=p.x+p.w; this.vx=0; }
            }
        }
        for (const b of boxes) {
            if (aabb(this,b)&&this.y+this.h>b.y+8) {
                const push=this.vx*0.55;
                if (this.vx>0) { this.x=b.x-this.w; b.vx=push; this.vx=push; }
                else if (this.vx<0) { this.x=b.x+b.w; b.vx=push; this.vx=push; }
            }
        }
 
        // Move Y
        const wasGrounded=this.grounded; this.grounded=false;
        this.y+=this.vy;
        for (const p of platforms) {
            if (!p.active) continue;
            if (aabb(this,p)) {
                if (this.vy>0) {
                    this.y=p.y-this.h; this.vy=0; this.grounded=true;
                    this.coyote=120; this.canDbl=true; this.standingOn=p;
                    if (p.type==='bounce') {
                        this.vy=JF*1.7; this.grounded=false; this.standingOn=null; SFX.bounce();
                        this.sx=0.18; this.sy=2.6;
                        spawnParts(this.x+this.w/2,this.y+this.h,35,COLORS.yellow,9,2);
                    } else if (p.type==='crumble'&&!p.crumbled) {
                        if (p.crumbleTimer<0) p.crumbleTimer=600;
                    }
                } else if (this.vy<0) { this.y=p.y+p.h; this.vy=0; }
            }
        }
        for (const b of boxes) {
            if (aabb(this,b)) {
                if (this.vy>0) { this.y=b.y-this.h; this.vy=0; this.grounded=true; this.coyote=120; this.canDbl=true; this.standingOn=b; }
                else if (this.vy<0) { this.y=b.y+b.h; this.vy=0; }
            }
        }
 
        if (this.grounded&&!wasGrounded) {
            this.sx=2; this.sy=0.28; SFX.land(1);
            spawnParts(this.x+this.w/2,this.y+this.h,22,skin.main,7,0.4);
            if (this.vy>10) shake(6);
        }
 
        // Hazards
        for (const h of hazards) {
            if (!h.collected&&aabb(this,h)) {
                if (h.type==='mine') { h.collected=true; shake(20); hitstop(80); spawnParts(h.x+15,h.y+15,60,COLORS.orange,12); SFX.die(); this.hurt(); }
                else this.hurt();
            }
        }
 
        // Enemies
        if (this.dashT<=0) {
            for (const e of enemies) {
                if (!e.isDead&&aabb(this,e)) {
                    if (this.vy>0&&this.y+this.h-this.vy<=e.y+20) {
                        killEnemy(e, true);
                        this.vy=JF*0.75;
                        addScore(200);
                    } else this.hurt();
                }
            }
            if (boss&&!boss.isDead&&aabb(this,boss)) {
                if (this.vy>0&&this.y+this.h-this.vy<=boss.y+30) {
                    boss.hp--; this.vy=JF*0.8; SFX.hit();
                    spawnParts(boss.x+boss.w/2,boss.y+boss.h/2,60,boss.col,12);
                    shake(12); hitstop(60);
                    if (boss.hp<=0) bossKill();
                } else this.hurt();
            }
        }
 
        // Boss/enemy projectiles
        for (const bp of bossProj) if (aabb(this,bp)) this.hurt();
        for (const ep of enemyProj) if (aabb(this,ep)) this.hurt();
 
        // Levers
        for (const lv of levers) {
            if (!lv.active&&aabb(this,lv)) {
                lv.active=true; lv.target.active=false; SFX.collect();
                spawnParts(lv.x+lv.w/2,lv.y,20,COLORS.green,5);
                spawnParts(lv.target.x+lv.target.w/2,lv.target.y+lv.target.h/2,40,COLORS.cyan,8);
                shake(4); toast('DOOR OPENED',COLORS.green);
            }
        }
 
        // Coins
        for (const c of coins) {
            if (!c.collected&&aabb(this,c)) {
                c.collected=true; SFX.collect();
                spawnParts(c.x+c.w/2,c.y+c.h/2,22,COLORS.cyan,7);
                shake(2); hitstop(30);
                addScore(100);
                this.odCoins++;
                if (this.odCoins>=10) {
                    this.odCoins=0; this.odTimer=6000; SFX.powerup();
                    shake(18); toast('⚡ OVERDRIVE!',COLORS.pink);
                    document.getElementById('od-fill').classList.add('active');
                }
            }
        }
 
        // Hearts
        for (const h of hearts) {
            if (!h.collected&&aabb(this,{x:h.x-10,y:h.y-10,w:30,h:30})) {
                h.collected=true; this.healHP();
            }
        }
 
        // OD bar
        if (this.odTimer>0) {
            document.getElementById('od-fill').style.width=(this.odTimer/6000*100)+'%';
        } else {
            document.getElementById('od-fill').classList.remove('active');
            document.getElementById('od-fill').style.width=(this.odCoins/10*100)+'%';
        }
 
        // Shooting
        const fireRate=od?45:140;
        if ((keys.shoot||keys.jump)&&this.shootT<=0) {
            this.shootT=fireRate; SFX.shoot();
            this.sx=1.5; this.sy=0.6;
            const col=od?'#ff00ff':'#00ffee';
            playerProj.push({x:this.x+this.w+4,y:this.y+this.h/2-5,w:26,h:10,vx:22,col});
            playerProj.push({x:this.x-26,y:this.y+this.h/2-5,w:26,h:10,vx:-22,col});
            spawnParts(this.x+this.w,this.y+this.h/2,4,COLORS.cyan,5,0.8);
            spawnParts(this.x,this.y+this.h/2,4,COLORS.cyan,5,0.8);
        }
 
        // Trail
        if (Math.abs(this.vx)>2||Math.abs(this.vy)>2||this.dashT>0) {
            this.trail.unshift({x:this.x,y:this.y,sx:this.sx,sy:this.sy,rot:this.rot,life:1});
        }
        const maxTrail=this.dashT>0?18:8;
        if (this.trail.length>maxTrail) this.trail.pop();
        const trailDecay=this.dashT>0?0.07:0.16;
        for (const t of this.trail) t.life-=trailDecay;
        this.trail=this.trail.filter(t=>t.life>0);
 
        // Squish spring
        const ten=0.14, damp=0.8;
        this.sxV+=(1-this.sx)*ten; this.syV+=(1-this.sy)*ten;
        this.sxV*=damp; this.syV*=damp;
        this.sx+=this.sxV+Math.sin(gtime*0.01)*0.035;
        this.sy+=this.syV+Math.cos(gtime*0.01)*0.035;
        this.rot=this.vx*0.045;
 
        // Fall death
        if (this.y>currentFloorY+1800) this.hurt(); // only lose HP, not instant die
 
        // Goal
        if (goal&&aabb(this,goal)) this.win();
    },
 
    win() {
        if (this.isDead||this.hasWon) return;
        this.hasWon=true; SFX.level();
