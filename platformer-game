<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NEON OVERDRIVE — v2.0</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Share+Tech+Mono&display=swap');
 
        :root {
            --pink: #ff0066;
            --cyan: #00ffee;
            --purple: #aa00ff;
            --green: #00ff88;
            --orange: #ff6600;
            --yellow: #ffee00;
            --dark: #04020e;
            --panel: rgba(8, 4, 28, 0.85);
        }
 
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
 
        body, html {
            width: 100%; height: 100%; overflow: hidden;
            background: var(--dark);
            font-family: 'Share Tech Mono', monospace;
            color: #fff;
            user-select: none;
        }
 
        canvas { display: block; width: 100%; height: 100%; }
 
        /* ====== HUD ====== */
        #hud {
            position: absolute; top: 0; left: 0; right: 0;
            display: flex; align-items: center; justify-content: space-between;
            padding: 14px 24px 0;
            pointer-events: none; z-index: 10;
            gap: 16px;
        }
 
        .hud-block {
            display: flex; flex-direction: column; align-items: center;
            background: var(--panel);
            border: 1px solid rgba(0,255,238,0.2);
            border-radius: 4px;
            padding: 6px 18px;
            box-shadow: 0 0 20px rgba(0,255,238,0.06), inset 0 0 12px rgba(0,0,0,0.4);
            min-width: 90px;
        }
 
        .hud-label {
            font-size: 9px; letter-spacing: 3px; text-transform: uppercase;
            color: rgba(0,255,238,0.5); margin-bottom: 2px;
        }
 
        .hud-value {
            font-family: 'Bebas Neue', cursive;
            font-size: 28px; line-height: 1;
            color: var(--cyan);
            text-shadow: 0 0 12px var(--cyan);
        }
 
        #score-val { color: var(--pink); text-shadow: 0 0 12px var(--pink); }
        #combo-val { color: #fff; text-shadow: 0 0 12px #aaa; }
 
        /* Overdrive bar */
        #od-wrap {
            flex: 1; max-width: 320px;
            display: flex; flex-direction: column; align-items: center; gap: 4px;
        }
        #od-label {
            font-size: 9px; letter-spacing: 3px;
            color: rgba(0,255,238,0.5);
        }
        #od-track {
            width: 100%; height: 8px;
            background: rgba(0,0,0,0.6);
            border: 1px solid rgba(0,255,238,0.25);
            border-radius: 4px;
            overflow: hidden;
            position: relative;
        }
        #od-fill {
            height: 100%;
            width: 0%;
            background: linear-gradient(90deg, var(--cyan), var(--pink));
            border-radius: 4px;
            transition: width 0.15s ease;
        }
        #od-fill.active {
            animation: odPulse 0.4s infinite alternate;
        }
        @keyframes odPulse {
            from { box-shadow: 0 0 6px var(--cyan); }
            to { box-shadow: 0 0 24px var(--pink); }
        }
 
        /* Health pips */
        #health-wrap { display: flex; gap: 6px; align-items: center; }
        .hp-pip {
            width: 14px; height: 14px; border-radius: 50%;
            background: var(--pink);
            box-shadow: 0 0 10px var(--pink);
            transition: all 0.2s;
        }
        .hp-pip.empty {
            background: rgba(255,0,102,0.15);
            box-shadow: none;
            border: 1px solid rgba(255,0,102,0.3);
        }
 
        /* Boss bar */
        #boss-bar-wrap {
            position: absolute; bottom: 30px; left: 50%; transform: translateX(-50%);
            width: 520px; display: none;
            flex-direction: column; align-items: center; gap: 6px;
            z-index: 10; pointer-events: none;
        }
        #boss-name-txt {
            font-family: 'Bebas Neue', cursive;
            font-size: 18px; letter-spacing: 4px;
            color: var(--pink); text-shadow: 0 0 15px var(--pink);
        }
        #boss-track {
            width: 100%; height: 16px;
            background: rgba(0,0,0,0.7);
            border: 1px solid var(--pink);
            border-radius: 8px; overflow: hidden;
            box-shadow: 0 0 20px rgba(255,0,102,0.3);
        }
        #boss-fill {
            height: 100%;
            background: linear-gradient(90deg, #ff0066, #ff4400);
            transition: width 0.08s linear;
        }
 
        /* ====== SCREENS ====== */
        .screen {
            position: absolute; inset: 0;
            display: flex; flex-direction: column;
            align-items: center; justify-content: center;
            background: rgba(4, 2, 14, 0.92);
            backdrop-filter: blur(12px);
            z-index: 20;
            transition: opacity 0.4s;
        }
        .screen.hidden { opacity: 0; pointer-events: none; }
 
        .game-title {
            font-family: 'Bebas Neue', cursive;
            font-size: clamp(56px, 10vw, 96px);
            color: var(--pink);
            text-shadow: 4px 4px 0 #000, 0 0 30px var(--pink), 0 0 60px rgba(255,0,102,0.4);
            letter-spacing: 6px;
            animation: titleFloat 3s ease-in-out infinite;
            line-height: 1;
        }
        .game-subtitle {
            font-size: 11px; letter-spacing: 6px; text-transform: uppercase;
            color: var(--cyan); margin: 8px 0 28px;
            opacity: 0.8;
        }
        @keyframes titleFloat {
            0%, 100% { transform: translateY(0) skewX(-1deg); }
            50% { transform: translateY(-8px) skewX(1deg); }
        }
 
        /* Level grid */
        .level-grid {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 10px;
            margin-bottom: 20px;
            max-width: 580px; width: 90%;
        }
 
        .btn {
            font-family: 'Bebas Neue', cursive;
            font-size: 16px; letter-spacing: 2px;
            border: 1px solid var(--cyan);
            background: rgba(0,255,238,0.04);
            color: var(--cyan);
            padding: 10px 8px;
            border-radius: 4px;
            cursor: pointer;
            transition: all 0.18s;
        }
        .btn:hover {
            background: var(--cyan); color: #000;
            box-shadow: 0 0 20px var(--cyan);
            transform: translateY(-2px);
        }
        .btn-boss { border-color: var(--pink); color: var(--pink); }
        .btn-boss:hover { background: var(--pink); color: #fff; box-shadow: 0 0 20px var(--pink); }
        .btn-boss2 { border-color: var(--orange); color: var(--orange); }
        .btn-boss2:hover { background: var(--orange); color: #fff; box-shadow: 0 0 20px var(--orange); }
 
        .menu-row { display: flex; gap: 10px; flex-wrap: wrap; justify-content: center; margin-bottom: 18px; }
        .btn-skin { border-color: #fff; color: #fff; }
        .btn-skin:hover, .btn-skin.active { background: #fff; color: #000; box-shadow: 0 0 20px #fff; }
        .btn-music { border-color: var(--yellow); color: var(--yellow); }
        .btn-music:hover, .btn-music.active { background: var(--yellow); color: #000; box-shadow: 0 0 20px var(--yellow); }
        .btn-ai { border-color: var(--purple); color: var(--purple); }
        .btn-ai:hover, .btn-ai.active { background: var(--purple); color: #fff; box-shadow: 0 0 20px var(--purple); }
 
        .controls-grid {
            display: grid; grid-template-columns: 1fr 1fr;
            gap: 8px 24px;
            background: rgba(0,0,0,0.4);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 6px;
            padding: 16px 24px;
            max-width: 600px; width: 90%;
            font-size: 11px;
        }
        .ctrl-key { color: var(--cyan); font-size: 12px; }
        .ctrl-desc { color: rgba(255,255,255,0.5); font-size: 10px; margin-top: 1px; }
 
        /* Combo flash overlay */
        #combo-flash {
            position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
            font-family: 'Bebas Neue', cursive;
            font-size: 80px; pointer-events: none;
            z-index: 15; opacity: 0;
            text-shadow: 0 0 30px var(--yellow);
            color: var(--yellow);
            transition: opacity 0.3s;
        }
 
        /* Toast notifications */
        #toast-wrap {
            position: absolute; bottom: 80px; right: 24px;
            display: flex; flex-direction: column; gap: 6px;
            pointer-events: none; z-index: 15;
        }
        .toast {
            font-family: 'Bebas Neue', cursive;
            font-size: 14px; letter-spacing: 2px;
            padding: 6px 14px;
            background: rgba(0,0,0,0.7);
            border-left: 3px solid var(--cyan);
            border-radius: 2px;
            animation: toastIn 0.2s ease, toastOut 0.3s ease 1.5s forwards;
        }
        @keyframes toastIn { from { transform: translateX(20px); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
        @keyframes toastOut { to { transform: translateX(20px); opacity: 0; } }
 
        /* Scanline effect */
        #scanlines {
            position: absolute; inset: 0;
            background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,0.08) 2px, rgba(0,0,0,0.08) 4px);
            pointer-events: none; z-index: 5;
        }
    </style>
</head>
<body>
 
<canvas id="c"></canvas>
<div id="scanlines"></div>
 
<!-- HUD -->
<div id="hud">
    <div class="hud-block">
        <div class="hud-label">Level</div>
        <div class="hud-value" id="lv-val">1</div>
    </div>
    <div class="hud-block">
        <div class="hud-label">Score</div>
        <div class="hud-value" id="score-val">0</div>
    </div>
    <div id="od-wrap">
        <div id="od-label">OVERDRIVE</div>
        <div id="od-track"><div id="od-fill"></div></div>
    </div>
    <div class="hud-block">
        <div class="hud-label">Combo</div>
        <div class="hud-value" id="combo-val">x1</div>
    </div>
    <div class="hud-block">
        <div class="hud-label">HP</div>
        <div id="health-wrap">
            <div class="hp-pip" id="hp0"></div>
            <div class="hp-pip" id="hp1"></div>
            <div class="hp-pip" id="hp2"></div>
        </div>
    </div>
</div>
 
<!-- Boss bar -->
<div id="boss-bar-wrap">
    <div id="boss-name-txt">???</div>
    <div id="boss-track"><div id="boss-fill" style="width:100%"></div></div>
</div>
 
<!-- Combo flash -->
<div id="combo-flash"></div>
 
<!-- Toasts -->
<div id="toast-wrap" id="toast-wrap"></div>
 
<!-- Start Screen -->
<div class="screen" id="start-screen">
    <div class="game-title">NEON OVERDRIVE</div>
    <div class="game-subtitle">v2.0 — Hyper Edition</div>
 
    <div class="level-grid">
        <button class="btn" onclick="startGame(1)">Lv 1</button>
        <button class="btn" onclick="startGame(2)">Lv 2</button>
        <button class="btn" onclick="startGame(3)">Lv 3</button>
        <button class="btn" onclick="startGame(4)">Lv 4</button>
        <button class="btn btn-boss" onclick="startGame(5)">BOSS 1</button>
        <button class="btn" onclick="startGame(6)">Lv 6</button>
        <button class="btn" onclick="startGame(7)">Lv 7</button>
        <button class="btn" onclick="startGame(8)">Lv 8</button>
        <button class="btn" onclick="startGame(9)">Lv 9</button>
        <button class="btn btn-boss2" onclick="startGame(10)">BOSS 2</button>
    </div>
 
    <div class="menu-row">
        <button class="btn btn-skin" id="skinBtn" onclick="cycleSkin()">🎨 Skin: Neon Pink</button>
        <button class="btn btn-music" id="musicBtn" onclick="toggleMusic()">🎵 Music: OFF</button>
        <button class="btn btn-ai" id="aiBtn" onclick="toggleAI()">🤖 AI Guide: OFF</button>
    </div>
 
    <div class="controls-grid">
        <div><div class="ctrl-key">A / D  or  ←/→</div><div class="ctrl-desc">Move</div></div>
        <div><div class="ctrl-key">SPACE / W / ↑</div><div class="ctrl-desc">Jump (double-jump available)</div></div>
        <div><div class="ctrl-key">SHIFT</div><div class="ctrl-desc">Hyper Dash (i-frames)</div></div>
        <div><div class="ctrl-key">X / J</div><div class="ctrl-desc">Shoot projectiles</div></div>
        <div><div class="ctrl-key">Cyan Diamonds ×10</div><div class="ctrl-desc">Triggers OVERDRIVE mode</div></div>
        <div><div class="ctrl-key">Stomp enemies</div><div class="ctrl-desc">Jump on heads for kills</div></div>
        <div><div class="ctrl-key">3 HP pips</div><div class="ctrl-desc">Hit enemies to lose HP</div></div>
        <div><div class="ctrl-key">Red Hearts</div><div class="ctrl-desc">Collect to restore HP</div></div>
    </div>
</div>
 
<script>
'use strict';
// ─── Canvas setup ───────────────────────────────────────────────
const canvas = document.getElementById('c');
const ctx = canvas.getContext('2d');
let W, H;
 
function resize() {
    W = canvas.width = window.innerWidth;
    H = canvas.height = window.innerHeight;
}
window.addEventListener('resize', resize); resize();
 
// ─── Constants / Config ─────────────────────────────────────────
const GRAVITY = 0.48;
const MAX_PARTICLES = 600;
const COLORS = {
    pink: '#ff0066', cyan: '#00ffee', purple: '#aa00ff',
    green: '#00ff88', orange: '#ff6600', yellow: '#ffee00',
    white: '#ffffff', red: '#ff2222'
};
 
// ─── Skins ──────────────────────────────────────────────────────
const SKINS = [
    { name: 'Neon Pink', main: '#ff0066', glow: '#ff0066', core: '#ffaacc' },
    { name: 'Toxic Green', main: '#00ff88', glow: '#00ff88', core: '#aaffcc' },
    { name: 'Electric Blue', main: '#00aaff', glow: '#00aaff', core: '#aaddff' },
    { name: 'Golden Blaze', main: '#ffaa00', glow: '#ff6600', core: '#ffeeaa' },
    { name: 'Void Purple', main: '#cc00ff', glow: '#cc00ff', core: '#ddaaff' },
];
let skinIdx = 0;
function cycleSkin() {
    skinIdx = (skinIdx + 1) % SKINS.length;
    const s = SKINS[skinIdx];
    const btn = document.getElementById('skinBtn');
    btn.textContent = `🎨 Skin: ${s.name}`;
    btn.style.borderColor = s.main; btn.style.color = s.main;
    document.querySelector('.game-title').style.color = s.main;
    document.querySelector('.game-title').style.textShadow = `4px 4px 0 #000, 0 0 30px ${s.main}, 0 0 60px ${s.main}44`;
}
 
// ─── Audio ──────────────────────────────────────────────────────
let audioCtx;
let musicOn = false, musicTimer;
const BASS = [55, 55, 65.41, 55, 73.42, 55, 65.41, 55];
let bassIdx = 0;
 
function initAudio() {
    if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    if (audioCtx.state === 'suspended') audioCtx.resume();
}
 
function tone(freq, type, vol, dur, bend) {
    if (!audioCtx) return;
    const o = audioCtx.createOscillator(), g = audioCtx.createGain();
    o.type = type;
    o.frequency.setValueAtTime(freq, audioCtx.currentTime);
    if (bend) o.frequency.exponentialRampToValueAtTime(freq * bend, audioCtx.currentTime + dur);
    g.gain.setValueAtTime(vol, audioCtx.currentTime);
    g.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + dur);
    o.connect(g); g.connect(audioCtx.destination);
    o.start(); o.stop(audioCtx.currentTime + dur);
}
 
const SFX = {
    jump:    () => tone(320, 'square', 0.04, 0.2, 1.6),
    land:    (v) => tone(120, 'triangle', 0.03 * v, 0.1, 0.5),
    collect: () => { tone(800, 'sine', 0.08, 0.1); setTimeout(() => tone(1200, 'sine', 0.08, 0.15), 50); },
    die:     () => { tone(100, 'sawtooth', 0.15, 0.5, 0.1); tone(60, 'square', 0.1, 0.6, 0.05); },
    hit:     () => tone(180, 'square', 0.08, 0.12, 0.5),
    shoot:   () => tone(700, 'sawtooth', 0.03, 0.08, 0.1),
    dash:    () => tone(450, 'sine', 0.07, 0.25, 0.08),
    bounce:  () => tone(260, 'square', 0.07, 0.4, 3.0),
    heart:   () => { tone(500, 'sine', 0.12, 0.15, 1.5); setTimeout(() => tone(700, 'sine', 0.1, 0.2, 1.5), 100); },
    powerup: () => { [400,600,800,1000].forEach((f,i) => setTimeout(() => tone(f, 'square', 0.08, 0.15, 1.5), i * 80)); },
    level:   () => { [300,500,700,900,1100].forEach((f,i) => setTimeout(() => tone(f, 'sine', 0.1, 0.2), i * 60)); },
};
 
function toggleMusic() {
    initAudio(); musicOn = !musicOn;
    const btn = document.getElementById('musicBtn');
    if (musicOn) {
        btn.textContent = '🎵 Music: ON'; btn.classList.add('active');
        musicTimer = setInterval(() => {
            if (!gameActive) return;
            tone(BASS[bassIdx], 'sawtooth', 0.12, 0.22, 0.9);
            // Add occasional chords
            if (bassIdx % 4 === 0) tone(BASS[bassIdx] * 1.5, 'triangle', 0.05, 0.22);
            bassIdx = (bassIdx + 1) % BASS.length;
        }, 240);
    } else {
        btn.textContent = '🎵 Music: OFF'; btn.classList.remove('active');
        clearInterval(musicTimer);
    }
}
 
// ─── Input ──────────────────────────────────────────────────────
const keys = { left:false, right:false, jump:false, jumpTap:false, shoot:false, dash:false };
window.addEventListener('keydown', e => {
    if (['Space','ArrowUp','ArrowDown','ArrowLeft','ArrowRight'].includes(e.code)) e.preventDefault();
    if (e.code==='ArrowLeft'||e.code==='KeyA') keys.left=true;
    if (e.code==='ArrowRight'||e.code==='KeyD') keys.right=true;
    if ((e.code==='Space'||e.code==='ArrowUp'||e.code==='KeyW')&&!keys.jump) { keys.jump=true; keys.jumpTap=true; }
    if (e.code==='KeyX'||e.code==='KeyJ') keys.shoot=true;
    if (e.code==='ShiftLeft'||e.code==='ShiftRight') keys.dash=true;
    if (e.code==='Escape' && gameActive) pauseGame();
});
window.addEventListener('keyup', e => {
    if (e.code==='ArrowLeft'||e.code==='KeyA') keys.left=false;
    if (e.code==='ArrowRight'||e.code==='KeyD') keys.right=false;
    if (e.code==='Space'||e.code==='ArrowUp'||e.code==='KeyW') keys.jump=false;
    if (e.code==='KeyX'||e.code==='KeyJ') keys.shoot=false;
    if (e.code==='ShiftLeft'||e.code==='ShiftRight') keys.dash=false;
});
 
// ─── Particles ──────────────────────────────────────────────────
const particles = [];
function spawnParts(x, y, n, col, spd, grav=0.2) {
    for (let i = 0; i < n && particles.length < MAX_PARTICLES; i++) {
        const a = Math.random() * Math.PI * 2, v = Math.random() * spd;
        particles.push({
            x, y, vx: Math.cos(a)*v, vy: Math.sin(a)*v - Math.random()*spd*0.5,
            col, life: Math.random()*400+200, maxLife: 600,
            size: Math.random()*7+2, grav
        });
    }
}
function spawnSparkLine(x1, y1, x2, y2, col, n=8) {
    for (let i = 0; i < n; i++) {
        const t = i/n;
        particles.push({
            x: x1+(x2-x1)*t + (Math.random()-0.5)*20,
            y: y1+(y2-y1)*t + (Math.random()-0.5)*20,
            vx: (Math.random()-0.5)*3, vy: -Math.random()*2,
            col, life: 300, maxLife: 300,
            size: Math.random()*5+2, grav: 0.05
        });
    }
}
 
// ─── Toast ──────────────────────────────────────────────────────
function toast(msg, col='#00ffee') {
    const wrap = document.getElementById('toast-wrap');
    const el = document.createElement('div');
    el.className = 'toast';
    el.style.borderLeftColor = col;
    el.style.color = col;
    el.textContent = msg;
    wrap.appendChild(el);
    setTimeout(() => el.remove(), 1900);
}
 
// ─── World / Globals ────────────────────────────────────────────
let platforms=[], coins=[], hearts=[], hazards=[], enemies=[];
let boxes=[], levers=[];
let boss=null, bossProj=[], goal=null;
let playerProj=[], enemyProj=[];
let nextGenX=0, currentFloorY=0, platCount=0;
let WIN_X=6000;
 
let gameActive=false, lastTime=0, gtime=0;
let shakePwr=0, hitPause=0, rafId=null;
 
const cam = { x:0, y:0, tx:0, ty:0, zoom:1, tz:1 };
function shake(v) { shakePwr = Math.min(shakePwr+v, 45); }
function hitstop(ms) { hitPause=ms; }
 
let aiEnabled=false;
function toggleAI() {
    aiEnabled=!aiEnabled; initAudio();
    const btn=document.getElementById('aiBtn');
    if (aiEnabled) { btn.textContent='🤖 AI Guide: ON'; btn.classList.add('active'); }
    else { btn.textContent='🤖 AI Guide: OFF'; btn.classList.remove('active'); }
}
 
// ─── Background ─────────────────────────────────────────────────
let stars=[], bgAsteroids=[], bgShips=[], bgLasers=[], bgExplosions=[];
 
function mkAsteroid(x,y) {
    const sz=Math.random()*55+12;
    const pts=[];
    const n=Math.floor(Math.random()*5)+6;
    for(let i=0;i<n;i++){const a=(i/n)*Math.PI*2, r=sz*(0.55+Math.random()*0.45); pts.push({x:Math.cos(a)*r,y:Math.sin(a)*r});}
    return {x,y,vx:(Math.random()>0.5?1:-1)*(Math.random()*0.06+0.01),vy:(Math.random()-0.5)*0.03,rot:Math.random()*Math.PI*2,rs:(Math.random()-0.5)*0.003,sz,dp:Math.random()*0.4+0.1,pts};
}
function mkShip(fac) {
    const dp=Math.random()*0.35+0.15;
    const sx=fac===1? -200-Math.random()*400 : W+200+Math.random()*400;
    return {fac,x:sx+cam.x*dp,y:(Math.random()*H*0.8+H*0.1)+cam.y*dp,vx:fac*(Math.random()*0.2+0.1),ty:0,dp,scale:Math.random()*0.35+0.2,t:0,fireT:Math.random()*2000+1000,dodgeT:Math.random()*2000};
}
function initBG() {
    stars=[]; bgAsteroids=[]; bgShips=[];
    for(let i=0;i<220;i++) stars.push({x:Math.random()*W,y:Math.random()*H,sz:Math.random()*1.8+0.3,dp:Math.random()*0.5+0.1,blink:Math.random()*100});
    for(let i=0;i<12;i++) bgAsteroids.push(mkAsteroid(Math.random()*W,Math.random()*H));
    for(let i=0;i<12;i++) bgShips.push(mkShip(i%2===0?1:-1));
}
initBG();
window.addEventListener('resize', initBG);
 
// ─── World Generation ────────────────────────────────────────────
function resetWorld() {
    platforms=[]; coins=[]; hearts=[]; hazards=[]; enemies=[];
    boxes=[]; levers=[]; boss=null; bossProj=[]; goal=null;
    playerProj=[]; enemyProj=[];
    nextGenX=-100; currentFloorY=0; platCount=0;
 
    WIN_X = 5500 + currentLevel * 900;
    const lvl=currentLevel;
 
    document.getElementById('boss-bar-wrap').style.display='none';
 
    if (lvl===5||lvl===10) {
        // Boss arena
        platforms.push({x:-200,y:120,w:1600,h:600,type:'ground',active:true});
        platforms.push({x:-200,y:-1200,w:50,h:1400,type:'ground',active:true});
        platforms.push({x:1150,y:-1200,w:50,h:1400,type:'ground',active:true});
        // Add 3 floating platforms for the player to use
        platforms.push({x:80,y:-60,w:160,h:20,type:'plat',active:true,vx:0,vy:0,baseX:80,baseY:-60,timeOff:0});
        platforms.push({x:380,y:-130,w:120,h:20,type:'plat',active:true,vx:2,vy:0,baseX:380,baseY:-130,timeOff:1.5});
        platforms.push({x:720,y:-60,w:160,h:20,type:'plat',active:true,vx:0,vy:0,baseX:720,baseY:-60,timeOff:3.0});
        initBoss(lvl===5?1:2);
        return;
    }
 
    platforms.push({x:-100,y:120,w:700,h:600,type:'ground',active:true});
    nextGenX=600; platCount++;
    generateMore(W*3);
}
 
function generateMore(until) {
    if (goal||(currentLevel===5||currentLevel===10)) return;
    const diff=1+currentLevel*0.18;
 
    while (nextGenX<until) {
        if (nextGenX>=WIN_X) {
            platforms.push({x:nextGenX,y:currentFloorY,w:1200,h:800,type:'ground',active:true});
            goal={x:nextGenX+600,y:currentFloorY-130,w:90,h:130};
            nextGenX+=1200; return;
        }
 
        const gap=Math.random()*(100*diff)+40;
        const dY=(Math.random()*160*diff)-80;
        currentFloorY=Math.max(-600,Math.min(600,currentFloorY+dY));
        nextGenX+=gap;
 
        const isMoving=currentLevel>=2&&Math.random()<(0.2+currentLevel*0.04)&&platCount>2;
        const isBouncy=currentLevel>=3&&!isMoving&&Math.random()<0.12;
        const isCrumble=currentLevel>=5&&!isMoving&&!isBouncy&&Math.random()<0.1;
        let pw=Math.random()*280+100;
        if (isBouncy) pw=90;
 
        const p={
            x:nextGenX, y:currentFloorY, w:pw, h:isBouncy?22:800,
            type:isCrumble?'crumble':isBouncy?'bounce':'ground',
            active:true, opacity:1,
            vx:0, vy:0, baseX:nextGenX, baseY:currentFloorY, timeOff:Math.random()*100,
            crumbleTimer:-1, crumbled:false
        };
        if (isMoving) {
            const spd=(Math.random()*1.8+0.8)*diff;
            if (Math.random()>0.5) p.vx=spd*(Math.random()>0.5?1:-1);
            else p.vy=spd*(Math.random()>0.5?1:-1);
        }
        platforms.push(p); platCount++;
 
        // Walker enemy
        if (currentLevel>=2&&Math.random()<(0.15+currentLevel*0.04)&&pw>130&&!isMoving&&!isBouncy) {
            enemies.push(mkWalker(p));
        }
        // Flyer
        if (currentLevel>=4&&Math.random()<(0.08+currentLevel*0.025)) {
            enemies.push(mkFlyer(nextGenX+pw/2,currentFloorY-200-Math.random()*100));
        }
        // Sniper turret
        if (currentLevel>=6&&Math.random()<0.08&&pw>180&&!isMoving&&!isBouncy) {
            enemies.push(mkTurret(p));
        }
        // Shield walker (level 7+)
        if (currentLevel>=7&&Math.random()<0.07&&pw>150&&!isMoving) {
            enemies.push(mkShieldWalker(p));
        }
        // Mines (level 8+)
        if (currentLevel>=8&&Math.random()<0.1) {
            hazards.push({x:nextGenX+pw/2-15,y:currentFloorY-30,w:30,h:30,type:'mine',timer:0});
        }
 
        // Door/lever puzzle
        if (currentLevel>=6&&Math.random()<0.2&&pw>220&&!isMoving&&!isBouncy) {
            const door={x:nextGenX+pw/2,y:currentFloorY-210,w:36,h:210,type:'door',active:true,opacity:1};
            platforms.push(door);
            levers.push({x:nextGenX+60,y:currentFloorY-44,w:22,h:44,active:false,target:door});
            boxes.push({x:nextGenX+pw-90,y:currentFloorY-56,w:56,h:56,vx:0,vy:0,grounded:false});
        }
 
        // Coin
        if (Math.random()>0.25) {
            const baseY=currentFloorY-60-Math.random()*50;
            coins.push({x:nextGenX+pw/2,y:baseY,w:22,h:22,baseY,t:Math.random()*100,collected:false});
        }
        // Heart pickup (less common)
        if (Math.random()<0.08&&currentLevel>1) {
            const baseY=currentFloorY-75;
            hearts.push({x:nextGenX+pw/2-40,y:baseY,baseY,t:Math.random()*100,collected:false});
        }
        // Spike hazard
        if (Math.random()<(0.12+currentLevel*0.02)&&pw>180&&!isMoving&&!isBouncy) {
            const hw=Math.random()*60+20;
            hazards.push({x:nextGenX+pw/2-hw/2,y:currentFloorY-22,w:hw,h:22,type:'spike'});
        }
 
        nextGenX+=pw;
    }
}
 
// Enemy factories
function mkWalker(plat) {
    return {type:'walker',x:plat.x+plat.w/2,y:plat.y-30,w:30,h:30,
        vx:1.5*(1+currentLevel*0.1),minX:plat.x+10,maxX:plat.x+plat.w-40,
        isDead:false,deathTimer:0,anim:Math.random()*100,hp:1};
}
function mkFlyer(x,y) {
    return {type:'flyer',x,y,w:32,h:22,vx:0,isDead:false,deathTimer:0,
        anim:Math.random()*100,shootT:Math.random()*1200+800,hp:1,
        pattern:Math.floor(Math.random()*2)};
}
function mkTurret(plat) {
    return {type:'turret',x:plat.x+plat.w/2-16,y:plat.y-50,w:32,h:50,
        isDead:false,deathTimer:0,shootT:Math.random()*2000+1000,
        charged:0,hp:2,anim:0};
}
function mkShieldWalker(plat) {
    return {type:'shieldWalker',x:plat.x+plat.w/2,y:plat.y-38,w:36,h:38,
        vx:1.2*(1+currentLevel*0.08),minX:plat.x+10,maxX:plat.x+plat.w-46,
        isDead:false,deathTimer:0,anim:Math.random()*100,hp:3,shieldAngle:0};
}
 
// Boss init
