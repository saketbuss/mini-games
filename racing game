                { id: "truck", name: "Heavy Hauler", color: 0x3b82f6, stats: { topSpeed: 1.2, accel: 0.85, handling: 0.85 }, chassis: [2.6, 1.2, 6.5], cab: [2.6, 1.0, 2.0], cabPos: [0, 1.1, 1.5], wheels: [[-1.4, -0.2, 2.0], [1.4, -0.2, 2.0], [-1.4, -0.2, -2.0], [1.4, -0.2, -2.0]], wRad: 0.6 },
