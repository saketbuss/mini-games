<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Apple Glass - AR Drive & Flight</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@100;300;400;600&display=swap');
        
        body, html {
            margin: 0;
            padding: 0;
            width: 100%;
            height: 100%;
            overflow: hidden;
            background-color: #000;
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            touch-action: none;
        }

        #game-canvas {
            display: block;
            width: 100%;
            height: 100%;
            position: absolute;
            top: 0;
            left: 0;
            z-index: 1;
        }

        /* Apple Glass / AR HUD Styles */
        .glass-hud {
            z-index: 10;
            pointer-events: none;
            color: rgba(255, 255, 255, 0.95);
            text-shadow: 0 0 10px rgba(0, 150, 255, 0.5);
        }

        .glass-panel {
            background: rgba(15, 25, 40, 0.2);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(100, 200, 255, 0.15);
            border-radius: 16px;
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.3);
        }

        #ui-layer {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 20;
            pointer-events: none;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            padding: 1.5rem;
            box-sizing: border-box;
            opacity: 0;
            transition: opacity 1s ease-in-out;
        }

        #startup-screen {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 50;
            background: #000;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            color: white;
            transition: opacity 1s ease;
            pointer-events: auto;
        }

        .ar-reticle {
            width: 60px;
            height: 60px;
            border: 1px solid rgba(255,255,255,0.3);
            border-radius: 50%;
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .ar-reticle::after {
            content: '';
            width: 4px;
            height: 4px;
            background: rgba(255,255,255,0.8);
            border-radius: 50%;
        }

        .touch-zone {
            position: absolute;
            top: 0;
            width: 50%;
            height: 100%;
            z-index: 15;
            pointer-events: auto;
        }
        #touch-left { left: 0; }
        #touch-right { right: 0; }
        
        #touch-boost {
            position: absolute;
            bottom: 40%;
            right: 5%;
            width: 80px;
            height: 80px;
            border-radius: 50%;
            background: rgba(74, 222, 128, 0.2);
            border: 2px solid rgba(74, 222, 128, 0.8);
            z-index: 25;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #4ade80;
            font-weight: bold;
            font-size: 12px;
            letter-spacing: 2px;
            pointer-events: auto;
            user-select: none;
            opacity: 0.8;
            transition: transform 0.1s, background 0.1s;
        }
        #touch-boost:active { transform: scale(0.9); background: rgba(74, 222, 128, 0.5); }

        #touch-flight {
            position: absolute;
            bottom: 40%;
            left: 5%;
            width: 80px;
            height: 80px;
            border-radius: 50%;
            background: rgba(59, 130, 246, 0.2);
            border: 2px solid rgba(59, 130, 246, 0.8);
            z-index: 25;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #3b82f6;
            font-weight: bold;
            font-size: 12px;
            letter-spacing: 1px;
            pointer-events: auto;
            user-select: none;
            opacity: 0.8;
            transition: transform 0.1s, background 0.3s;
        }
        #touch-flight:active { transform: scale(0.9); }

        #damage-flash {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(255, 0, 0, 0.3);
            z-index: 30;
            pointer-events: none;
            opacity: 0;
            transition: opacity 0.2s;
        }

        .ar-scrollbar::-webkit-scrollbar { height: 4px; width: 4px; }
        .ar-scrollbar::-webkit-scrollbar-track { background: rgba(255, 255, 255, 0.05); border-radius: 4px; }
        .ar-scrollbar::-webkit-scrollbar-thumb { background: rgba(74, 222, 128, 0.5); border-radius: 4px; }
        
        .skin-card {
            min-width: 140px;
            flex-shrink: 0;
            scroll-snap-align: start;
        }
    </style>
</head>
<body>

    <canvas id="game-canvas"></canvas>
    <div id="damage-flash"></div>

    <div id="touch-left" class="touch-zone"></div>
    <div id="touch-right" class="touch-zone"></div>
    <div id="touch-boost" class="glass-panel" style="display: none;">BOOST</div>
    <div id="touch-flight" class="glass-panel" style="display: none;">FLIGHT</div>

    <!-- AR Interface -->
    <div id="ui-layer">
        <div class="flex justify-between items-start w-full glass-hud">
            <div class="flex items-center gap-3">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-white opacity-70"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                <div class="flex flex-col w-32 md:w-48">
                    <div class="flex justify-between w-full items-end">
                        <span class="text-[10px] md:text-xs font-semibold tracking-widest opacity-50 uppercase">Race Progress</span>
                        <span id="race-pct" class="text-xs font-bold">0%</span>
                    </div>
                    <div class="w-full h-1 bg-white/20 mt-1 rounded-full overflow-hidden">
                        <div id="race-progress-bar" class="h-full bg-green-400 w-0 transition-all duration-300 shadow-[0_0_8px_rgba(74,222,128,0.8)]"></div>
                    </div>
                </div>
            </div>
            
            <div class="glass-panel px-4 py-2 flex flex-col items-end gap-1">
                <div class="flex items-center gap-2">
                    <div class="w-2 h-2 rounded-full bg-green-400 animate-pulse shadow-[0_0_5px_#4ade80]"></div>
                    <span class="text-xs font-medium tracking-widest">AR LINK ACTIVE</span>
                </div>
                <span id="hud-vehicle-name" class="text-[10px] font-mono opacity-50 uppercase">CONCEPT_V1</span>
            </div>
        </div>

        <div class="ar-reticle glass-hud"></div>

        <div class="flex justify-between items-end w-full glass-hud">
            <div class="flex flex-col">
                <span class="text-xs font-semibold tracking-widest opacity-50 uppercase mb-1">Velocity</span>
                <div class="flex items-baseline gap-1">
                    <span id="speed-display" class="text-5xl md:text-6xl font-thin tracking-tighter">000</span>
                    <span class="text-sm md:text-lg font-light opacity-70">MPH</span>
                </div>
                <div class="w-24 md:w-32 h-1 bg-white/20 mt-2 rounded-full overflow-hidden">
                    <div id="rpm-bar" class="h-full bg-white w-0 transition-all duration-75"></div>
                </div>
                <span class="text-[10px] font-semibold tracking-widest text-cyan-400 opacity-80 uppercase mt-3 mb-1">Nitro Reserve</span>
                <div class="w-24 md:w-32 h-1.5 bg-cyan-900/40 rounded-full overflow-hidden border border-cyan-500/30">
                    <div id="nitro-bar" class="h-full bg-cyan-400 w-full transition-all duration-75 shadow-[0_0_8px_rgba(34,211,238,0.8)]"></div>
                </div>
            </div>

            <div class="flex flex-col items-end text-right">
                <span class="text-xs font-semibold tracking-widest opacity-50 uppercase mb-1">Position</span>
                <div class="flex items-baseline gap-1">
                    <span id="position-display" class="text-4xl md:text-5xl font-light flex items-baseline gap-1">1 <span class="text-sm md:text-lg font-light opacity-70">/ 4</span></span>
                </div>
                <span id="status-msg" class="text-[10px] md:text-xs font-medium mt-2 tracking-wide text-blue-300">SYSTEM NOMINAL</span>
            </div>
        </div>
    </div>

    <!-- Startup Screen -->
    <div id="startup-screen">
        <h1 class="text-3xl font-light tracking-widest mb-2 mt-4 text-white drop-shadow-[0_0_15px_rgba(255,255,255,0.5)]">GLASS<span class="font-semibold text-green-400">OS</span></h1>
        
        <p class="text-[10px] font-bold opacity-50 uppercase tracking-[0.2em] mb-2 w-full max-w-2xl px-4 text-left">1. Select Vehicle Frame</p>
        <div id="skin-list" class="flex gap-3 mb-4 overflow-x-auto w-full max-w-2xl px-4 pb-2 ar-scrollbar snap-x"></div>

        <p class="text-[10px] font-bold opacity-50 uppercase tracking-[0.2em] mb-2 mt-2 w-full max-w-2xl px-4 text-left">2. Select Race Parameter</p>
        <div id="level-list" class="flex flex-col gap-2 mb-6 max-h-40 overflow-y-auto w-full max-w-2xl px-4 ar-scrollbar z-10"></div>

        <button id="start-btn" class="glass-panel px-12 py-3 text-sm tracking-widest uppercase font-bold hover:bg-white/10 transition-colors cursor-pointer border-green-400/50 hover:border-green-400 shadow-[0_0_15px_rgba(74,222,128,0.2)]">
            Initialize Drive
        </button>
        <p class="text-[11px] opacity-50 mt-4 max-w-sm text-center pb-4 leading-relaxed">
            Use Arrow Keys, A/D, or tap screen sides to steer.<br>
            <span class="text-green-400 font-bold">Space</span> to Boost. <span class="text-blue-400 font-bold">F</span> to Transform.
        </p>
    </div>

    <!-- End Screen -->
    <div id="end-screen" style="display: none; opacity: 0; pointer-events: auto;" class="absolute top-0 left-0 w-full h-full z-50 bg-black/90 flex flex-col items-center justify-center text-white transition-opacity duration-1000">
        <h1 class="text-4xl md:text-5xl font-light tracking-widest mb-4">RACE <span class="font-semibold text-green-400">COMPLETE</span></h1>
        <p class="text-xl font-light mb-8">FINAL POSITION: <span id="final-pos" class="font-bold text-5xl ml-2">1</span><span class="text-lg opacity-50"> / 4</span></p>
        <button id="restart-btn" class="glass-panel px-8 py-3 text-sm tracking-widest uppercase hover:bg-white/10 transition-colors cursor-pointer">
            Return to Garage
        </button>
    </div>

    <script>
        window.onload = function() {
            // --- Three.js Setup ---
            const canvas = document.getElementById('game-canvas');
            const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: false });
            renderer.setSize(window.innerWidth, window.innerHeight);
            renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
            
            const scene = new THREE.Scene();
            scene.background = new THREE.Color(0x050a12);
            scene.fog = new THREE.Fog(0x050a12, 50, 600); 

            const camera = new THREE.PerspectiveCamera(60, window.innerWidth / window.innerHeight, 0.1, 1500);
            camera.position.set(0, 4, -12);
            camera.lookAt(0, 0, 10);

            const hemiLight = new THREE.HemisphereLight(0xffffff, 0x444455, 0.8);
            hemiLight.position.set(0, 20, 0);
            scene.add(hemiLight);

            const dirLight = new THREE.DirectionalLight(0xffffff, 1.5);
            dirLight.position.set(20, 50, -20);
            scene.add(dirLight);

            // --- Game Configuration Data ---
