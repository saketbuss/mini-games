// Procedural Ground Texture
function makeGroundTex(){
  const cv=document.createElement('canvas');cv.width=cv.height=2048;
  const cx=cv.getContext('2d');
  cx.fillStyle='#1a1e1a';cx.fillRect(0,0,2048,2048);
  // Grime/noise
  for(let i=0;i<30000;i++){
    const x=Math.random()*2048,y=Math.random()*2048;
    cx.fillStyle=`rgba(${Math.floor(Math.random()*30)},${Math.floor(Math.random()*30)},${Math.floor(Math.random()*30)},${Math.random()*0.8})`;
    cx.fillRect(x,y,Math.random()*3+1,Math.random()*3+1);
  }
  // Grid lines
  cx.strokeStyle='rgba(60,80,60,0.4)';cx.lineWidth=1.5;
  for(let i=0;i<=2048;i+=64){cx.beginPath();cx.moveTo(i,0);cx.lineTo(i,2048);cx.stroke();cx.beginPath();cx.moveTo(0,i);cx.lineTo(2048,i);cx.stroke();}
  // Major grid
  cx.strokeStyle='rgba(80,100,80,0.5)';cx.lineWidth=3;
  for(let i=0;i<=2048;i+=256){cx.beginPath();cx.moveTo(i,0);cx.lineTo(i,2048);cx.stroke();cx.beginPath();cx.moveTo(0,i);cx.lineTo(2048,i);cx.stroke();}
  // Markings
  cx.strokeStyle='rgba(200,180,50,0.25)';cx.lineWidth=6;
  cx.strokeRect(512,512,1024,1024);
  const t=new THREE.CanvasTexture(cv);t.wrapS=t.wrapT=THREE.RepeatWrapping;t.repeat.set(40,40);return t;
}

