function damagePlayer(amount,fromPos){
  if(!player.isAlive)return;
  let dmg=amount;
  if(player.armor>0){const absorbed=Math.min(dmg*0.6,player.armor);player.armor-=absorbed;dmg-=absorbed;}
  player.health=Math.max(0,player.health-dmg);
  
  updateHealthUI();
  
  // Blood overlay
  const bo=document.getElementById('blood-overlay');bo.style.opacity='0.5';setTimeout(()=>bo.style.opacity='0',600);
  
  // Hit direction indicator
  if(fromPos){
    player.recentDamageDir.copy(fromPos).sub(yaw.position).normalize();
    showHitDirection(player.recentDamageDir);
  }
  
  if(player.health<=0){playerDie();}
}

