function switchWep(idx){
  if(reloadTimeout){clearTimeout(reloadTimeout);reloadTimeout=null;}
  reloading=false;chambering=false;shotsFired=0;
  releaseADS();
  document.getElementById('reload-wrap').style.display='none';
  
  curWep=idx;
  const w=WEAPONS[idx];
  document.getElementById('wep-name').textContent=w.name;
  document.getElementById('wep-class').textContent=w.wclass+' • '+(w.type==='ar'?'AUTO':(w.type==='smg'?'AUTO':w.type.toUpperCase()));
  document.getElementById('ammo-cur').textContent=isFinite(w.ammo)?w.ammo:'∞';
  document.getElementById('ammo-max').textContent=isFinite(w.maxAmmo)?w.maxAmmo:'∞';
  updateAmmoBar();
  
  // Slots
  for(let i=0;i<5;i++){const s=document.getElementById('slot'+i);s.classList.toggle('active',i===idx);}
  
  // Attachments
  document.getElementById('att-sight').textContent='◉ '+w.attachSight;
  document.getElementById('att-barrel').textContent='▮ '+w.attachBarrel;
  document.getElementById('att-grip').textContent='◧ '+w.attachGrip;
  
  buildWepMesh(w.type);
  
  // Crosshair type
  const isScope=w.type==='sniper';const isShotgun=w.type==='shotgun';
  document.getElementById('xhair-circle').style.display=isShotgun?'block':'none';
  document.getElementById('xl-dot').style.display=isScope?'none':'block';
  [document.getElementById('xl-t'),document.getElementById('xl-b'),document.getElementById('xl-l'),document.getElementById('xl-r')].forEach(el=>el.style.display=isScope||w.type==='melee'?'none':'block');
}

function updateAmmoBar(){
  const w=WEAPONS[curWep];
  if(!isFinite(w.ammo)){document.getElementById('ammo-bar-fill').style.width='100%';return;}
  const pct=w.ammo/w.maxAmmo*100;
  document.getElementById('ammo-bar-fill').style.width=pct+'%';
  document.getElementById('ammo-bar-fill').style.background=pct<30?'#ff3333':(pct<60?'#ffaa00':'linear-gradient(90deg,#00ff88,#00ffcc)');
}

function triggerReload(){
  const w=WEAPONS[curWep];
  if(w.type==='melee'||w.ammo>=w.maxAmmo)return;
  reloading=true;firing=false;releaseADS();
  playReload();
  const rw=document.getElementById('reload-wrap');rw.style.display='block';
  const fill=document.getElementById('reload-bar-fill');
  fill.style.transition='none';fill.style.width='0%';
  setTimeout(()=>{fill.style.transition=`width ${w.reload}s linear`;fill.style.width='100%';},50);
  
  reloadTimeout=setTimeout(()=>{
    w.ammo=w.maxAmmo;
    document.getElementById('ammo-cur').textContent=w.ammo;
    updateAmmoBar();reloading=false;
    rw.style.display='none';reloadTimeout=null;
  },w.reload*1000);
}

function attemptFire(){
  if(reloading||chambering||!player.isAlive)return;
  if(buildMode)return;
  // Sprint blocking
  if(keys['ShiftLeft']&&!player.isADS&&(player.vel.x**2+player.vel.z**2)**0.5>6)return;
  
  const w=WEAPONS[curWep];const now=Date.now();
  if(now-lastFire<w.rate)return;
  
  if(w.ammo<=0&&isFinite(w.ammo)){playReload();triggerReload();return;}
  
  lastFire=now;shotsFired++;
  if(isFinite(w.ammo)){w.ammo--;document.getElementById('ammo-cur').textContent=w.ammo;updateAmmoBar();}
  if(w.type!=='ar'&&w.type!=='smg')firing=false;
  
  playGunshot(w.type==='ar'?'ar':(w.type==='smg'?'smg':w.type));
  if(w.type!=='melee')ejectShell();
  applyRecoil(w);
  doShakeScreen(w.type==='sniper'?0.1:(w.type==='shotgun'?0.07:0.04));
  
  if(w.type==='sniper'){
    chambering=true;
    setTimeout(()=>{chambering=false;playReload();},800);
  }
  
  if(w.type==='melee'){doMelee(w);return;}
  
  const pellets=w.pellets||1;
  for(let i=0;i<pellets;i++)spawnBullet(w);
  
  muzzleFlash.intensity=4;setTimeout(()=>muzzleFlash.intensity=0,50);
}

function spawnBullet(w){
  const dir=new THREE.Vector3();camera.getWorldDirection(dir);
  
  let sprd=w.spread;
  const velMag=Math.sqrt(player.vel.x**2+player.vel.z**2);
  if(velMag>2)sprd*=2.0;
  if(player.isCrouching)sprd*=0.55;
  if(player.isADS)sprd*=0.15;
  
  if(sprd>0){dir.x+=(Math.random()-0.5)*sprd;dir.y+=(Math.random()-0.5)*sprd;dir.z+=(Math.random()-0.5)*sprd;dir.normalize();}
  
  // Pattern recoil
  if(w.spread>0&&w.type==='ar'&&shotsFired>5){
    const kick=Math.min(shotsFired-5,20)*0.0004;
    dir.y+=kick*0.5;dir.normalize();
  }
  
  const startPos=new THREE.Vector3();camera.getWorldPosition(startPos);
  
  const b=new THREE.Mesh(bulletGeo,bulletMat);
  b.position.copy(startPos);
  b.quaternion.setFromUnitVectors(new THREE.Vector3(0,0,1),dir);
  scene.add(b);
  projectiles.push({mesh:b,vel:dir.clone().multiplyScalar(w.speed),drop:w.drop,dmg:w.dmg,age:0,maxAge:4});
}

function doMelee(w){
  const dir=new THREE.Vector3();camera.getWorldDirection(dir);
  raycaster.set(camera.position.clone().setFromMatrixPosition(camera.matrixWorld),dir);
  raycaster.far=w.range;
  const hittables=[];
  bots.forEach(b=>{if(b.userData.hp>0&&b.visible)b.children.forEach(c=>hittables.push(c));});
  const hits=raycaster.intersectObjects(hittables);
  if(hits.length){
    const hg=hits[0].object.parent;
    if(bots.includes(hg)){damageBot(hg,w.dmg,false,hits[0].point,hits[0].face.normal);}
  }
  doShakeScreen(0.06);
}

function applyRecoil(w){
  const mod=player.isADS?0.45:1.0;const cmod=player.isCrouching?0.65:1.0;
  const kick=(w.type==='sniper'?0.09:(w.type==='shotgun'?0.055:(w.type==='ar'?0.016:0.012)))*mod*cmod;
  recoilState.tgtX+=kick;
  recoilState.tgtY+=(Math.random()-0.5)*kick*0.6;
  wepAnim.rotX=player.isADS?0.04:0.12;
  wepAnim.z=player.isADS?0.08:0.2;
}

function doShakeScreen(i){shake.i=i;}

