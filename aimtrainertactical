  spawnParticles(hitPoint,0xcc0000,isHead?8:4);
  spawnBloodDecal(hitPoint,normal||new THREE.Vector3(0,1,0));
  
  // Flash body
  const orig=b.userData.bodyColor;b.userData.bMat.emissive.setHex(0xffffff);b.userData.bMat.emissiveIntensity=0.6;
  setTimeout(()=>{b.userData.bMat.emissive.setHex(0);b.userData.bMat.emissiveIntensity=0;},60);
  
  // Flinch
  b.rotation.x-=0.15;b.userData.state='evade';b.userData.stateTimer=0;
