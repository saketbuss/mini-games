function createExplosion(pos,radius=8,dmg=80){
  playExplosion();
  spawnParticles(pos,0xff4400,25);
  spawnParticles(pos,0xffcc00,15,true);
  
  // Flash overlay
  const fl=document.getElementById('expl-flash');
  fl.style.opacity='0.7';setTimeout(()=>fl.style.opacity='0',80);
  
  // Camera shake
  doShakeScreen(0.3);
  
  // Damage player if close
  const distToPlayer=pos.distanceTo(yaw.position);
  if(distToPlayer<radius){
    const dmgAmt=dmg*(1-distToPlayer/radius);
    damagePlayer(dmgAmt,pos);
    // Concussion ring
    const cc=document.getElementById('concuss-overlay');
    cc.style.opacity='0.4';cc.style.transition='opacity 2s';
    setTimeout(()=>cc.style.opacity='0',100);
  }
  
  // Damage bots in radius
  bots.forEach(b=>{
    if(!b.visible||b.userData.hp<=0)return;
    if(b.position.distanceTo(pos)<radius){
      const d=dmg*(1-b.position.distanceTo(pos)/radius);
      damageBot(b,d,false,b.position,new THREE.Vector3(0,1,0));
      b.userData.velY=8;
    }
  });
  
  // Explode nearby barrels
  explodableBarrels.forEach(brl=>{
    if(!brl.exploded&&brl.mesh.position.distanceTo(pos)<radius*1.5){
      brl.exploded=true;
      setTimeout(()=>createExplosion(brl.mesh.position,6,50),Math.random()*300);
      scene.remove(brl.mesh);
    }
  });
  
  // Scorch mark
  const scorch=new THREE.Mesh(new THREE.CircleGeometry(radius*0.4,12),new THREE.MeshBasicMaterial({color:0x111111,transparent:true,opacity:0.7,depthWrite:false}));
  scorch.position.copy(pos);scorch.position.y=0.02;scorch.rotation.x=-Math.PI/2;
  scene.add(scorch);decals.push({mesh:scorch,age:0,maxAge:60});
  
  // Explosion light
  const el=new THREE.PointLight(0xff6600,8,radius*2);el.position.copy(pos);scene.add(el);
  let elAge=0;
  const elUpdate=setInterval(()=>{elAge+=0.05;el.intensity*=0.8;if(elAge>0.5){scene.remove(el);clearInterval(elUpdate);}},50);
}

