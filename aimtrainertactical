// MINIMAP
// ═══════════════════════════════════════════════════════════
const mmCv=document.getElementById('minimap-canvas');
const mmCx=mmCv.getContext('2d');
const MM_SCALE=160/160; // 160px = 160 world units
const MM_CENTER=80;// canvas center
const MM_RANGE=80;// world units to show each side

function updateMinimap(){
  mmCx.fillStyle='rgba(4,8,12,0.95)';mmCx.fillRect(0,0,160,160);
  
  // Grid
  mmCx.strokeStyle='rgba(0,255,136,0.04)';mmCx.lineWidth=0.5;
  for(let i=0;i<160;i+=16){mmCx.beginPath();mmCx.moveTo(i,0);mmCx.lineTo(i,160);mmCx.stroke();mmCx.beginPath();mmCx.moveTo(0,i);mmCx.lineTo(0,i);mmCx.lineTo(160,i);mmCx.stroke();}
  
  const px=yaw.position.x,pz=yaw.position.z;
  const scale=160/(MM_RANGE*2);
  
  function worldToMM(wx,wz){return{x:MM_CENTER+(wx-px)*scale,y:MM_CENTER+(wz-pz)*scale};}
  
  // Environment walls (simplified)
  mmCx.fillStyle='rgba(100,110,100,0.4)';
  envMeshes.slice(1,20).forEach(m=>{
    if(!m.geometry)return;
    const {x,y}=worldToMM(m.position.x,m.position.z);
    const bb=m.geometry.boundingBox;if(!bb){m.geometry.computeBoundingBox();}
    const bbc=m.geometry.boundingBox;if(!bbc)return;
    const sw=(bbc.max.x-bbc.min.x)*scale;const sh=(bbc.max.z-bbc.min.z)*scale;
    mmCx.fillRect(x-sw/2,y-sh/2,Math.max(sw,2),Math.max(sh,2));
  });
  
  // Bots
  bots.forEach(b=>{
    if(!b.visible||b.userData.hp<=0)return;
    const {x,y}=worldToMM(b.position.x,b.position.z);
    if(x<0||x>160||y<0||y>160)return;
    mmCx.fillStyle=b.userData.isElite?'#ff3333':'#ff6666';
    mmCx.beginPath();mmCx.arc(x,y,3,0,Math.PI*2);mmCx.fill();
  });
  
  // Drones
  drones.forEach(d=>{
    if(!d.visible||d.userData.hp<=0)return;
    const {x,y}=worldToMM(d.position.x,d.position.z);
    if(x<0||x>160||y<0||y>160)return;
    mmCx.fillStyle='#00ffcc';
    mmCx.fillRect(x-2,y-2,4,4);
  });
  
  // Player
  const heading=yaw.rotation.y;
  mmCx.save();mmCx.translate(MM_CENTER,MM_CENTER);mmCx.rotate(-heading);
  mmCx.fillStyle='#00ff88';
  mmCx.beginPath();mmCx.moveTo(0,-7);mmCx.lineTo(4,5);mmCx.lineTo(-4,5);mmCx.closePath();mmCx.fill();
  mmCx.restore();
  
  // Range ring
  mmCx.strokeStyle='rgba(0,255,136,0.1)';mmCx.lineWidth=1;
  mmCx.beginPath();mmCx.arc(MM_CENTER,MM_CENTER,75,0,Math.PI*2);mmCx.stroke();
}

