let audioCtx;
function initAudio(){if(!audioCtx)audioCtx=new(window.AudioContext||window.webkitAudioContext)();if(audioCtx.state==='suspended')audioCtx.resume();}

function makeNoise(dur,freq,vol,type='noise',pan=0){
  if(!audioCtx)return;
  const t=audioCtx.currentTime;
  const panner=audioCtx.createStereoPanner();panner.pan.value=pan;
  const gain=audioCtx.createGain();gain.gain.setValueAtTime(vol,t);gain.gain.exponentialRampToValueAtTime(0.001,t+dur);
  panner.connect(audioCtx.destination);gain.connect(panner);
  if(type==='noise'){
    const buf=audioCtx.createBuffer(1,audioCtx.sampleRate*dur,audioCtx.sampleRate);
    const d=buf.getChannelData(0);for(let i=0;i<d.length;i++)d[i]=Math.random()*2-1;
    const src=audioCtx.createBufferSource();src.buffer=buf;
    const filt=audioCtx.createBiquadFilter();filt.frequency.value=freq;
    src.connect(filt);filt.connect(gain);src.start(t);
  }else{
    const osc=audioCtx.createOscillator();osc.type=type;
    osc.frequency.setValueAtTime(freq,t);osc.frequency.exponentialRampToValueAtTime(freq*0.3,t+dur);
    osc.connect(gain);osc.start(t);osc.stop(t+dur);
  }
}

function playGunshot(type,pan=0){
  if(!audioCtx)return;
  const t=audioCtx.currentTime;
  const p=audioCtx.createStereoPanner();p.pan.value=Math.max(-1,Math.min(1,pan));p.connect(audioCtx.destination);
  
  // Noise burst
  const buf=audioCtx.createBuffer(1,audioCtx.sampleRate*0.8,audioCtx.sampleRate);
  const d=buf.getChannelData(0);for(let i=0;i<d.length;i++)d[i]=(Math.random()*2-1)*(1-i/(d.length));
  const src=audioCtx.createBufferSource();src.buffer=buf;
  const filt=audioCtx.createBiquadFilter();
  
  const g=audioCtx.createGain();src.connect(filt);filt.connect(g);g.connect(p);

  if(type==='ar'){filt.type='bandpass';filt.frequency.value=2500;filt.Q.value=0.5;g.gain.setValueAtTime(0.7,t);g.gain.exponentialRampToValueAtTime(0.001,t+0.25);src.start(t);}
  else if(type==='smg'){filt.type='bandpass';filt.frequency.value=3500;g.gain.setValueAtTime(0.4,t);g.gain.exponentialRampToValueAtTime(0.001,t+0.12);src.start(t);}
  else if(type==='sniper'){filt.type='lowpass';filt.frequency.value=800;g.gain.setValueAtTime(1.2,t);g.gain.exponentialRampToValueAtTime(0.001,t+1.0);src.start(t);}
  else if(type==='shotgun'){filt.type='lowpass';filt.frequency.value=1200;g.gain.setValueAtTime(1.0,t);g.gain.exponentialRampToValueAtTime(0.001,t+0.6);src.start(t);}
  else if(type==='pistol'){filt.type='bandpass';filt.frequency.value=2000;g.gain.setValueAtTime(0.5,t);g.gain.exponentialRampToValueAtTime(0.001,t+0.2);src.start(t);}
  
  // Body impact
  const osc=audioCtx.createOscillator();const og=audioCtx.createGain();
  osc.type='triangle';osc.frequency.setValueAtTime(type==='sniper'?80:120,t);osc.frequency.exponentialRampToValueAtTime(20,t+0.5);
  og.gain.setValueAtTime(type==='sniper'?1.0:0.7,t);og.gain.exponentialRampToValueAtTime(0.001,t+0.5);
  osc.connect(og);og.connect(p);osc.start(t);osc.stop(t+0.5);
}

function playExplosion(){
  if(!audioCtx)return;
  const t=audioCtx.currentTime;
  const buf=audioCtx.createBuffer(1,audioCtx.sampleRate*2,audioCtx.sampleRate);
  const d=buf.getChannelData(0);for(let i=0;i<d.length;i++)d[i]=(Math.random()*2-1)*(1-i/(d.length*0.8));
  const src=audioCtx.createBufferSource();src.buffer=buf;
  const f=audioCtx.createBiquadFilter();f.type='lowpass';f.frequency.value=600;
  const g=audioCtx.createGain();g.gain.setValueAtTime(2.5,t);g.gain.exponentialRampToValueAtTime(0.001,t+2.0);
  src.connect(f);f.connect(g);g.connect(audioCtx.destination);src.start(t);
  // Sub
  const o=audioCtx.createOscillator();const og=audioCtx.createGain();
  o.type='sine';o.frequency.setValueAtTime(60,t);o.frequency.exponentialRampToValueAtTime(15,t+0.8);
  og.gain.setValueAtTime(2.0,t);og.gain.exponentialRampToValueAtTime(0.001,t+0.8);
  o.connect(og);og.connect(audioCtx.destination);o.start(t);o.stop(t+0.8);
}

function playHit(isHead){
  if(!audioCtx)return;
  const t=audioCtx.currentTime;
  const o=audioCtx.createOscillator();const g=audioCtx.createGain();
  o.type='sine';o.frequency.setValueAtTime(isHead?1500:800,t);o.frequency.exponentialRampToValueAtTime(isHead?2000:1100,t+0.1);
  g.gain.setValueAtTime(isHead?0.8:0.5,t);g.gain.exponentialRampToValueAtTime(0.001,t+0.12);
  o.connect(g);g.connect(audioCtx.destination);o.start(t);o.stop(t+0.15);
}

