const keys={};
let isLocked=false;

document.addEventListener('keydown',e=>{
  keys[e.code]=true;
  if(!isLocked)return;
  
  const k=e.code;
  if(k==='Digit1')switchWep(0);
  if(k==='Digit2')switchWep(1);
  if(k==='Digit3')switchWep(2);
  if(k==='Digit4')switchWep(3);
  if(k==='Digit5')switchWep(4);
  if(k==='KeyR'&&!reloading)triggerReload();
  if(k==='KeyN')toggleNightVision();
  if(k==='KeyG')throwGrenade('frag');
  if(k==='KeyH')throwGrenade('flash');
  if(k==='KeyJ')throwGrenade('smoke');
  if(k==='KeyT')placeC4();
  if(k==='KeyB')detonateC4();
  if(k==='KeyF')toggleBuildMode();
});
document.addEventListener('keyup',e=>{keys[e.code]=false;});

document.addEventListener('mousedown',e=>{
  if(!isLocked)return;
  if(e.button===0){firing=true;attemptFire();}
  if(e.button===2&&!reloading){
    player.isADS=true;
    const w=WEAPONS[curWep];
    if(w.type==='sniper'){document.getElementById('scope').style.display='block';wepGroup.visible=false;}
    document.getElementById('xhair-wrap').style.opacity=w.type==='sniper'?'0':'0.8';
  }
});
document.addEventListener('mouseup',e=>{
  if(e.button===0)firing=false;
  if(e.button===2)releaseADS();
});

const sens=0.002;
document.addEventListener('mousemove',e=>{
  if(!isLocked)return;
  let sm=1;if(player.isADS){sm=WEAPONS[curWep].type==='sniper'?0.12:0.45;}
  yaw.rotation.y-=e.movementX*sens*sm;
  pitch.rotation.x-=e.movementY*sens*sm;
  pitch.rotation.x=Math.max(-Math.PI/2+0.05,Math.min(Math.PI/2-0.05,pitch.rotation.x));
  if(!player.isADS){
    wepAnim.tSwayX+=e.movementY*0.0004;wepAnim.tSwayY+=e.movementX*0.0004;
    wepAnim.tSwayX=Math.max(-0.08,Math.min(0.08,wepAnim.tSwayX));
    wepAnim.tSwayY=Math.max(-0.08,Math.min(0.08,wepAnim.tSwayY));
  }
});

function releaseADS(){
  player.isADS=false;
  document.getElementById('scope').style.display='none';
  document.getElementById('xhair-wrap').style.opacity='1';
  wepGroup.visible=true;
  document.getElementById('breath-wrap').style.display='none';
}

