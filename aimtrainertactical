function damageBot(b,dmg,isHead,hitPoint,normal){
  if(!b.visible||b.userData.hp<=0)return;
  const finalDmg=isHead?dmg*2.8:dmg;
  b.userData.hp-=finalDmg;
  
  playHit(isHead);
