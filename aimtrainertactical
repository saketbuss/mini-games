<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TACTICAL SIM ULTRA — BLACK SITE</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<style>
*{margin:0;padding:0;box-sizing:border-box;}
body{overflow:hidden;background:#000;font-family:'Courier New',monospace;user-select:none;cursor:crosshair;}
#c{display:block;width:100vw;height:100vh;}

/* ─── VIGNETTE & OVERLAY EFFECTS ─── */
#vignette{position:fixed;inset:0;pointer-events:none;background:radial-gradient(ellipse at center,transparent 50%,rgba(0,0,0,0.7) 100%);z-index:2;}
#blood-overlay{position:fixed;inset:0;pointer-events:none;background:radial-gradient(ellipse at center,transparent 60%,rgba(180,0,0,0) 100%);z-index:3;opacity:0;transition:opacity 0.3s;}
#night-vision-overlay{position:fixed;inset:0;pointer-events:none;z-index:4;display:none;background:repeating-linear-gradient(0deg,rgba(0,255,0,0.03) 0px,rgba(0,255,0,0.03) 1px,transparent 1px,transparent 2px);mix-blend-mode:screen;}
#concuss-overlay{position:fixed;inset:0;pointer-events:none;z-index:5;opacity:0;background:white;}
#hit-dir-overlay{position:fixed;inset:0;pointer-events:none;z-index:3;}

/* ─── CROSSHAIRS ─── */
#xhair-wrap{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);pointer-events:none;z-index:10;width:120px;height:120px;}
.xl{position:absolute;background:#00ff88;transition:all 0.08s ease-out;}
#xl-t{top:50%;left:50%;width:2px;height:14px;transform:translate(-50%,-24px);}
#xl-b{top:50%;left:50%;width:2px;height:14px;transform:translate(-50%,10px);}
#xl-l{top:50%;left:50%;width:14px;height:2px;transform:translate(-24px,-50%);}
#xl-r{top:50%;left:50%;width:14px;height:2px;transform:translate(10px,-50%);}
#xl-dot{position:absolute;top:50%;left:50%;width:3px;height:3px;background:#00ff88;border-radius:50%;transform:translate(-50%,-50%);}
#xhair-circle{position:absolute;top:50%;left:50%;width:52px;height:52px;border:1.5px solid rgba(0,255,136,0.5);border-radius:50%;transform:translate(-50%,-50%);display:none;}

/* ─── SCOPE ─── */
#scope{position:fixed;inset:0;display:none;pointer-events:none;z-index:15;background:radial-gradient(circle at 50% 50%,transparent 28%,rgba(0,0,0,0.98) 32%,#000 100%);}
#scope-h{position:absolute;top:50%;left:0;right:0;height:1px;background:rgba(255,255,255,0.8);}
#scope-v{position:absolute;left:50%;top:0;bottom:0;width:1px;background:rgba(255,255,255,0.8);}
#scope-dot{position:absolute;top:50%;left:50%;width:5px;height:5px;background:red;border-radius:50%;transform:translate(-50%,-50%);box-shadow:0 0 8px 3px rgba(255,0,0,0.6);}
.scope-tick-h,.scope-tick-v{position:absolute;background:rgba(255,255,255,0.6);}
#scope-mil1{top:50%;left:calc(50% + 40px);width:1px;height:10px;transform:translateY(-50%);}
#scope-mil2{top:50%;left:calc(50% - 40px);width:1px;height:10px;transform:translateY(-50%);}
#scope-mil3{top:50%;left:calc(50% + 80px);width:1px;height:6px;transform:translateY(-50%);}
#scope-mil4{top:50%;left:calc(50% - 80px);width:1px;height:6px;transform:translateY(-50%);}
#scope-mil5{left:50%;top:calc(50% + 40px);height:1px;width:10px;transform:translateX(-50%);}
#scope-mil6{left:50%;top:calc(50% - 40px);height:1px;width:10px;transform:translateX(-50%);}
#scope-range{position:absolute;top:calc(50% - 80px);left:calc(50% + 15px);color:white;font-size:11px;font-family:'Courier New',monospace;}

/* ─── HUD PANELS ─── */
.panel{background:rgba(4,8,12,0.88);border:1px solid rgba(0,255,136,0.12);backdrop-filter:blur(12px);box-shadow:0 0 30px rgba(0,0,0,0.8),inset 0 0 20px rgba(0,255,136,0.02);}

/* ─── MINIMAP ─── */
#minimap{position:fixed;top:80px;right:20px;width:160px;height:160px;z-index:10;border-radius:4px;overflow:hidden;border:1px solid rgba(0,255,136,0.25);box-shadow:0 0 20px rgba(0,0,0,0.9);}
#minimap canvas{width:100%;height:100%;}
#minimap-frame{position:absolute;inset:0;border:2px solid rgba(0,255,136,0.08);border-radius:3px;pointer-events:none;}
#minimap-label{position:absolute;bottom:4px;left:50%;transform:translateX(-50%);color:rgba(0,255,136,0.6);font-size:8px;letter-spacing:2px;}

/* ─── TOP STATS ─── */
#hud-tl{position:fixed;top:16px;left:16px;z-index:10;padding:12px 16px;border-radius:4px;min-width:200px;}
#hud-tl h1{font-size:11px;font-weight:900;letter-spacing:4px;color:#00ff88;margin-bottom:8px;text-shadow:0 0 12px rgba(0,255,136,0.8);}
.stat-row{display:flex;align-items:center;gap:8px;margin-bottom:4px;}
.stat-label{font-size:9px;color:rgba(255,255,255,0.4);letter-spacing:1px;width:60px;}
.stat-val{font-size:10px;color:#fff;font-weight:bold;letter-spacing:1px;}
.stat-val.green{color:#00ff88;}
.stat-val.yellow{color:#ffd700;}
.stat-val.red{color:#ff3333;}
.stat-val.cyan{color:#00ffff;}
.divider{width:100%;height:1px;background:rgba(0,255,136,0.08);margin:6px 0;}

/* ─── WEAPON HUD ─── */
#hud-br{position:fixed;bottom:16px;right:16px;z-index:10;padding:14px 18px;border-radius:4px;min-width:240px;}
#wep-name{font-size:16px;font-weight:900;color:#fff;letter-spacing:2px;margin-bottom:2px;}
#wep-class{font-size:9px;color:rgba(0,255,136,0.6);letter-spacing:3px;margin-bottom:10px;}
#ammo-display{display:flex;align-items:flex-end;gap:6px;margin-bottom:12px;}
#ammo-cur{font-size:42px;font-weight:900;color:#fff;line-height:1;}
#ammo-sep{font-size:16px;color:rgba(255,255,255,0.3);margin-bottom:4px;}
#ammo-max{font-size:18px;color:rgba(255,255,255,0.4);margin-bottom:4px;}
#ammo-bar{height:3px;background:rgba(255,255,255,0.08);border-radius:2px;margin-bottom:10px;overflow:hidden;}
#ammo-bar-fill{height:100%;background:linear-gradient(90deg,#00ff88,#00ffcc);transition:width 0.1s;border-radius:2px;}
#slots{display:flex;gap:4px;}
.slot{padding:4px 6px;font-size:9px;font-weight:700;border-radius:2px;border:1px solid rgba(255,255,255,0.12);color:rgba(255,255,255,0.4);transition:all 0.15s;letter-spacing:1px;}
.slot.active{background:rgba(0,255,136,0.12);border-color:rgba(0,255,136,0.5);color:#00ff88;box-shadow:0 0 10px rgba(0,255,136,0.2);}

/* ─── KILL FEED ─── */
#killfeed{position:fixed;top:80px;left:16px;z-index:10;display:flex;flex-direction:column;gap:4px;pointer-events:none;}
.kf-entry{background:rgba(4,8,12,0.85);border-left:2px solid #ff3333;padding:4px 10px;font-size:10px;color:#fff;letter-spacing:1px;animation:kfSlide 0.2s ease-out,kfFade 0.5s 3.5s forwards;border-radius:0 3px 3px 0;}
.kf-entry.headshot{border-left-color:#ffd700;}
.kf-entry.multi{border-left-color:#ff6600;}
@keyframes kfSlide{from{transform:translateX(-30px);opacity:0;}to{transform:translateX(0);opacity:1;}}
@keyframes kfFade{from{opacity:1;}to{opacity:0;}}

/* ─── KILLSTREAK ─── */
#killstreak{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);z-index:12;pointer-events:none;text-align:center;opacity:0;transition:opacity 0.3s;}
#killstreak-text{font-size:32px;font-weight:900;letter-spacing:6px;color:#ffd700;text-shadow:0 0 20px rgba(255,215,0,0.8),0 0 60px rgba(255,100,0,0.4);}
#killstreak-sub{font-size:12px;color:rgba(255,215,0,0.7);letter-spacing:4px;margin-top:4px;}

/* ─── CHALLENGE POPUP ─── */
#challenge-pop{position:fixed;top:30%;left:50%;transform:translate(-50%,-50%);z-index:12;pointer-events:none;opacity:0;transition:all 0.3s;}
#challenge-pop-inner{background:rgba(0,0,0,0.9);border:1px solid rgba(255,215,0,0.4);padding:12px 24px;border-radius:4px;text-align:center;}
#challenge-title{font-size:9px;color:#ffd700;letter-spacing:4px;margin-bottom:4px;}
#challenge-desc{font-size:14px;color:#fff;font-weight:700;letter-spacing:2px;}
#challenge-pts{font-size:11px;color:#ffd700;margin-top:4px;}

/* ─── RELOAD BAR ─── */
#reload-wrap{position:fixed;bottom:25%;left:50%;transform:translateX(-50%);z-index:10;pointer-events:none;display:none;text-align:center;}
#reload-label{font-size:9px;color:rgba(255,255,255,0.5);letter-spacing:4px;margin-bottom:4px;}
#reload-bar-bg{width:200px;height:3px;background:rgba(255,255,255,0.1);border-radius:2px;overflow:hidden;}
#reload-bar-fill{height:100%;width:0%;background:#ff4444;transition:width linear;border-radius:2px;}

/* ─── BREATH BAR ─── */
#breath-wrap{position:fixed;bottom:22%;left:50%;transform:translateX(-50%);z-index:10;pointer-events:none;display:none;text-align:center;}
#breath-label{font-size:9px;color:rgba(0,255,255,0.5);letter-spacing:4px;margin-bottom:4px;}
#breath-bar-bg{width:200px;height:3px;background:rgba(0,255,255,0.1);border-radius:2px;overflow:hidden;}
#breath-bar-fill{height:100%;width:100%;background:#00ffff;transition:width 0.1s linear;border-radius:2px;}

/* ─── GRENADE INDICATOR ─── */
#grenade-ui{position:fixed;bottom:120px;right:16px;z-index:10;display:flex;flex-direction:column;gap:6px;align-items:flex-end;}
.gren-slot{display:flex;align-items:center;gap:8px;font-size:10px;color:rgba(255,255,255,0.6);}
.gren-icon{width:24px;height:24px;border-radius:3px;border:1px solid rgba(255,255,255,0.2);display:flex;align-items:center;justify-content:center;font-size:14px;}
.gren-slot.active .gren-icon{border-color:rgba(0,255,136,0.6);background:rgba(0,255,136,0.08);}
.gren-count{font-weight:700;color:#fff;}

/* ─── TACTICAL ABILITIES ─── */
#tacticals{position:fixed;bottom:16px;left:50%;transform:translateX(-50%);z-index:10;display:flex;gap:8px;}
.tac{width:52px;height:52px;border:1px solid rgba(255,255,255,0.2);border-radius:4px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:2px;font-size:20px;cursor:pointer;transition:all 0.2s;position:relative;background:rgba(4,8,12,0.85);}
.tac:hover{border-color:rgba(0,255,136,0.4);}
.tac-label{font-size:7px;letter-spacing:1px;color:rgba(255,255,255,0.5);}
.tac-key{position:absolute;top:2px;left:4px;font-size:8px;color:rgba(255,255,255,0.4);}
.tac-cd{position:absolute;inset:0;background:rgba(0,0,0,0.7);display:none;align-items:center;justify-content:center;font-size:12px;font-weight:900;color:#fff;border-radius:4px;}
.tac-cd-bar{position:absolute;bottom:0;left:0;height:2px;background:#00ff88;border-radius:0 0 0 4px;}

/* ─── COMPASS ─── */
#compass-wrap{position:fixed;top:16px;left:50%;transform:translateX(-50%);z-index:10;width:320px;height:28px;overflow:hidden;mask-image:linear-gradient(to right,transparent,#000 15%,#000 85%,transparent);-webkit-mask-image:linear-gradient(to right,transparent,#000 15%,#000 85%,transparent);}
#compass-bg{position:absolute;inset:0;background:rgba(4,8,12,0.8);border:1px solid rgba(0,255,136,0.12);}
#compass-ribbon{position:absolute;top:0;height:100%;display:flex;align-items:center;white-space:nowrap;}
.c-tick{width:20px;text-align:center;font-size:8px;color:rgba(255,255,255,0.35);display:inline-flex;flex-direction:column;align-items:center;justify-content:center;height:28px;border-right:1px solid rgba(255,255,255,0.06);}
.c-card{color:#00ff88!important;font-size:11px!important;font-weight:900;border-right-color:rgba(0,255,136,0.3)!important;}
#compass-center{position:absolute;top:0;bottom:0;left:50%;width:1px;background:rgba(0,255,136,0.5);pointer-events:none;}
#compass-center::after{content:'▼';position:absolute;top:-2px;left:50%;transform:translateX(-50%);color:#00ff88;font-size:6px;}

/* ─── NIGHT VISION ─── */
#nv-label{position:fixed;top:50px;left:50%;transform:translateX(-50%);z-index:20;font-size:10px;letter-spacing:6px;color:#00ff44;display:none;text-shadow:0 0 10px #00ff44;}

/* ─── DAMAGE NUMBERS ─── */
#dmg-container{position:fixed;inset:0;pointer-events:none;z-index:8;overflow:hidden;}

/* ─── HITMARKER ─── */
#hitmarker{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);pointer-events:none;z-index:11;opacity:0;transition:opacity 0.05s;}
.hm-line{position:absolute;background:#fff;top:50%;left:50%;}
#hm-tl{width:8px;height:2px;transform:translate(-14px,-1px) rotate(45deg);}
#hm-tr{width:8px;height:2px;transform:translate(6px,-1px) rotate(-45deg);}
#hm-bl{width:8px;height:2px;transform:translate(-14px,-1px) rotate(-45deg);}
#hm-br{width:8px;height:2px;transform:translate(6px,-1px) rotate(45deg);}

/* ─── HEALTH BAR ─── */
#health-wrap{position:fixed;bottom:80px;left:16px;z-index:10;width:200px;}
#health-label{font-size:8px;color:rgba(255,255,255,0.4);letter-spacing:3px;margin-bottom:4px;}
#health-bar-bg{height:6px;background:rgba(255,255,255,0.06);border-radius:3px;overflow:hidden;position:relative;}
#health-bar-fill{height:100%;width:100%;background:linear-gradient(90deg,#ff3333,#ff6600,#00ff88);transition:width 0.3s ease;border-radius:3px;}
#health-num{position:absolute;right:0;top:-16px;font-size:10px;color:#fff;font-weight:700;}

/* ─── ARMOR BAR ─── */
#armor-wrap{position:fixed;bottom:60px;left:16px;z-index:10;width:200px;}
#armor-label{font-size:8px;color:rgba(0,200,255,0.5);letter-spacing:3px;margin-bottom:4px;}
#armor-bar-bg{height:4px;background:rgba(255,255,255,0.06);border-radius:2px;overflow:hidden;}
#armor-bar-fill{height:100%;width:100%;background:linear-gradient(90deg,#0088ff,#00ccff);transition:width 0.3s ease;border-radius:2px;}

/* ─── STANCE ─── */
#stance-wrap{position:fixed;bottom:60px;left:230px;z-index:10;display:flex;flex-direction:column;gap:3px;}
.stance-btn{width:32px;height:22px;border:1px solid rgba(255,255,255,0.12);border-radius:2px;display:flex;align-items:center;justify-content:center;font-size:8px;font-weight:700;color:rgba(255,255,255,0.3);letter-spacing:1px;}
.stance-btn.on{border-color:rgba(0,255,136,0.5);color:#00ff88;background:rgba(0,255,136,0.08);}

/* ─── LEAN INDICATOR ─── */
#lean-indicator{position:fixed;bottom:70px;left:280px;z-index:10;font-size:16px;color:rgba(0,255,136,0.6);display:none;}

/* ─── START SCREEN ─── */
#start{position:fixed;inset:0;background:radial-gradient(ellipse at 30% 50%,#050a06,#000);display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:100;transition:opacity 0.8s;}
#start-title{font-size:52px;font-weight:900;letter-spacing:12px;color:#fff;text-align:center;line-height:1;margin-bottom:6px;}
#start-sub{font-size:11px;letter-spacing:8px;color:#00ff88;text-align:center;margin-bottom:60px;text-shadow:0 0 20px rgba(0,255,136,0.8);}
#start-btn{background:transparent;border:1px solid rgba(0,255,136,0.5);color:#00ff88;font-family:'Courier New',monospace;font-size:13px;font-weight:700;letter-spacing:6px;padding:14px 48px;cursor:pointer;transition:all 0.3s;border-radius:2px;}
#start-btn:hover{background:rgba(0,255,136,0.08);box-shadow:0 0 30px rgba(0,255,136,0.3),inset 0 0 20px rgba(0,255,136,0.05);}
.start-specs{display:flex;gap:40px;margin-top:50px;color:rgba(255,255,255,0.2);font-size:9px;letter-spacing:3px;}
.start-spec span{color:rgba(0,255,136,0.5);}

/* ─── EXPLOSION FLASH ─── */
#expl-flash{position:fixed;inset:0;pointer-events:none;z-index:6;background:#ff8800;opacity:0;transition:opacity 0.05s;}

/* ─── SMOKE GRENADES ─── */
.smoke-hud{position:fixed;pointer-events:none;z-index:6;border-radius:50%;background:radial-gradient(circle,rgba(180,180,180,0.7),rgba(150,150,150,0.3));backdrop-filter:blur(8px);}

/* ─── ATTACHMENTS UI ─── */
#attach-ui{position:fixed;bottom:180px;right:16px;z-index:10;display:flex;flex-direction:column;gap:3px;align-items:flex-end;}
.attach-badge{background:rgba(4,8,12,0.85);border:1px solid rgba(0,255,136,0.12);padding:3px 8px;border-radius:2px;font-size:8px;color:rgba(0,255,136,0.6);letter-spacing:2px;}

/* ─── WIND INDICATOR ─── */
#wind-ui{position:fixed;top:55px;left:50%;transform:translateX(-50%);z-index:10;font-size:8px;letter-spacing:3px;color:rgba(0,255,136,0.4);}

/* ─── ROUND TIMER ─── */
#round-info{position:fixed;top:16px;right:16px;z-index:10;text-align:right;}
#round-timer{font-size:22px;font-weight:900;color:#fff;letter-spacing:2px;}
#round-label{font-size:8px;color:rgba(255,255,255,0.3);letter-spacing:3px;margin-top:2px;}

/* ─── FLASH ─── */
@keyframes flashPop{0%{opacity:0.6;}100%{opacity:0;}}
</style>
</head>
<body oncontextmenu="return false;">

<canvas id="c"></canvas>

<!-- Visual overlays -->
<div id="vignette"></div>
<div id="blood-overlay"></div>
<div id="night-vision-overlay"></div>
<div id="concuss-overlay"></div>
<div id="hit-dir-overlay"></div>
<div id="expl-flash"></div>

<!-- Scope -->
<div id="scope">
  <div id="scope-h"></div>
  <div id="scope-v"></div>
  <div class="scope-tick-h" id="scope-mil1"></div>
  <div class="scope-tick-h" id="scope-mil2"></div>
  <div class="scope-tick-h" id="scope-mil3"></div>
  <div class="scope-tick-h" id="scope-mil4"></div>
  <div class="scope-tick-v" id="scope-mil5"></div>
  <div class="scope-tick-v" id="scope-mil6"></div>
  <div id="scope-dot"></div>
  <div id="scope-range">450m</div>
</div>

<!-- Crosshair -->
<div id="xhair-wrap">
  <div class="xl" id="xl-t"></div>
  <div class="xl" id="xl-b"></div>
  <div class="xl" id="xl-l"></div>
  <div class="xl" id="xl-r"></div>
  <div id="xl-dot"></div>
  <div id="xhair-circle"></div>
</div>

<!-- Hitmarker -->
<div id="hitmarker">
  <div class="hm-line" id="hm-tl"></div>
  <div class="hm-line" id="hm-tr"></div>
  <div class="hm-line" id="hm-bl"></div>
  <div class="hm-line" id="hm-br"></div>
</div>

<!-- Night vision label -->
<div id="nv-label">◉ NIGHT VISION ACTIVE</div>

<!-- Compass -->
<div id="compass-wrap">
  <div id="compass-bg"></div>
  <div id="compass-ribbon"></div>
  <div id="compass-center"></div>
</div>
<div id="wind-ui">WIND — ██░░░░ NE 14kn</div>

<!-- Round info -->
<div id="round-info" class="panel" style="padding:10px 14px;border-radius:4px;">
  <div id="round-timer">20:00</div>
  <div id="round-label">MISSION TIME</div>
</div>

<!-- Top left HUD -->
<div id="hud-tl" class="panel">
  <h1>■ BLACK SITE OPS</h1>
  <div class="stat-row"><div class="stat-label">SCORE</div><div class="stat-val green" id="score-ui">0</div></div>
  <div class="stat-row"><div class="stat-label">KILLS</div><div class="stat-val yellow" id="kills-ui">0</div></div>
  <div class="stat-row"><div class="stat-label">STREAK</div><div class="stat-val red" id="streak-ui">0</div></div>
  <div class="stat-row"><div class="stat-label">MODE</div><div class="stat-val cyan" id="mode-ui">ELIMINATION</div></div>
  <div class="divider"></div>
  <div class="stat-row"><div class="stat-label">WEATHER</div><div class="stat-val" id="weather-ui">CLEAR</div></div>
  <div class="stat-row"><div class="stat-label">TIME</div><div class="stat-val" id="time-ui">12:00</div></div>
  <div class="divider"></div>
  <div class="stat-row"><div class="stat-label">FPS</div><div class="stat-val" id="fps-ui">60</div></div>
</div>

<!-- Minimap -->
<div id="minimap" class="panel">
  <canvas id="minimap-canvas" width="160" height="160"></canvas>
  <div id="minimap-frame"></div>
  <div id="minimap-label">TACTICAL MAP</div>
</div>

<!-- Kill feed -->
<div id="killfeed"></div>

<!-- Health/Armor -->
<div id="health-wrap">
  <div id="health-label">HEALTH</div>
  <div id="health-bar-bg">
    <div id="health-bar-fill"></div>
    <div id="health-num">100</div>
  </div>
</div>
<div id="armor-wrap">
  <div id="armor-label">ARMOR</div>
  <div id="armor-bar-bg"><div id="armor-bar-fill"></div></div>
</div>

<!-- Stance -->
<div id="stance-wrap">
  <div class="stance-btn on" id="s-stand">STD</div>
  <div class="stance-btn" id="s-crouch">CRH</div>
</div>

<!-- Lean -->
<div id="lean-indicator" id="lean-ui">◄</div>

<!-- Weapon HUD -->
