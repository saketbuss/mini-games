// DAY/NIGHT & WEATHER
// ═══════════════════════════════════════════════════════════
let timeOfDay=12;const timeSpeed=0.3;
let weatherMode='clear';let weatherTimer=30;

const SKY_COLORS={clear:new THREE.Color(0x87ceeb),night:new THREE.Color(0x040814),dusk:new THREE.Color(0xff6633),rain:new THREE.Color(0x445566)};

function updateDayNight(delta){
  timeOfDay+=delta*timeSpeed;if(timeOfDay>=24)timeOfDay-=24;
  
  const angle=(timeOfDay/24)*Math.PI*2-Math.PI/2;
  sun.position.set(Math.cos(angle)*200,Math.sin(angle)*200,-60);
  
  let skyTarget,fogTarget,lightInt,ambInt;
  if(timeOfDay>=6&&timeOfDay<=18){
    skyTarget=SKY_COLORS.clear;lightInt=1.5;ambInt=0.3;
    document.getElementById('time-ui').textContent=Math.floor(timeOfDay)+':'+String(Math.floor((timeOfDay%1)*60)).padStart(2,'0');
    document.getElementById('weather-ui').textContent='DAY';
  }else if(timeOfDay>18&&timeOfDay<21){
    skyTarget=SKY_COLORS.dusk;lightInt=0.6;ambInt=0.2;
    document.getElementById('weather-ui').textContent='DUSK';
  }else{
    skyTarget=SKY_COLORS.night;lightInt=0.05;ambInt=0.05;
    stars.material.opacity=0.8;
    document.getElementById('weather-ui').textContent='NIGHT OPS';
  }
  
  if(weatherMode==='rain')skyTarget=SKY_COLORS.rain;
  
  if(!scene.background)scene.background=new THREE.Color();
  scene.background.lerp(skyTarget,0.005);
  scene.fog.color.lerp(skyTarget,0.005);
  sun.intensity+=(lightInt-sun.intensity)*0.01;
  ambient.intensity+=(ambInt-ambient.intensity)*0.01;
  stars.material.opacity+=(timeOfDay>=21||timeOfDay<=5?0.8:0)-stars.material.opacity)*0.01;
  
  // Weather update
  weatherTimer-=delta;
  if(weatherTimer<=0){
    weatherMode=Math.random()>0.4?'clear':'rain';
    weatherTimer=20+Math.random()*40;
    document.getElementById('weather-ui').textContent=weatherMode==='rain'?'STORM':'CLEAR';
  }
  
  // Rain
  const raining=weatherMode==='rain';
  rainSys.material.opacity+=((raining?0.55:0)-rainSys.material.opacity)*0.02;
  if(raining){
    const rArr=rainGeo.attributes.position.array;
    for(let i=0;i<rainCount;i++){
      rArr[i*3+1]-=3.5+Math.random()*2;
      rArr[i*3]+=windSpeed*Math.cos(windAngle)*0.5;
      rArr[i*3+2]+=windSpeed*Math.sin(windAngle)*0.5;
      if(rArr[i*3+1]<0){rArr[i*3+1]=180;rArr[i*3]=(Math.random()-0.5)*400;rArr[i*3+2]=(Math.random()-0.5)*400;}
    }
    rainGeo.attributes.position.needsUpdate=true;
    
    // Lightning
    lightningTimer-=delta;
    if(lightningTimer<=0){
      lightningTimer=5+Math.random()*15;
      lightningFlash=true;lightningLight.intensity=8;
      setTimeout(()=>{lightningLight.intensity=0;lightningFlash=false;},100+Math.random()*80);
    }
  }
}

// ═══════════════════════════════════════════════════════════
// PROJECTILE UPDATE
// ═══════════════════════════════════════════════════════════
function updateProjectiles(delta){
  for(let i=projectiles.length-1;i>=0;i--){
    const p=projectiles[i];p.age+=delta;
    p.vel.y-=p.drop*delta;
    
    const nextPos=p.mesh.position.clone().add(p.vel.clone().multiplyScalar(delta));
    const toNext=nextPos.clone().sub(p.mesh.position);
    const dist=toNext.length();toNext.normalize();
    
    raycaster.set(p.mesh.position,toNext);raycaster.far=dist+0.5;
    
    // Collect hittables
    const hittables=[...envMeshes];
    bots.forEach(b=>{if(b.visible&&b.userData.hp>0)b.children.forEach(c=>hittables.push(c));});
    drones.forEach(d=>{if(d.visible&&d.userData.hp>0)d.children.forEach(c=>hittables.push(c));});
    
    const hits=raycaster.intersectObjects(hittables);
    if(hits.length&&hits[0].distance<=dist+0.1){
      handleBulletHit(hits[0],p.dmg);
      scene.remove(p.mesh);projectiles.splice(i,1);
      continue;
    }
    
    p.mesh.position.copy(nextPos);
    p.mesh.quaternion.setFromUnitVectors(new THREE.Vector3(0,0,1),p.vel.clone().normalize());
    
    if(p.age>=p.maxAge){scene.remove(p.mesh);projectiles.splice(i,1);}
  }
}

function handleBulletHit(hit,dmg){
  const obj=hit.object;const par=obj.parent;const point=hit.point;const normal=hit.face.normal.clone().applyQuaternion(obj.getWorldQuaternion(new THREE.Quaternion()));
  
  // Check bot
  if(bots.includes(par)){
    const isHead=obj.geometry===botHeadGeo||obj.geometry===botEyeGeo;
    damageBot(par,dmg,isHead,point,normal);return;
  }
  // Check drone
  if(drones.includes(par)){
    par.userData.hp-=dmg*1.5;showHitmarker(false);showDmgNumber(dmg*1.5,point,true);
    par.userData.mat.emissive.setHex(0xffffff);par.userData.mat.emissiveIntensity=1;
    setTimeout(()=>{par.userData.mat.emissive.setHex(0x003322);par.userData.mat.emissiveIntensity=0.2;},60);
    spawnParticles(point,0x00ffcc,5,true);
    if(par.userData.hp<=0){
      createExplosion(par.position,4,30);par.visible=false;
      player.kills++;player.score+=250;player.streak++;
      updateScoreUI();addKillFeedEntry('DRONE','headshot');checkKillstreak();
      setTimeout(()=>respawnDrone(par),5000);
    }
    return;
  }
  // Check explodable barrel
  const brlObj=explodableBarrels.find(b=>b.mesh===obj);
  if(brlObj&&!brlObj.exploded){
    brlObj.health-=dmg;
    if(brlObj.health<=0){
      brlObj.exploded=true;
      const color=brlObj.color===0xff3300?0xff4400:0x2288ff;
      createExplosion(brlObj.mesh.position,brlObj.color===0xff3300?10:6,brlObj.color===0xff3300?120:40);
      scene.remove(brlObj.mesh);
    }
    return;
  }
  // Check glass
  const glassObj=glassWindows.find(g=>g.mesh===obj);
  if(glassObj&&!glassObj.broken){
    glassObj.broken=true;playShatter();
    spawnParticles(point,0x88aacc,8,true);
    glassObj.mesh.visible=false;
    return;
  }
  // Hit environment
  spawnParticles(point,0x888888,3);
  spawnBulletDecal(point,normal);
}

// ═══════════════════════════════════════════════════════════
// GRENADE UPDATE
// ═══════════════════════════════════════════════════════════
function updateGrenades(delta){
  for(let i=grenadesInWorld.length-1;i>=0;i--){
    const g=grenadesInWorld[i];g.age+=delta;
    g.vel.y-=25*delta;
    g.vel.x*=0.98;g.vel.z*=0.98;
    g.mesh.position.add(g.vel.clone().multiplyScalar(delta));
    g.mesh.rotation.x+=delta*5;g.mesh.rotation.z+=delta*4;
    
    if(g.mesh.position.y<0.14){
      g.mesh.position.y=0.14;
      if(!g.bounced){g.bounced=true;g.vel.y*=-0.4;g.vel.x*=0.6;g.vel.z*=0.6;playShell();}
      else{g.vel.set(0,0,0);}
    }
    
    if(g.age>=g.fuzeTime){
      if(g.type==='frag'){
        createExplosion(g.mesh.position,8,80);
      }else if(g.type==='flash'){
        // Flash effect - concuss player if nearby
        const d=g.mesh.position.distanceTo(yaw.position);
        if(d<15){
          const cc=document.getElementById('concuss-overlay');
          cc.style.transition='opacity 0s';cc.style.opacity='1';
          setTimeout(()=>{cc.style.transition='opacity 3s';cc.style.opacity='0';},100);
        }
        // Blind bots nearby
        bots.forEach(b=>{if(b.position.distanceTo(g.mesh.position)<12)b.userData.stateTimer=-3;});
        // White flash particle
        spawnParticles(g.mesh.position,0xffffff,12);
      }else if(g.type==='smoke'){
        // Create smoke cloud
        const sm=new THREE.Mesh(new THREE.SphereGeometry(0.3,8,8),new THREE.MeshBasicMaterial({color:0xaaaaaa,transparent:true,opacity:0.0}));
        sm.position.copy(g.mesh.position);sm.position.y+=0.5;scene.add(sm);
        smokeClouds.push({mesh:sm,age:0,maxAge:15,maxScale:6});
      }
      scene.remove(g.mesh);grenadesInWorld.splice(i,1);
    }
  }
}

function updateSmokeClouds(delta){
  for(let i=smokeClouds.length-1;i>=0;i--){
    const s=smokeClouds[i];s.age+=delta;
    const pct=s.age/s.maxAge;
    const scl=pct<0.2?pct*5*s.maxScale:s.maxScale;
    s.mesh.scale.setScalar(scl);
    s.mesh.material.opacity=pct<0.1?pct*10*0.65:(pct>0.8?(1-pct)*5*0.65:0.65);
    s.mesh.rotation.y+=delta*0.1;
    if(s.age>=s.maxAge){scene.remove(s.mesh);smokeClouds.splice(i,1);}
  }
}

// ═══════════════════════════════════════════════════════════
// BOT AI UPDATE
// ═══════════════════════════════════════════════════════════
function updateBots(delta,time){
  bots.forEach(b=>{
    if(!b.visible||b.userData.hp<=0)return;
    b.userData.velY-=30*delta;b.position.y+=b.userData.velY*delta;
    if(b.position.y<0){b.position.y=0;b.userData.velY=0;}
    b.userData.stateTimer+=delta;
    
    const playerPos=yaw.position;
    const toBotDist=b.position.distanceTo(playerPos);
    
    // Alert system
    if(toBotDist<60){b.userData.alertLevel=Math.min(1,b.userData.alertLevel+delta*0.3);}
    else{b.userData.alertLevel=Math.max(0,b.userData.alertLevel-delta*0.1);}
    
    // Face player
    if(b.userData.alertLevel>0.5&&toBotDist<80){
      const angle=Math.atan2(playerPos.x-b.position.x,playerPos.z-b.position.z);
      b.rotation.y+=((angle+Math.PI)-b.rotation.y)*5*delta;
    }
    
    // State machine
    if(b.userData.state==='patrol'){
      b.position.x+=b.userData.moveSpeed*delta;
      if(Math.abs(b.position.x-b.userData.startX)>20)b.userData.moveSpeed*=-1;
      
      // Transition to alert
      if(b.userData.alertLevel>0.6)b.userData.state='alert';
      
      // Occasional jump
      if(Math.random()<0.003&&b.userData.velY===0)b.userData.velY=10;
      
    }else if(b.userData.state==='alert'){
      // Move toward cover or player
      if(toBotDist>30){
        // Close in
        const dir=new THREE.Vector3(playerPos.x-b.position.x,0,playerPos.z-b.position.z).normalize();
        const speed=(b.userData.isElite?7:5)*(b.userData.isSniper?0.5:1);
        b.position.add(dir.multiplyScalar(speed*delta));
      }else if(toBotDist<8){
        // Retreat
        const dir=new THREE.Vector3(playerPos.x-b.position.x,0,playerPos.z-b.position.z).normalize().negate();
        b.position.add(dir.multiplyScalar(6*delta));
      }
      
      // Shoot at player
      const now=Date.now();
      const shotCooldown=b.userData.isElite?800:(b.userData.isSniper?2500:1200);
      if(now-b.userData.lastShotTime>shotCooldown&&toBotDist<70&&player.isAlive){
        b.userData.lastShotTime=now;
        // Bot shoots
        const hitChance=b.userData.isElite?0.35:(b.userData.isSniper?0.4:0.2);
        if(Math.random()<hitChance*(1-Math.min(1,toBotDist/60))){
          damagePlayer(b.userData.isElite?22:(b.userData.isSniper?45:12),b.position);
        }
        // Bot gunshot sound (faint, positioned)
        const pan=Math.max(-1,Math.min(1,(b.position.x-yaw.position.x)/30));
        makeNoise(0.15,2000,0.08,'noise',pan);
      }
      
      // Evade/strafe
      b.userData.dodgeTimer+=delta;
      if(b.userData.dodgeTimer>0.8){
        b.userData.dodgeTimer=0;
        const perp=new THREE.Vector3(-(playerPos.z-b.position.z),0,playerPos.x-b.position.x).normalize();
        const dir=Math.random()>0.5?perp:perp.negate();
        b.position.add(dir.multiplyScalar(3));
        if(Math.random()<0.25&&b.userData.velY===0)b.userData.velY=9;
      }
      
      if(b.userData.alertLevel<0.3)b.userData.state='patrol';
      
    }else if(b.userData.state==='evade'){
      b.userData.stateTimer+=delta;
      if(b.userData.stateTimer>0.4){
        b.userData.stateTimer=0;
        b.userData.moveDir.set((Math.random()-0.5)*2,0,(Math.random()-0.5)*2).normalize();
        if(Math.random()<0.3&&b.userData.velY===0)b.userData.velY=11;
      }
      const spd=b.userData.isElite?16:10;
      b.position.add(b.userData.moveDir.clone().multiplyScalar(spd*delta));
      b.position.x=Math.max(-150,Math.min(150,b.position.x));
      b.position.z=Math.max(-150,Math.min(150,b.position.z));
      
      if(Math.random()<0.01)b.userData.state='alert';
    }
  });
}

// ═══════════════════════════════════════════════════════════
// DRONE UPDATE
// ═══════════════════════════════════════════════════════════
function updateDrones(delta,time){
  drones.forEach(d=>{
    if(!d.visible||d.userData.hp<=0)return;
    const t=time*0.001+d.userData.timeOffset;
    // Patrol flight
    d.position.x+=(Math.cos(t*0.7)*8)*delta;
    d.position.z+=(Math.sin(t*0.5)*6)*delta;
    d.position.y=d.userData.baseY+Math.sin(t*2.3)*3;
    d.rotation.y+=delta*2;d.children[1].rotation.y+=delta*15;d.children[2].rotation.y-=delta*15;
    
    // Shoot at player occasionally
    const distToPlayer=d.position.distanceTo(yaw.position);
    if(distToPlayer<50&&player.isAlive){
      const now=Date.now();
      if(now-d.userData.lastShot>3500){
        d.userData.lastShot=now;
        if(Math.random()<0.25){
          damagePlayer(18,d.position);
          const pan=Math.max(-1,Math.min(1,(d.position.x-yaw.position.x)/30));
          makeNoise(0.1,3000,0.1,'noise',pan);
        }
      }
    }
  });
}

// ═══════════════════════════════════════════════════════════
// PLAYER MOVEMENT
// ═══════════════════════════════════════════════════════════
function updatePlayer(delta){
  if(!player.isAlive)return;
  
  // Crouch
  player.isCrouching=keys['KeyC'];
  const targetH=player.isCrouching?player.crouchHeight:player.height;
  player.curHeight+=(targetH-player.curHeight)*10*delta;
  yaw.position.y=player.curHeight;
  
  // Stance UI
  document.getElementById('s-stand').className='stance-btn'+(player.isCrouching?'':' on');
  document.getElementById('s-crouch').className='stance-btn'+(player.isCrouching?' on':'');
  
  // Lean
  const leanTarget=keys['KeyQ']?0.28:(keys['KeyE']?-0.28:0);
  player.leanAngle+=(leanTarget-player.leanAngle)*10*delta;
  roll.rotation.z=player.leanAngle;roll.position.x=-player.leanAngle*1.8;
  
  const leanUi=document.getElementById('lean-indicator');
  if(Math.abs(player.leanAngle)>0.05){leanUi.style.display='block';leanUi.textContent=player.leanAngle>0?'◄':'►';}
  else leanUi.style.display='none';
  
  // Movement
  const fwd=keys['KeyW'],bwd=keys['KeyS'],lt=keys['KeyA'],rt=keys['KeyD'];
  player.isSprinting=keys['ShiftLeft']&&fwd&&!player.isADS&&!player.isCrouching;
  
  let spd=player.speed;
  if(player.isSprinting)spd*=1.85;
  if(player.isCrouching)spd*=0.45;
  if(player.isADS)spd*=0.42;
  
  // Damping
  player.vel.x*=1-12*delta;player.vel.z*=1-12*delta;
  
  const dir=new THREE.Vector3(Number(rt)-Number(lt),0,Number(fwd)-Number(bwd));
  if(dir.length()>0){
    dir.normalize().applyEuler(new THREE.Euler(0,yaw.rotation.y,0));
    player.vel.x+=dir.x*spd*delta;
    player.vel.z+=dir.z*spd*delta;
  }
  
  yaw.position.x+=player.vel.x;yaw.position.z+=player.vel.z;
  yaw.position.x=Math.max(-150,Math.min(150,yaw.position.x));
  yaw.position.z=Math.max(-150,Math.min(150,yaw.position.z));
  
  // Gravity & platforms
  player.vel.y-=35*delta;
  let groundLevel=0;
  // Platform detection (simplified bounding)
  const px=yaw.position.x,pz=yaw.position.z;
  if(Math.abs(px-(-40))<10&&pz<-70&&pz>-90)groundLevel=5;
  if(Math.abs(px-40)<10&&pz<-70&&pz>-90)groundLevel=5;
  if(Math.abs(px)<12&&pz<-85&&pz>-98)groundLevel=8;
  
  yaw.position.y+=player.vel.y*delta;
  if(yaw.position.y<groundLevel+player.curHeight){
    if(player.vel.y<-12){playStep(2);doShakeScreen(0.08);}
    player.vel.y=0;yaw.position.y=groundLevel+player.curHeight;player.isGrounded=true;
  }else{player.isGrounded=false;}
  
  // Jump
  if((keys['Space'])&&player.isGrounded&&!player.isADS&&!player.isCrouching){
    player.vel.y=12;player.isGrounded=false;playStep(0.5);
  }
  
  // Head bob
  const velMag=Math.sqrt(player.vel.x**2+player.vel.z**2);
  if(player.isGrounded&&velMag>1){
    const bobSpd=player.isSprinting?18:(player.isCrouching?7:12);
    player.bobTimer+=delta*bobSpd;
    const bobAmt=player.isADS?0.008:(player.isCrouching?0.03:0.05);
    pitch.position.y=Math.sin(player.bobTimer)*bobAmt;
    if(!player.isADS)wepGroup.position.y+=Math.abs(Math.sin(player.bobTimer))*0.008;
    if(Math.sin(player.bobTimer)<-0.9&&Math.sin(player.bobTimer-delta*bobSpd)>=-0.9)playStep(player.isSprinting?0.6:0.3);
  }else{player.bobTimer=0;pitch.position.y+=(0-pitch.position.y)*10*delta;}
  
  // ADS zoom
  player.targetFov=player.isADS?WEAPONS[curWep].zFov:75;
  player.fov+=(player.targetFov-player.fov)*15*delta;
  camera.fov=player.fov;camera.updateProjectionMatrix();
}

// ═══════════════════════════════════════════════════════════
// CROSSHAIR & HUD UPDATE
// ═══════════════════════════════════════════════════════════
function updateCrosshair(delta){
  const w=WEAPONS[curWep];const velMag=Math.sqrt(player.vel.x**2+player.vel.z**2);
  if(!player.isADS&&w.type!=='sniper'&&w.type!=='melee'){
    const sprd=velMag>2?18:(player.isCrouching?3:8);
    const s=sprd+'px';
    document.getElementById('xl-t').style.transform=`translate(-50%,-${20+sprd}px)`;
    document.getElementById('xl-b').style.transform=`translate(-50%,${10+sprd}px)`;
    document.getElementById('xl-l').style.transform=`translate(-${20+sprd}px,-50%)`;
    document.getElementById('xl-r').style.transform=`translate(${10+sprd}px,-50%)`;
  }
  
  // Sniper breath
  if(player.isADS&&w.type==='sniper'){
    document.getElementById('breath-wrap').style.display='block';
    const holdBreath=keys['ShiftLeft'];
    if(holdBreath&&player.breath>0){
      player.breath=Math.max(0,player.breath-delta*25);
      pitch.rotation.x+=Math.sin(Date.now()*0.001*0.5)*w.sway*0.05*delta;
    }else{
      player.breath=Math.min(100,player.breath+delta*18);
      const swayMag=player.breath<20?w.sway*3:w.sway;
      yaw.rotation.y+=Math.sin(Date.now()*0.001*1.5)*swayMag*delta;
      pitch.rotation.x+=Math.cos(Date.now()*0.001*2.1)*swayMag*delta;
    }
    document.getElementById('breath-bar-fill').style.width=player.breath+'%';
    document.getElementById('breath-bar-fill').style.background=player.breath<30?'#ff3333':'#00ffff';
  }
}

// ═══════════════════════════════════════════════════════════
// WEAPON ANIMATION
// ═══════════════════════════════════════════════════════════
function updateWeaponAnim(delta){
  // Target position
  let tp;
  if(reloading)tp=wepPos.reload;
  else if(player.isADS)tp=wepPos.ads;
  else if(player.isSprinting&&Math.sqrt(player.vel.x**2+player.vel.z**2)>5)tp=wepPos.sprint;
  else tp=wepPos.def;
  
  wepGroup.position.x+=(tp.x-wepGroup.position.x)*15*delta;
  wepGroup.position.y+=(tp.y-wepGroup.position.y)*15*delta;
  
  // Recoil z kick
  wepAnim.z+=(0-wepAnim.z)*15*delta;wepAnim.rotX+=(0-wepAnim.rotX)*15*delta;
  const tgtRotZ=player.isSprinting?(-Math.PI/5):(reloading?0.4:0);
  wepAnim.rotZ+=(tgtRotZ-wepAnim.rotZ)*15*delta;
  
  // Sway
  wepAnim.swayX+=(wepAnim.tSwayX-wepAnim.swayX)*10*delta;wepAnim.swayY+=(wepAnim.tSwayY-wepAnim.swayY)*10*delta;
  wepAnim.tSwayX+=(0-wepAnim.tSwayX)*5*delta;wepAnim.tSwayY+=(0-wepAnim.tSwayY)*5*delta;
  
  wepGroup.position.z=tp.z+wepAnim.z;
  wepGroup.rotation.x=wepAnim.rotX+wepAnim.swayX;
  wepGroup.rotation.y=wepAnim.swayY;
  wepGroup.rotation.z=wepAnim.rotZ;
  
  // Reload sway
  if(reloading){
    const t=Date.now()*0.003;
    wepGroup.rotation.x+=Math.sin(t)*0.04;wepGroup.rotation.z+=Math.cos(t*0.7)*0.02;
  }
}

// ═══════════════════════════════════════════════════════════
// RECOIL & SHAKE
// ═══════════════════════════════════════════════════════════
function updateRecoil(delta){
  recoilState.curX+=(recoilState.tgtX-recoilState.curX)*15*delta;
  recoilState.curY+=(recoilState.tgtY-recoilState.curY)*15*delta;
  recoilState.tgtX=Math.max(0,recoilState.tgtX-delta*2.5);
  recoilState.tgtY*=(1-delta*8);
  
  if(shake.i>0){
    shake.x=(Math.random()-0.5)*shake.i;shake.y=(Math.random()-0.5)*shake.i;
    shake.i-=delta*2;if(shake.i<0)shake.i=0;
  }else{shake.x=0;shake.y=0;}
}

// ═══════════════════════════════════════════════════════════
// PARTICLES & SHELLS
// ═══════════════════════════════════════════════════════════
function updateParticles(delta){
  for(let i=particles.length-1;i>=0;i--){
    const p=particles[i];p.age+=delta;
    if(p.gravity)p.vel.y-=25*delta;
    p.mesh.position.add(p.vel.clone().multiplyScalar(delta));
    p.mesh.rotation.x+=delta*8;p.mesh.rotation.y+=delta*6;
    p.mesh.material.opacity=Math.max(0,1-p.age/p.maxAge);
    if(!p.mesh.material.transparent){p.mesh.material.transparent=true;}
    if(p.age>=p.maxAge){scene.remove(p.mesh);p.mesh.geometry.dispose();particles.splice(i,1);}
  }
}

function updateShells(delta){
  for(let i=shellCasings.length-1;i>=0;i--){
    const s=shellCasings[i];s.age+=delta;
    s.vel.y-=30*delta;s.mesh.position.add(s.vel.clone().multiplyScalar(delta));
    s.mesh.rotation.x+=s.rotVel.x*delta;s.mesh.rotation.y+=s.rotVel.y*delta;
    if(s.mesh.position.y<0.03){
      s.mesh.position.y=0.03;
      if(!s.bounced){s.bounced=true;s.vel.y*=-0.35;s.vel.x*=0.5;s.vel.z*=0.5;s.rotVel.multiplyScalar(0.4);playShell();}
      else{s.vel.set(0,0,0);}
    }
    if(s.age>6){scene.remove(s.mesh);shellCasings.splice(i,1);}
  }
}

function updateDecals(delta){
  for(let i=decals.length-1;i>=0;i--){
    const d=decals[i];d.age+=delta;
    if(d.age>=d.maxAge){scene.remove(d.mesh);decals.splice(i,1);}
  }
}

// ═══════════════════════════════════════════════════════════
// COMPASS UPDATE
// ═══════════════════════════════════════════════════════════
function updateCompass(){
  const heading=-yaw.rotation.y*(180/Math.PI);
  const ribbon=document.getElementById('compass-ribbon');
  // Each tick is 20px wide, 360deg
  const offset=heading*(document.getElementById('compass-ribbon').scrollWidth/2/360);
  ribbon.style.transform=`translateX(calc(-50% + ${offset%((ribbon.scrollWidth/2))}px))`;
}

// ═══════════════════════════════════════════════════════════
// BUILD MODE GHOST UPDATE
// ═══════════════════════════════════════════════════════════
function updateBuild(){
  if(!buildMode){ghostWall.visible=false;return;}
  ghostWall.visible=true;updateGhost();
  if(firing){placeBuildPiece();firing=false;}
}

function placeBuildPiece(){
  const m=new THREE.Mesh(ghostWall.geometry.clone(),solidBMat.clone());
  m.position.copy(ghostWall.position);m.rotation.copy(ghostWall.rotation);
  m.castShadow=true;m.receiveShadow=true;scene.add(m);
  buildPieces.push({mesh:m,health:100});
  envMeshes.push(m);
}

// ═══════════════════════════════════════════════════════════
// START & LOCK
// ═══════════════════════════════════════════════════════════
document.getElementById('start-btn').addEventListener('click',()=>{
  initAudio();
  document.body.requestPointerLock();
});

document.addEventListener('pointerlockchange',()=>{
  isLocked=document.pointerLockElement===document.body;
  document.getElementById('start').style.opacity=isLocked?'0':'1';
  document.getElementById('start').style.pointerEvents=isLocked?'none':'auto';
  if(!isLocked){Object.keys(keys).forEach(k=>keys[k]=false);firing=false;releaseADS();}
});

window.addEventListener('resize',()=>{
  camera.aspect=innerWidth/innerHeight;camera.updateProjectionMatrix();
  renderer.setSize(innerWidth,innerHeight);
});

// ═══════════════════════════════════════════════════════════
// COMPASS INIT
// ═══════════════════════════════════════════════════════════
(()=>{
  const rib=document.getElementById('compass-ribbon');
  const cards=['N','NE','E','SE','S','SW','W','NW'];
  for(let rep=0;rep<3;rep++){
    for(let i=0;i<360;i+=5){
      const el=document.createElement('span');el.className='c-tick';
      if(i%45===0){el.classList.add('c-card');el.textContent=cards[i/45];}
      else if(i%15===0){el.textContent=i;}
      rib.appendChild(el);
    }
  }
})();

// ═══════════════════════════════════════════════════════════
// MAIN LOOP
// ═══════════════════════════════════════════════════════════
let prevTime=performance.now();let frames=0;let lastFpsTime=0;
scene.background=new THREE.Color(0x87ceeb);

function animate(){
  requestAnimationFrame(animate);
  const now=performance.now();const delta=Math.min((now-prevTime)/1000,0.05);prevTime=now;
  
  frames++;
  if(now-lastFpsTime>=1000){document.getElementById('fps-ui').textContent=frames;frames=0;lastFpsTime=now;}
  
  if(!isLocked)return renderer.render(scene,camera);
  
  updateDayNight(delta);
  updatePlayer(delta);
  updateCrosshair(delta);
  updateWeaponAnim(delta);
  updateRecoil(delta);
  updateBots(delta,now);
  updateDrones(delta,now);
  updateProjectiles(delta);
  updateGrenades(delta);
  updateSmokeClouds(delta);
  updateParticles(delta);
  updateShells(delta);
  updateDecals(delta);
  updateBuild();
  updateMinimap();
  updateCompass();
  updateRoundTimer(delta);
  
  // Firing logic
  if(firing&&!reloading&&!chambering)attemptFire();
  else if(!firing)shotsFired=0;
  
  // Reset streak on no kill
  if(player.streak>0&&player.kills>0){/* streak persists until death */}
  
  // Apply recoil to camera (then restore for rendering)
  pitchObject&&pitch.rotation.x;// handled inline
  pitch.rotation.x+=recoilState.curX+shake.x;
  yaw.rotation.y+=recoilState.curY+shake.y;
  
  renderer.render(scene,camera);
  
  pitch.rotation.x-=recoilState.curX+shake.x;
  yaw.rotation.y-=recoilState.curY+shake.y;
}

